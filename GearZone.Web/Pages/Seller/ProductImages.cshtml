@page
@model GearZone.Web.Pages.Seller.ProductImagesModel
@{
    ViewData["Title"] = "Quản lý ảnh sản phẩm";
}

<div class="max-w-5xl mx-auto px-4 py-8">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-8">
        <a href="javascript:history.back()" class="p-2 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="material-symbols-outlined text-gray-600">arrow_back</span>
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Quản lý ảnh sản phẩm</h1>
            <p class="text-sm text-gray-500 mt-1">Tối đa 10 ảnh, mỗi ảnh không quá 5MB (JPG, PNG, WEBP)</p>
        </div>
    </div>

    <!-- Alerts -->
    @if (Model.SuccessMessage != null)
    {
        <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center gap-3">
            <span class="material-symbols-outlined text-green-600">check_circle</span>
            <span class="text-green-800 font-medium">@Model.SuccessMessage</span>
        </div>
    }

    @if (Model.Errors.Any())
    {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-red-600">error</span>
                <span class="text-red-800 font-semibold">Có lỗi xảy ra:</span>
            </div>
            <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
                @foreach (var error in Model.Errors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    <!-- Upload Zone -->
    <div class="mb-8">
        <form method="post" asp-page-handler="Upload" enctype="multipart/form-data" id="uploadForm">
            <input type="hidden" asp-for="ProductId" />

            <div id="dropZone"
                 class="border-2 border-dashed border-gray-300 rounded-2xl p-10 text-center cursor-pointer
                        hover:border-primary hover:bg-primary/5 transition-all duration-300 group"
                 onclick="document.getElementById('fileInput').click()">
                <div class="flex flex-col items-center gap-4">
                    <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                        <span class="material-symbols-outlined text-3xl text-gray-400 group-hover:text-primary transition-colors">cloud_upload</span>
                    </div>
                    <div>
                        <p class="text-gray-700 font-semibold">Kéo thả ảnh vào đây hoặc <span class="text-primary">chọn file</span></p>
                        <p class="text-sm text-gray-400 mt-1">JPG, PNG, WEBP – Tối đa 5MB mỗi ảnh</p>
                    </div>
                </div>
                <input type="file" id="fileInput" name="files" multiple accept=".jpg,.jpeg,.png,.webp"
                       class="hidden" onchange="handleFileSelect(this)" />
            </div>

            <!-- Preview Area -->
            <div id="previewArea" class="hidden mt-4">
                <div class="flex items-center justify-between mb-3">
                    <p class="text-sm font-medium text-gray-700">
                        <span id="fileCount">0</span> file đã chọn
                    </p>
                    <button type="button" onclick="clearFiles()" class="text-sm text-red-500 hover:text-red-700 font-medium">
                        Xóa tất cả
                    </button>
                </div>
                <div id="previewGrid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3"></div>
                <button type="submit"
                        class="mt-4 w-full py-3 bg-primary text-white font-semibold rounded-xl
                               hover:bg-primary/90 transition-colors flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">upload</span>
                    Upload ảnh
                </button>
            </div>
        </form>
    </div>

    <!-- Current Images -->
    @if (Model.Images.Any())
    {
        <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                <span class="material-symbols-outlined text-[22px]">photo_library</span>
                Ảnh hiện tại (@Model.Images.Count/10)
            </h2>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                @foreach (var image in Model.Images)
                {
                    <div class="relative group rounded-xl overflow-hidden border-2 @(image.IsPrimary ? "border-primary shadow-lg" : "border-gray-200") transition-all">
                        <!-- Image -->
                        <div class="aspect-square bg-gray-100">
                            <img src="@image.ImageUrl" alt="Product image"
                                 class="w-full h-full object-cover" />
                        </div>

                        <!-- Primary Badge -->
                        @if (image.IsPrimary)
                        {
                            <div class="absolute top-2 left-2 bg-primary text-white text-xs font-bold px-2 py-1 rounded-lg flex items-center gap-1">
                                <span class="material-symbols-outlined text-[14px]">star</span>
                                Ảnh chính
                            </div>
                        }

                        <!-- Actions Overlay -->
                        <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2">
                            @if (!image.IsPrimary)
                            {
                                <form method="post" asp-page-handler="SetPrimary" class="inline">
                                    <input type="hidden" asp-for="ProductId" />
                                    <input type="hidden" name="imageId" value="@image.Id" />
                                    <button type="submit" title="Đặt làm ảnh chính"
                                            class="p-2 bg-white rounded-lg hover:bg-primary hover:text-white transition-colors text-gray-700">
                                        <span class="material-symbols-outlined text-[20px]">star</span>
                                    </button>
                                </form>
                            }

                            <form method="post" asp-page-handler="Delete" class="inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa ảnh này?')">
                                <input type="hidden" asp-for="ProductId" />
                                <input type="hidden" name="imageId" value="@image.Id" />
                                <button type="submit" title="Xóa ảnh"
                                        class="p-2 bg-white rounded-lg hover:bg-red-500 hover:text-white transition-colors text-gray-700">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-16 bg-gray-50 rounded-2xl">
            <span class="material-symbols-outlined text-6xl text-gray-300">image</span>
            <p class="text-gray-500 mt-4 font-medium">Chưa có ảnh nào</p>
            <p class="text-sm text-gray-400 mt-1">Hãy upload ảnh đầu tiên cho sản phẩm</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Drag & Drop
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const previewArea = document.getElementById('previewArea');
        const previewGrid = document.getElementById('previewGrid');
        const fileCount = document.getElementById('fileCount');

        ['dragenter', 'dragover'].forEach(e => {
            dropZone.addEventListener(e, (ev) => {
                ev.preventDefault();
                dropZone.classList.add('border-primary', 'bg-primary/5');
            });
        });

        ['dragleave', 'drop'].forEach(e => {
            dropZone.addEventListener(e, (ev) => {
                ev.preventDefault();
                dropZone.classList.remove('border-primary', 'bg-primary/5');
            });
        });

        dropZone.addEventListener('drop', (ev) => {
            ev.preventDefault();
            const dt = ev.dataTransfer;
            fileInput.files = dt.files;
            handleFileSelect(fileInput);
        });

        function handleFileSelect(input) {
            const files = input.files;
            if (!files.length) {
                previewArea.classList.add('hidden');
                return;
            }

            previewArea.classList.remove('hidden');
            previewGrid.innerHTML = '';
            fileCount.textContent = files.length;

            Array.from(files).forEach((file, idx) => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const div = document.createElement('div');
                    div.className = 'relative aspect-square rounded-xl overflow-hidden border border-gray-200 bg-gray-100';
                    div.innerHTML = `
                        <img src="${e.target.result}" alt="${file.name}"
                             class="w-full h-full object-cover" />
                        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-2">
                            <p class="text-white text-xs truncate">${file.name}</p>
                            <p class="text-white/70 text-xs">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                        </div>
                    `;
                    previewGrid.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        }

        function clearFiles() {
            fileInput.value = '';
            previewArea.classList.add('hidden');
            previewGrid.innerHTML = '';
        }
    </script>
}
