@page
@model GearZone.Web.Pages.Admin.PayoutBatches.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Payout Batches";
    ViewData["PageHeader"] = "Payout Batches";
    ViewData["ActivePage"] = "PayoutBatches";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Payout Batches" };
}

    <!-- Stats Widgets -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Gross -->
        <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col gap-3 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-4xl text-primary">payments</span>
            </div>
            <div class="flex items-center gap-2.5">
                <div class="size-9 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-[20px]">payments</span>
                </div>
                <span class="text-[11px] font-black text-slate-500 uppercase tracking-widest">Gross Revenue</span>
            </div>
            <div class="flex flex-col">
                <div class="text-2xl font-black text-slate-900 leading-none">@Model.Summary.TotalGrossAmount.ToString("N0") <span class="text-sm font-bold text-slate-400">₫</span></div>
                <div class="mt-2 flex items-center gap-1.5">
                    <span class="text-[10px] font-bold text-slate-400">TOTAL VOLUME</span>
                </div>
            </div>
        </div>

        <!-- Total Commission -->
        <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col gap-3 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-4xl text-blue-600">percent</span>
            </div>
            <div class="flex items-center gap-2.5">
                <div class="size-9 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600">
                    <span class="material-symbols-outlined text-[20px]">percent</span>
                </div>
                <span class="text-[11px] font-black text-slate-500 uppercase tracking-widest">Commission</span>
            </div>
            <div class="flex flex-col">
                <div class="text-2xl font-black text-slate-900 leading-none">@Model.Summary.TotalCommissionAmount.ToString("N0") <span class="text-sm font-bold text-slate-400">₫</span></div>
                <div class="mt-2 flex items-center gap-1.5">
                    <span class="text-[10px] font-bold text-slate-400">PLATFORM FEE</span>
                </div>
            </div>
        </div>

        <!-- Net Disbursed -->
        <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col gap-3 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-4xl text-green-600">account_balance_wallet</span>
            </div>
            <div class="flex items-center gap-2.5">
                <div class="size-9 rounded-xl bg-green-50 flex items-center justify-center text-green-600">
                    <span class="material-symbols-outlined text-[20px]">account_balance_wallet</span>
                </div>
                <span class="text-[11px] font-black text-slate-500 uppercase tracking-widest">Net Disbursed</span>
            </div>
            <div class="flex flex-col">
                <div class="text-2xl font-black text-slate-900 leading-none">@Model.Summary.TotalNetAmount.ToString("N0") <span class="text-sm font-bold text-slate-400">₫</span></div>
                <div class="mt-2 flex items-center gap-1.5">
                    <span class="text-[10px] font-bold text-slate-400">TO SELLERS</span>
                </div>
            </div>
        </div>

        <!-- Batch Count -->
        <div class="bg-white rounded-2xl p-5 shadow-card border border-slate-100 flex flex-col gap-3 relative overflow-hidden group">
            <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                <span class="material-symbols-outlined text-4xl text-violet-600">inventory_2</span>
            </div>
            <div class="flex items-center gap-2.5">
                <div class="size-9 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600">
                    <span class="material-symbols-outlined text-[20px]">inventory_2</span>
                </div>
                <span class="text-[11px] font-black text-slate-500 uppercase tracking-widest">Total Batches</span>
            </div>
            <div class="flex flex-col">
                <div class="text-2xl font-black text-slate-900 leading-none">@Model.Summary.BatchCount</div>
                <div class="mt-2 flex items-center gap-1.5">
                    <span class="text-[10px] font-bold text-slate-400">TOTAL BATCHES FOUND</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
        <form method="get" id="filter-form" class="flex flex-col">
            <input type="hidden" name="Query.PageNumber" id="page-number-input" value="@Model.Query.PageNumber" />

            <!-- Primary toolbar -->
            <div class="flex flex-col lg:flex-row gap-4 p-5 items-start lg:items-center bg-white border-b border-slate-50">
                <!-- Search -->
                <div class="relative flex-1 w-full">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400 pointer-events-none">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                    </span>
                    <input asp-for="Query.SearchTerm"
                           class="form-input w-full rounded-xl border-slate-200 bg-slate-50 pl-11 pr-4 py-2.5 text-sm font-semibold text-slate-900 placeholder:text-slate-400 placeholder:font-medium focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all"
                           placeholder="Search by batch code (e.g. BATCH-2026-W11)"
                           type="text" autocomplete="off" />
                </div>

                <!-- Date Range -->
                <div class="shrink-0 w-full lg:w-48">
                    <select asp-for="Query.DateRange"
                            class="form-select w-full rounded-xl border-slate-200 bg-slate-50 py-2.5 pl-4 px-10 text-sm font-semibold text-slate-900 focus:border-primary focus:ring-4 focus:ring-primary/10 shadow-sm transition-all"
                            onchange="this.form.submit()">
                        <option value="">All Time</option>
                        <option value="today">Today</option>
                        <option value="week">Past Week</option>
                        <option value="month">Past Month</option>
                        <option value="year">Past Year</option>
                        <option value="custom">Custom Range</option>
                    </select>
                </div>

                <!-- Status filter -->
                <div class="shrink-0 w-full lg:w-48">
                    <select asp-for="Query.Status"
                            class="form-select w-full rounded-xl border-slate-200 bg-slate-50 py-2.5 pl-4 px-10 text-sm font-semibold text-slate-900 focus:border-primary focus:ring-4 focus:ring-primary/10 shadow-sm transition-all"
                            onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        @foreach (var s in Enum.GetValues<GearZone.Domain.Enums.PayoutBatchStatus>())
                        {
                            <option value="@s" selected="@(Model.Query.Status == s)">@s</option>
                        }
                    </select>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-2 shrink-0 w-full lg:w-auto">
                    <button type="submit"
                            class="flex-1 lg:flex-none flex items-center justify-center gap-2 bg-slate-900 hover:bg-slate-800 text-white px-5 py-2.5 rounded-xl text-sm font-bold shadow-sm transition-all active:scale-[0.98]">
                        <span class="material-symbols-outlined text-[18px]">filter_list</span>
                        <span>Apply Filters</span>
                    </button>
                    <a asp-page="/Admin/PayoutBatches/Index"
                       class="flex items-center justify-center p-2.5 rounded-xl border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-colors bg-white shadow-sm"
                       title="Reset filters">
                        <span class="material-symbols-outlined text-[20px]">restart_alt</span>
                    </a>
                </div>
            </div>

            <!-- Custom date range inputs -->
            @if (Model.Query.DateRange == "custom")
            {
                <div class="flex items-center gap-4 p-4 bg-slate-50 border-t border-slate-100">
                    <div class="flex items-center gap-3">
                        <label class="text-[11px] font-black text-slate-500 uppercase">From</label>
                        <input type="date" asp-for="Query.StartDate" class="form-input rounded-lg border-slate-200 text-sm py-1.5 focus:border-primary focus:ring-primary" />
                    </div>
                    <div class="flex items-center gap-3">
                        <label class="text-[11px] font-black text-slate-500 uppercase">To</label>
                        <input type="date" asp-for="Query.EndDate" class="form-input rounded-lg border-slate-200 text-sm py-1.5 focus:border-primary focus:ring-primary" />
                    </div>
                    <button type="submit" class="bg-white border border-slate-200 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-bold hover:bg-slate-50 transition-all shadow-sm">Update Range</button>
                </div>
            }
        </form>
    </div>

    <!-- Batches Table -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden flex flex-col">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="py-4 pl-6 pr-3 text-[10px] font-black uppercase tracking-widest text-slate-400">Batch Info</th>
                        <th class="py-4 px-3 text-[10px] font-black uppercase tracking-widest text-slate-400">Period</th>
                        <th class="py-4 px-3 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Gross Revenue</th>
                        <th class="py-4 px-3 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Commission</th>
                        <th class="py-4 px-3 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Net Disbursed</th>
                        <th class="py-4 px-3 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Stores</th>
                        <th class="py-4 px-3 text-[10px] font-black uppercase tracking-widest text-slate-400 text-center">Status</th>
                        <th class="py-4 pr-6 pl-3 text-[10px] font-black uppercase tracking-widest text-slate-400 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Batches.Items.Any())
                    {
                        @foreach (var b in Model.Batches.Items)
                        {
                            <tr class="group hover:bg-slate-50/80 transition-all cursor-default data-row" data-href="/Admin/PayoutBatches/Details/@b.Id">
                                <td class="py-4 pl-6 pr-3 align-middle">
                                    <div class="flex flex-col">
                                        <span class="font-mono text-sm font-bold text-slate-900 group-hover:text-primary transition-colors">@b.BatchCode</span>
                                        <span class="text-[10px] text-slate-400 font-medium mt-0.5">CREATED: @b.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </td>
                                <td class="py-4 px-3 align-middle whitespace-nowrap">
                                    <div class="text-xs font-semibold text-slate-600">@b.PeriodStart.ToString("dd/MM/yy") – @b.PeriodEnd.ToString("dd/MM/yy")</div>
                                </td>
                                <td class="py-4 px-3 text-right align-middle whitespace-nowrap">
                                    <span class="text-sm font-bold text-slate-900">@b.TotalGrossAmount.ToString("N0") ₫</span>
                                </td>
                                <td class="py-4 px-3 text-right align-middle whitespace-nowrap">
                                    <span class="text-xs font-bold text-blue-600">-@b.TotalCommissionAmount.ToString("N0") ₫</span>
                                </td>
                                <td class="py-4 px-3 text-right align-middle whitespace-nowrap">
                                    <span class="text-sm font-black text-green-600">@b.TotalNetAmount.ToString("N0") ₫</span>
                                </td>
                                <td class="py-4 px-3 text-center align-middle">
                                    <div class="inline-flex items-center justify-center size-7 rounded-lg bg-slate-100 text-slate-600 font-bold text-xs">@b.TotalStores</div>
                                </td>
                                <td class="py-4 px-3 text-center align-middle">
                                    @{
                                        var (bg, text, dot) = b.Status switch
                                        {
                                            GearZone.Domain.Enums.PayoutBatchStatus.Draft => ("bg-slate-50 text-slate-600 border-slate-200", "Draft", "bg-slate-400"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.PendingApproval => ("bg-amber-50 text-amber-700 border-amber-200", "Review Requested", "bg-amber-400"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.Approved => ("bg-blue-50 text-blue-700 border-blue-200", "Approved", "bg-blue-400"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.Processing => ("bg-violet-50 text-violet-700 border-violet-200", "In Progress", "bg-violet-400"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.Completed => ("bg-green-50 text-green-700 border-green-200", "Completed", "bg-green-500"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.PartialFailed => ("bg-orange-50 text-orange-700 border-orange-200", "Attention Needed", "bg-orange-400"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.OnHold => ("bg-red-50 text-red-700 border-red-200", "On Hold", "bg-red-500"),
                                            _ => ("bg-slate-50 text-slate-600 border-slate-200", b.Status.ToString(), "bg-slate-400")
                                        };
                                    }
                                    <span class="inline-flex items-center gap-1.5 rounded-full border @bg px-2.5 py-1 text-[10px] font-black uppercase tracking-wider">
                                        <span class="size-1.5 rounded-full @dot"></span>
                                        @text
                                    </span>
                                </td>
                                <td class="py-4 pr-6 pl-3 align-middle text-right whitespace-nowrap">
                                    <div class="flex items-center justify-end gap-1.5">
                                        <a asp-page="/Admin/PayoutBatches/Details" asp-route-id="@b.Id"
                                           class="size-8 flex items-center justify-center rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm"
                                           onclick="event.stopPropagation()" title="View Details">
                                            <span class="material-symbols-outlined text-[18px]">visibility</span>
                                        </a>
                                        @if (b.Status == GearZone.Domain.Enums.PayoutBatchStatus.PendingApproval)
                                        {
                                            <button type="button"
                                                    onclick="openApproveModal('@b.Id'); event.stopPropagation()"
                                                    class="size-8 flex items-center justify-center rounded-lg bg-blue-50 border border-blue-200 text-blue-600 hover:bg-blue-600 hover:text-white transition-all shadow-sm"
                                                    title="Approve Batch">
                                                <span class="material-symbols-outlined text-[18px]">check</span>
                                            </button>
                                        }
                                        @if (b.Status == GearZone.Domain.Enums.PayoutBatchStatus.Approved)
                                        {
                                            <button type="button"
                                                    onclick="openProcessModal('@b.Id', '@b.BatchCode'); event.stopPropagation()"
                                                    class="size-8 flex items-center justify-center rounded-lg bg-violet-50 border border-violet-200 text-violet-600 hover:bg-violet-600 hover:text-white transition-all shadow-sm"
                                                    title="Process Payouts">
                                                <span class="material-symbols-outlined text-[18px]">bolt</span>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="py-16 text-center text-slate-500">
                                <div class="flex flex-col items-center justify-center space-y-4">
                                    <div class="size-20 rounded-full bg-slate-50 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-5xl text-slate-200">account_balance_wallet</span>
                                    </div>
                                    <div class="space-y-1">
                                        <p class="text-base font-bold text-slate-900">No batches match your criteria</p>
                                        <p class="text-sm text-slate-400">Try adjusting your search terms or filters</p>
                                    </div>
                                    <a asp-page="/Admin/PayoutBatches/Index" class="text-sm font-bold text-primary hover:underline">Clear all filters</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.Batches.TotalPages > 1)
        {
            <div class="flex items-center justify-between border-t border-slate-100 px-6 py-4">
                <span class="text-sm text-slate-500">
                    Showing @((Model.Batches.PageNumber - 1) * Model.Batches.PageSize + 1)–@(Math.Min(Model.Batches.PageNumber * Model.Batches.PageSize, Model.Batches.TotalCount)) of @Model.Batches.TotalCount.ToString("N0") batches
                </span>
                <nav class="flex items-center gap-1.5">
                    @if (Model.Batches.PageNumber > 1)
                    {
                        <button type="button" onclick="gotoPage(@(Model.Batches.PageNumber - 1))" class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm">
                            <span class="material-symbols-outlined text-lg leading-none">chevron_left</span>
                        </button>
                    }
                    <span class="px-3 py-1.5 text-sm font-medium text-slate-700">@Model.Batches.PageNumber / @Model.Batches.TotalPages</span>
                    @if (Model.Batches.PageNumber < Model.Batches.TotalPages)
                    {
                        <button type="button" onclick="gotoPage(@(Model.Batches.PageNumber + 1))" class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm">
                            <span class="material-symbols-outlined text-lg leading-none">chevron_right</span>
                        </button>
                    }
                </nav>
            </div>
        }
    </div>
</div>

<!-- Approve Modal -->
<div id="approve-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-2">Approve Batch</h3>
        <p class="text-sm text-slate-500 mb-5">Are you sure you want to approve this payout batch? This action cannot be undone.</p>
        <form method="post" id="approve-form">
            <input type="hidden" name="id" id="approve-batch-id" />
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeModal('approve-modal')" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" asp-page-handler="ApproveBatch" class="px-5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold shadow-sm transition-colors">Approve</button>
            </div>
        </form>
    </div>
</div>

<!-- Hold Modal -->
<div id="hold-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-2">Hold Batch</h3>
        <p class="text-sm text-slate-500 mb-3">Please provide a reason for placing this batch on hold.</p>
        <form method="post" id="hold-form">
            <input type="hidden" name="id" id="hold-batch-id" />
            <textarea name="reason" rows="3" class="form-input w-full rounded-lg border-slate-200 py-2 px-3 text-sm mb-4 focus:ring-primary focus:border-primary" placeholder="Hold reason…" required></textarea>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeModal('hold-modal')" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" asp-page-handler="HoldBatch" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-semibold shadow-sm transition-colors">Confirm Hold</button>
            </div>
        </form>
    </div>
</div>

<!-- Process Modal -->
<div id="process-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-2">Process Batch</h3>
        <p class="text-sm text-slate-500 mb-5">This will initiate all pending payout transactions in this batch via PayOS. Continue?</p>
        <form method="post" id="process-form">
            <input type="hidden" name="id" id="process-batch-id" />
            <input type="hidden" name="batchCode" id="process-batch-code" />
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeModal('process-modal')" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" asp-page-handler="ProcessBatch" class="px-5 py-2 rounded-lg bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold shadow-sm transition-colors">Process</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function gotoPage(page) {
            document.getElementById('page-number-input').value = page;
            document.getElementById('filter-form').submit();
        }

        function openApproveModal(id) {
            document.getElementById('approve-batch-id').value = id;
            document.getElementById('approve-modal').classList.remove('hidden');
        }

        function openHoldModal(id) {
            document.getElementById('hold-batch-id').value = id;
            document.getElementById('hold-modal').classList.remove('hidden');
        }

        function openProcessModal(id, code) {
            document.getElementById('process-batch-id').value = id;
            document.getElementById('process-batch-code').value = code;
            document.getElementById('process-modal').classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        // Row click navigate
        document.querySelectorAll('.data-row').forEach(row => {
            row.addEventListener('click', function (e) {
                if (!e.target.closest('a') && !e.target.closest('button')) {
                    window.location.href = this.dataset.href;
                }
            });
        });
    </script>
}
