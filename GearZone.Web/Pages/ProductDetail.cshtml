@page "/product/{slug}"
@model GearZone.Web.Pages.ProductDetailModel
@{
    ViewData["Title"] = Model.Product.Name + " | GearZone";
}

<div class="max-w-7xl mx-auto px-4 py-6">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-[18px]">home</span>
        </a>
        @foreach (var crumb in Model.Product.Breadcrumbs)
        {
            <span class="material-symbols-outlined text-[16px] text-gray-300">chevron_right</span>
            @if (crumb.Slug != null)
            {
                <a href="/category/@crumb.Slug" class="hover:text-primary transition-colors">@crumb.Name</a>
            }
            else
            {
                <span>@crumb.Name</span>
            }
        }
        <span class="material-symbols-outlined text-[16px] text-gray-300">chevron_right</span>
        <span class="text-gray-700 font-medium truncate max-w-[200px]">@Model.Product.Name</span>
    </nav>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">

        <!-- === LEFT: Image Gallery === -->
        <div>
            <!-- Main Image -->
            <div class="relative aspect-square bg-gray-100 rounded-2xl overflow-hidden mb-4 border border-gray-200">
                @if (Model.Product.Images.Any())
                {
                    <img id="mainImage" src="@Model.Product.Images.First().ImageUrl" alt="@Model.Product.Name"
                         class="w-full h-full object-contain transition-all duration-300" />
                }
                else
                {
                    <div class="flex items-center justify-center h-full">
                        <span class="material-symbols-outlined text-8xl text-gray-300">image</span>
                    </div>
                }
            </div>

            <!-- Thumbnails -->
            @if (Model.Product.Images.Count > 1)
            {
                <div class="flex gap-3 overflow-x-auto pb-2">
                    @foreach (var image in Model.Product.Images)
                    {
                        <button onclick="setMainImage('@image.ImageUrl', this)"
                                class="flex-shrink-0 w-20 h-20 rounded-xl overflow-hidden border-2 transition-all
                                       @(image.IsPrimary ? "border-primary ring-2 ring-primary/20" : "border-gray-200 hover:border-gray-400") thumbnail-btn">
                            <img src="@image.ImageUrl" alt="" class="w-full h-full object-cover" />
                        </button>
                    }
                </div>
            }
        </div>

        <!-- === RIGHT: Product Info === -->
        <div>
            <!-- Name -->
            <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">@Model.Product.Name</h1>

            <!-- Rating -->
            <div class="flex items-center gap-3 mb-4">
                <div class="flex items-center gap-1">
                    @for (int i = 0; i < 5; i++)
                    {
                        <span class="material-symbols-outlined text-[20px] @(i < (int)Model.Product.AverageRating ? "text-yellow-400" : "text-gray-300")">star</span>
                    }
                </div>
                <span class="text-sm text-gray-500">(@Model.Product.ReviewCount đánh giá)</span>
            </div>

            <!-- Price -->
            <div class="bg-gradient-to-r from-orange-50 to-red-50 rounded-2xl p-5 mb-6">
                @if (Model.Product.MinPrice == Model.Product.MaxPrice || Model.Product.Variants.Count <= 1)
                {
                    <div class="text-3xl font-bold text-red-600">
                        @Model.Product.MinPrice.ToString("N0") ₫
                    </div>
                }
                else
                {
                    <div class="text-3xl font-bold text-red-600">
                        @Model.Product.MinPrice.ToString("N0") ₫ – @Model.Product.MaxPrice.ToString("N0") ₫
                    </div>
                }
            </div>

            <!-- Variants -->
            @if (Model.Product.Variants.Any())
            {
                <div class="mb-6">
                    <h3 class="text-sm font-semibold text-gray-700 mb-3">Phân loại:</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var variant in Model.Product.Variants)
                        {
                            <button onclick="selectVariant('@variant.Id', '@variant.Price', this)"
                                    class="variant-btn px-4 py-2 rounded-xl border-2 border-gray-200 text-sm font-medium
                                           hover:border-primary hover:text-primary transition-all
                                           @(variant.StockQuantity > 0 ? "" : "opacity-50 cursor-not-allowed")"
                                    @(variant.StockQuantity <= 0 ? "disabled" : "")>
                                @variant.VariantName
                                @if (variant.StockQuantity <= 0)
                                {
                                    <span class="text-xs text-red-500 ml-1">(Hết hàng)</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }

            <!-- Stock Status -->
            @{
                var totalStock = Model.Product.Variants.Sum(v => v.StockQuantity);
            }
            <div class="flex items-center gap-2 mb-6">
                @if (totalStock > 0)
                {
                    <span class="material-symbols-outlined text-green-500 text-[20px]">check_circle</span>
                    <span class="text-sm text-green-600 font-medium">Còn hàng (@totalStock sản phẩm)</span>
                }
                else
                {
                    <span class="material-symbols-outlined text-red-500 text-[20px]">cancel</span>
                    <span class="text-sm text-red-500 font-medium">Hết hàng</span>
                }
            </div>

            <!-- Actions -->
            <div class="flex gap-3 mb-8">
                <button class="flex-1 py-3 bg-primary text-white font-semibold rounded-xl
                               hover:bg-primary/90 transition-colors flex items-center justify-center gap-2
                               @(totalStock <= 0 ? "opacity-50 cursor-not-allowed" : "")"
                        @(totalStock <= 0 ? "disabled" : "")>
                    <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                    Thêm vào giỏ hàng
                </button>
                <button class="px-4 py-3 border-2 border-gray-200 rounded-xl hover:border-red-400 hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined text-[22px]">favorite</span>
                </button>
            </div>

            <!-- Store Info -->
            <div class="bg-gray-50 rounded-2xl p-4 flex items-center gap-4">
                <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center border border-gray-200 overflow-hidden">
                    @if (!string.IsNullOrEmpty(Model.Product.Store.LogoUrl))
                    {
                        <img src="@Model.Product.Store.LogoUrl" alt="@Model.Product.Store.StoreName" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-gray-400">storefront</span>
                    }
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-semibold text-gray-900 truncate">@Model.Product.Store.StoreName</p>
                    <a href="/store/@Model.Product.Store.Slug" class="text-sm text-primary hover:underline">Xem thêm sản phẩm →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs: Mô tả / Thông số kỹ thuật -->
    <div class="border-t border-gray-200 pt-8">
        <!-- Tab Buttons -->
        <div class="flex gap-1 mb-6 bg-gray-100 rounded-xl p-1 max-w-md">
            <button onclick="switchTab('description', this)"
                    class="tab-btn flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all bg-white text-primary shadow-sm">
                Mô tả
            </button>
            <button onclick="switchTab('specs', this)"
                    class="tab-btn flex-1 py-2.5 px-4 rounded-lg text-sm font-semibold transition-all text-gray-500 hover:text-gray-700">
                Thông số kỹ thuật
            </button>
        </div>

        <!-- Tab: Mô tả -->
        <div id="tab-description" class="tab-content">
            <div class="prose prose-gray max-w-none">
                @if (!string.IsNullOrWhiteSpace(Model.Product.Description))
                {
                    <div class="text-gray-700 leading-relaxed whitespace-pre-line">@Model.Product.Description</div>
                }
                else
                {
                    <p class="text-gray-400 italic">Chưa có mô tả cho sản phẩm này.</p>
                }
            </div>
        </div>

        <!-- Tab: Thông số kỹ thuật -->
        <div id="tab-specs" class="tab-content hidden">
            @if (Model.Product.Specs.Any())
            {
                <div class="overflow-hidden rounded-xl border border-gray-200">
                    <table class="w-full">
                        @{ var isEven = false; }
                        @foreach (var spec in Model.Product.Specs)
                        {
                            <tr class="@(isEven ? "bg-gray-50" : "bg-white")">
                                <td class="px-5 py-3 text-sm font-semibold text-gray-600 w-1/3 border-r border-gray-100">@spec.Key</td>
                                <td class="px-5 py-3 text-sm text-gray-900">@spec.Value</td>
                            </tr>
                            isEven = !isEven;
                        }
                    </table>
                </div>
            }
            else
            {
                <p class="text-gray-400 italic">Chưa có thông số kỹ thuật.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Gallery: switch main image
        function setMainImage(url, btn) {
            document.getElementById('mainImage').src = url;
            document.querySelectorAll('.thumbnail-btn').forEach(b => {
                b.classList.remove('border-primary', 'ring-2', 'ring-primary/20');
                b.classList.add('border-gray-200');
            });
            btn.classList.add('border-primary', 'ring-2', 'ring-primary/20');
            btn.classList.remove('border-gray-200');
        }

        // Variant selector
        function selectVariant(id, price, btn) {
            document.querySelectorAll('.variant-btn').forEach(b => {
                b.classList.remove('border-primary', 'text-primary', 'bg-primary/5');
                b.classList.add('border-gray-200');
            });
            btn.classList.add('border-primary', 'text-primary', 'bg-primary/5');
            btn.classList.remove('border-gray-200');
        }

        // Tab switching
        function switchTab(tab, btn) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.getElementById('tab-' + tab).classList.remove('hidden');

            document.querySelectorAll('.tab-btn').forEach(b => {
                b.classList.remove('bg-white', 'text-primary', 'shadow-sm');
                b.classList.add('text-gray-500');
            });
            btn.classList.add('bg-white', 'text-primary', 'shadow-sm');
            btn.classList.remove('text-gray-500');
        }
    </script>
}
