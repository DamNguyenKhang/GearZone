@page "/admin/payouts"
@model GearZone.Web.Pages.Admin.Payouts.IndexModel
@{
    ViewData["Title"] = "Payout Management";
    ViewData["PageHeader"] = "Payout Management";
    ViewData["ActivePage"] = "Payouts";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Finance", "Payouts" };
    Layout = "_AdminLayout";
}

<div class="flex flex-col gap-6">
    <!-- Stats Overview -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-[24px]">payments</span>
            </div>
            <div>
                <p class="text-slate-500 text-xs font-medium uppercase tracking-wider">Total Payouts</p>
                <h3 class="text-2xl font-bold text-slate-900">$12,450.00</h3>
            </div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-[24px]">pending_actions</span>
            </div>
            <div>
                <p class="text-slate-500 text-xs font-medium uppercase tracking-wider">Pending Approvals</p>
                <h3 class="text-2xl font-bold text-slate-900">5</h3>
            </div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-[24px]">task_alt</span>
            </div>
            <div>
                <p class="text-slate-500 text-xs font-medium uppercase tracking-wider">Completed</p>
                <h3 class="text-2xl font-bold text-slate-900">128</h3>
            </div>
        </div>
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-red-50 text-red-600 flex items-center justify-center">
                <span class="material-symbols-outlined text-[24px]">error</span>
            </div>
            <div>
                <p class="text-slate-500 text-xs font-medium uppercase tracking-wider">Failed/Rejected</p>
                <h3 class="text-2xl font-bold text-slate-900">2</h3>
            </div>
        </div>
    </div>

    <!-- Filters & Actions Bar -->
    <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex flex-col gap-4">
        <form method="get" class="flex flex-col lg:flex-row gap-4 justify-between items-start lg:items-end">
            <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto flex-1">
                <!-- Search -->
                <div class="relative w-full sm:max-w-xs">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                    </span>
                    <input name="searchTerm" class="form-input w-full rounded-lg border-slate-200 bg-slate-50 pl-10 pr-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-primary focus:ring-primary" placeholder="Search Store or Payout ID..." type="text" />
                </div>
                <!-- Status Filter -->
                <div class="w-full sm:w-40">
                    <select name="status" class="form-select w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 text-sm text-slate-900 focus:border-primary focus:ring-primary">
                        <option value="">All Status</option>
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Completed">Completed</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
                <!-- Date Filter -->
                <div class="w-full flex gap-2 sm:w-80">
                    <div class="relative w-1/2">
                        <input type="date" name="startDate" class="form-input w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 px-3 text-sm text-slate-900 focus:border-primary focus:ring-primary" title="Start Date" />
                    </div>
                    <div class="relative w-1/2">
                        <input type="date" name="endDate" class="form-input w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 px-3 text-sm text-slate-900 focus:border-primary focus:ring-primary" title="End Date" />
                    </div>
                </div>
                <button type="button"
                        class="w-full sm:w-auto h-[42px] px-5 flex items-center justify-center gap-2 bg-slate-800 text-white border border-slate-800 text-sm rounded-lg font-medium hover:bg-slate-900 transition-all shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">search</span>
                    Search
                </button>
            </div>
            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-2 w-full lg:w-auto">
                <button type="button" class="w-full sm:w-auto h-[42px] px-5 flex items-center justify-center gap-2 bg-white border border-slate-200 text-slate-700 text-sm rounded-lg font-medium hover:bg-slate-50 transition-all shadow-sm">
                    <span class="material-symbols-outlined text-[20px]">download</span>
                    <span>Export CSV</span>
                </button>
            </div>
        </form>

    </div>

    <!-- Data Table Card -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden flex flex-col">
        <div class="overflow-x-auto w-full">
            <table class="w-full text-left border-collapse min-w-max">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="py-4 pl-6 pr-3 text-xs font-semibold uppercase tracking-wider text-slate-500 w-[50px]">
                            <input class="rounded border-slate-300 text-primary focus:ring-primary size-4" type="checkbox" id="selectAll" />
                        </th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap">Payout ID</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap">Store Info</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap text-right">Gross Revenue</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap text-right">Commission</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap text-right">Net Disbursed</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap">Bank Reference</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap">Status</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 whitespace-nowrap">Request Date</th>
                        <th class="py-4 pl-3 pr-6 text-xs font-semibold uppercase tracking-wider text-slate-500 text-right whitespace-nowrap">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <!-- Example row for Pending Status -->
                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer" onclick="if(!event.target.closest('a, button, input')) window.location.href='/admin/payouts/transactions/PAY-4890'">
                        <td class="py-4 pl-6 pr-3 align-middle">
                            <input class="rounded border-slate-300 text-primary focus:ring-primary size-4 row-checkbox" type="checkbox" value="PAY-4890" />
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-sm font-medium text-slate-900 group-hover:text-primary transition-colors">
                            <a asp-page="/Admin/Payouts/TransactionDetail" asp-route-id="PAY-4890">#PAY-4890</a>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap">
                            <div class="flex items-center gap-3">
                                <div class="size-9 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center font-bold text-xs shadow-sm flex-shrink-0">GG</div>
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-slate-900">Gear Galaxy</span>
                                    <span class="text-[10px] text-slate-500">owner@geargalaxy.com</span>
                                </div>
                            </div>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-right">
                            <span class="text-sm font-medium text-slate-700">$1,500.00</span>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-right">
                            <span class="text-sm font-medium text-slate-500">-$250.00 <span class="text-[10px] bg-slate-100 px-1 py-0.5 rounded text-slate-400">16.6%</span></span>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-right">
                            <span class="text-sm font-bold text-emerald-600">$1,250.00</span>
                        </td>
                        <td class="py-4 px-3 text-slate-500 text-sm whitespace-nowrap">
                            ***7890 (Techcombank)
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-600/20">
                                <span class="size-1.5 rounded-full bg-amber-500"></span>
                                Pending
                            </span>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap">
                            <div class="flex flex-col">
                                <span class="text-sm text-slate-900">Mar 09, 2026</span>
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">10:30 AM</span>
                            </div>
                        </td>
                        <td class="py-4 pl-3 pr-6 text-right whitespace-nowrap">
                            <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-page="/Admin/Payouts/TransactionDetail" asp-route-id="PAY-4890" class="text-slate-400 hover:text-primary transition-colors p-1 flex items-center justify-center" title="View Details">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </a>
                                <button class="text-slate-400 hover:text-emerald-500 transition-colors p-1" title="Approve">
                                    <span class="material-symbols-outlined text-[20px]">check_circle</span>
                                </button>
                                <button class="text-slate-400 hover:text-red-500 transition-colors p-1" title="Reject">
                                    <span class="material-symbols-outlined text-[20px]">cancel</span>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <!-- Example row for Completed Status -->
                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer" onclick="if(!event.target.closest('a, button, input')) window.location.href='/admin/payouts/transactions/PAY-4889'">
                        <td class="py-4 pl-6 pr-3 align-middle">
                            <input class="rounded border-slate-300 text-primary focus:ring-primary size-4 row-checkbox" type="checkbox" value="PAY-4889" />
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-sm font-medium text-slate-900 group-hover:text-primary transition-colors">
                            <a asp-page="/Admin/Payouts/TransactionDetail" asp-route-id="PAY-4889">#PAY-4889</a>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap">
                            <div class="flex items-center gap-3">
                                <div class="size-9 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-xs shadow-sm flex-shrink-0">TC</div>
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-slate-900">Tech Corner</span>
                                    <span class="text-[10px] text-slate-500">contact@techcorner.com</span>
                                </div>
                            </div>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-right">
                            <span class="text-sm font-medium text-slate-700">$1,000.00</span>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-right">
                            <span class="text-sm font-medium text-slate-500">-$149.50 <span class="text-[10px] bg-slate-100 px-1 py-0.5 rounded text-slate-400">15%</span></span>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap text-right">
                            <span class="text-sm font-bold text-emerald-600">$850.50</span>
                        </td>
                        <td class="py-4 px-3 text-slate-500 text-sm whitespace-nowrap">
                            ***1234 (Vietcombank)
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-50 text-green-700 ring-1 ring-inset ring-green-600/20">
                                <span class="size-1.5 rounded-full bg-green-500"></span>
                                Completed
                            </span>
                        </td>
                        <td class="py-4 px-3 whitespace-nowrap">
                            <div class="flex flex-col">
                                <span class="text-sm text-slate-900">Mar 08, 2026</span>
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">02:15 PM</span>
                            </div>
                        </td>
                        <td class="py-4 pl-3 pr-6 text-right whitespace-nowrap">
                            <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a asp-page="/Admin/Payouts/TransactionDetail" asp-route-id="PAY-4889" class="text-slate-400 hover:text-primary transition-colors p-1 flex items-center justify-center" title="View Details">
                                    <span class="material-symbols-outlined text-[20px]">visibility</span>
                                </a>
                                <button class="text-slate-400 hover:text-slate-600 transition-colors p-1" title="Download Receipt">
                                    <span class="material-symbols-outlined text-[20px]">receipt</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="border-t border-slate-100 px-6 py-4 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="text-sm text-slate-500">
                Showing <span class="font-medium text-slate-900">1</span> to 
                <span class="font-medium text-slate-900">2</span> of 
                <span class="font-medium text-slate-900">2</span> payouts
            </div>
            
            <nav aria-label="Pagination" class="flex items-center gap-1">
                <button disabled title="Previous" class="p-2 rounded-lg border border-slate-200 bg-white text-slate-400 opacity-50 cursor-not-allowed">
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                </button>
                <div class="flex items-center gap-1 px-1">
                    <button title="Page 1" class="size-9 rounded-lg border border-primary bg-primary text-white text-sm font-bold shadow-sm shadow-primary/20 transition-all">1</button>
                </div>
                <button disabled title="Next" class="p-2 rounded-lg border border-slate-200 bg-white text-slate-400 opacity-50 cursor-not-allowed">
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                </button>
            </nav>
        </div>
    </div>
</div>

<!-- Floating Bulk Actions Bar -->
<div id="bulkActionsContainer" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden transition-all duration-300 translate-y-4 opacity-0">
    <div class="bg-[#4a89db] px-5 py-3 rounded-xl shadow-2xl flex items-center gap-4 text-white">
        <div class="flex items-center gap-2.5 border-r border-white/20 pr-4">
            <span class="font-bold text-xl" id="selectedCountDisplay">0</span>
            <div class="flex flex-col text-xs font-semibold leading-[1.1] text-blue-50">
                <span>payouts</span>
                <span>selected</span>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <button type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-orange-500 hover:bg-orange-600 transition-colors text-sm font-medium shadow-sm text-white">
                <span class="material-symbols-outlined text-[18px]">payments</span>
                Process Payout
            </button>
            <button type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-white/30 hover:bg-white/10 transition-colors text-sm font-medium text-white">
                <span class="material-symbols-outlined text-[18px]">check_circle</span>
                Approve
            </button>
            <button type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-white/30 hover:bg-white/10 transition-colors text-sm font-medium text-white">
                <span class="material-symbols-outlined text-[18px]">cancel</span>
                Reject
            </button>
            <button type="button" id="closeBulkActionsBtn" class="flex items-center justify-center p-1 rounded-lg hover:bg-black/10 transition-colors ml-1 text-blue-100 hover:text-white">
                <span class="material-symbols-outlined text-[20px]">close</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const selectAll = document.getElementById('selectAll');
            const rowCheckboxes = document.querySelectorAll('.row-checkbox');
            const bulkActionsContainer = document.getElementById('bulkActionsContainer');
            const selectedCountDisplay = document.getElementById('selectedCountDisplay');
            const selectedCount = document.getElementById('selectedCount');

            function updateProcessButton() {
                const checkedCount = document.querySelectorAll('.row-checkbox:checked').length;
                if (checkedCount > 0) {
                    if (bulkActionsContainer) {
                        bulkActionsContainer.classList.remove('hidden');
                        // Use a tiny timeout to ensure the display change applies before transition begins
                        setTimeout(() => {
                            bulkActionsContainer.classList.remove('translate-y-4', 'opacity-0');
                            bulkActionsContainer.classList.add('translate-y-0', 'opacity-100');
                        }, 10);
                    }
                    if (selectedCountDisplay) selectedCountDisplay.textContent = checkedCount;
                } else {
                    if (bulkActionsContainer) {
                        bulkActionsContainer.classList.remove('translate-y-0', 'opacity-100');
                        bulkActionsContainer.classList.add('translate-y-4', 'opacity-0');
                        // Wait for transition before hiding element
                        setTimeout(() => {
                            // Check again in case user rapidly checked something else
                            if (document.querySelectorAll('.row-checkbox:checked').length === 0) {
                                bulkActionsContainer.classList.add('hidden');
                            }
                        }, 300);
                    }
                }
            }

            const closeBulkActionsBtn = document.getElementById('closeBulkActionsBtn');
            if (closeBulkActionsBtn) {
                closeBulkActionsBtn.addEventListener('click', () => {
                    if (selectAll) selectAll.checked = false;
                    rowCheckboxes.forEach(cb => cb.checked = false);
                    updateProcessButton();
                });
            }

            if (selectAll) {
                selectAll.addEventListener('change', function() {
                    rowCheckboxes.forEach(cb => {
                        cb.checked = selectAll.checked;
                    });
                    updateProcessButton();
                });
            }

            rowCheckboxes.forEach(cb => {
                cb.addEventListener('change', function() {
                    const allChecked = Array.from(rowCheckboxes).every(c => c.checked);
                    const someChecked = Array.from(rowCheckboxes).some(c => c.checked);
                    
                    if (selectAll) {
                        selectAll.checked = allChecked;
                        selectAll.indeterminate = someChecked && !allChecked;
                    }
                    updateProcessButton();
                });
            });
        });
    </script>
}
