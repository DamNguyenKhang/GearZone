@model GearZone.Application.Features.Catalog.DTOs.CatalogProductDto
@{
    var viewMode = ViewData["ViewMode"]?.ToString() ?? "grid";
    var isList = viewMode == "list";
}

<div class="bg-white dark:bg-surface-dark rounded-xl border border-border-light dark:border-border-dark shadow-soft hover:shadow-hover hover:-translate-y-1 transition-all duration-300 group flex @(isList ? "flex-row h-auto sm:h-56" : "flex-col") relative overflow-hidden">
    @if(Model.SaleBadges.Any())
    {
        <div class="absolute top-3 left-3 z-10 bg-price-red text-white text-[10px] font-bold px-2 py-1 rounded">@Model.SaleBadges.First()</div>
    }
    
    <!-- Premium Compare Toggle -->
    <div class="absolute top-3 right-3 z-10 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
        <label class="relative flex items-center gap-2 cursor-pointer group/toggle">
            <input class="peer sr-only compare-checkbox" 
                   type="checkbox" 
                   data-product-id="@Model.Id" 
                   data-product-name="@Model.Name" 
                   data-product-image="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder.png" : Model.ImageUrl)"
                   data-category-id="@Model.CategoryId" />
            <div class="flex items-center gap-2 px-3 py-1.5 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border border-slate-200 dark:border-slate-800 rounded-full shadow-lg transition-all peer-checked:bg-primary peer-checked:border-primary group-hover/toggle:border-primary/50">
                <span class="material-symbols-outlined text-[16px] text-slate-500 dark:text-slate-400 peer-checked:text-white transition-colors">compare_arrows</span>
                <span class="text-[10px] font-black uppercase tracking-widest text-slate-600 dark:text-slate-300 peer-checked:text-white transition-colors">Compare</span>
            </div>
            <!-- Checkmark badge that pops out when selected -->
            <div class="absolute -top-1 -right-1 w-4 h-4 bg-secondary text-white rounded-full flex items-center justify-center scale-0 peer-checked:scale-100 transition-transform duration-300 shadow-sm">
                <span class="material-symbols-outlined text-[10px] font-bold">check</span>
            </div>
        </label>
    </div>
    
    <!-- Image Section -->
    <a href="/product/@Model.Slug" class="@(isList ? "w-40 sm:w-56 flex-shrink-0" : "p-4 flex items-center justify-center h-48") bg-white relative block">
        <img class="w-full h-full object-contain p-4 mix-blend-multiply dark:mix-blend-normal" alt="@Model.Name" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder.png" : Model.ImageUrl)"/>
    </a>
    
    <!-- Content Section -->
    <div class="p-4 flex flex-col gap-2 flex-1 @(isList ? "" : "border-t") border-border-light dark:border-border-dark">
        <div class="flex items-center gap-2 mb-1">
            <span class="text-[10px] font-bold uppercase tracking-wider text-text-secondary border border-border-light dark:border-border-dark px-1.5 rounded">@Model.BrandName</span>
            @if(Model.ReviewCount > 0)
            {
                <div class="flex items-center gap-0.5 text-amber-400">
                    <span class="material-symbols-outlined text-[14px] fill-current">star</span>
                    <span class="text-xs font-medium text-text-secondary ml-1">@Model.Rating.ToString("0.0") (@Model.ReviewCount)</span>
                </div>
            }
        </div>
        
        <h3 class="font-bold text-sm sm:text-base text-text-main dark:text-white leading-snug line-clamp-2 min-h-[2.5em] group-hover:text-primary transition-colors cursor-pointer">
            <a href="/product/@Model.Slug">@Model.Name</a>
        </h3>
        
        <div class="hidden sm:flex flex-wrap gap-1 my-1">
            @foreach(var tag in Model.HighlightTags)
            {
                <span class="text-[10px] bg-background-light dark:bg-gray-800 text-text-secondary px-1.5 py-0.5 rounded">@tag</span>
            }
        </div>
        
        <div class="@(isList ? "flex flex-row sm:items-center justify-between gap-4 mt-auto" : "mt-auto pt-2 flex flex-col gap-1")">
            <div class="flex flex-col @(isList ? "sm:flex-row sm:items-baseline" : "") gap-1 sm:gap-2">
                <span class="text-lg sm:text-xl font-bold text-primary">@Model.BasePrice.ToString("N0") VND</span>
                @if (Model.OriginalPrice.HasValue)
                {
                    <span class="text-xs text-text-secondary line-through decoration-slate-400">@Model.OriginalPrice.Value.ToString("N0") VND</span>
                }
            </div>
            
            <div class="@(isList ? "flex items-center gap-4" : "flex flex-col gap-1")">
                <div class="@(isList ? "hidden sm:flex" : "flex") items-center gap-2">
                    <div class="w-5 h-5 rounded-full bg-gray-200 overflow-hidden flex-shrink-0">
                        <img alt="Store Logo" class="w-full h-full object-cover" src="@(string.IsNullOrEmpty(Model.StoreLogoUrl) ? "/images/store-placeholder.png" : Model.StoreLogoUrl)"/>
                    </div>
                    <span class="text-xs text-text-secondary truncate">@Model.StoreName</span>
                </div>
                
                <button class="@(isList ? "w-auto px-4 sm:px-6 mt-0" : "w-full mt-2") bg-secondary/10 hover:bg-secondary text-secondary hover:text-white font-semibold py-2 rounded-lg text-sm transition-all flex items-center justify-center gap-2 group-btn add-to-cart-grid-btn" 
                        data-variant-id="@Model.DefaultVariantId"
                        @(Model.IsInStock ? "" : "disabled")>
                    <span class="material-symbols-outlined text-[18px]">shopping_cart</span>
                    @(Model.IsInStock ? (isList ? "" : "Add to Cart") : "Out of Stock")
                    @if(isList && Model.IsInStock) { <span class="hidden sm:inline">Add to Cart</span> }
                </button>
            </div>
        </div>
    </div>
</div>



