            background: #f8fafc;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #cbd5e1;
        }

        .date-pill.active {
            background-color: #1A56DB !important;
            color: white !important;
            box-shadow: 0 4px 6px -1px rgba(26, 86, 219, 0.2);
        }
    </style>
}

@section Scripts {
    <script>
        function toggleDetailPanel() {
            const panel = document.getElementById('detailPanel');
            if (panel.classList.contains('translate-x-full')) {
                panel.classList.remove('translate-x-full');
            } else {
                panel.classList.add('translate-x-full');
            }
        }

        function toggleAdvancedFilters() {
            const section = document.getElementById('advanced-filters-section');
            section.classList.toggle('hidden');
        }

        // --- Types Dropdown Logic ---
        function toggleTypesDropdown() {
            const panel = document.getElementById('types-dropdown-panel');
            panel.classList.toggle('hidden');
        }

        function selectAllTypes() {
            document.querySelectorAll('input[name="Types"]').forEach(cb => cb.checked = true);
            updateTypesLabel();
        }

        function clearAllTypes() {
            document.querySelectorAll('input[name="Types"]').forEach(cb => cb.checked = false);
            updateTypesLabel();
        }

        function updateTypesLabel() {
            const checked = document.querySelectorAll('input[name="Types"]:checked');
            const total = document.querySelectorAll('input[name="Types"]').length;
            const label = document.getElementById('types-selected-label');
            
            if (checked.length === 0) label.innerText = "Select Types";
            else if (checked.length === total) label.innerText = "All Types";
            else if (checked.length === 1) label.innerText = checked[0].parentElement.querySelector('span.text-sm').innerText;
            else label.innerText = `${checked.length} Types`;
        }

        function applyTypesFilter() {
            document.getElementById('types-dropdown-panel').classList.add('hidden');
            // Form submission will happen on "Apply Filters" or Search
        }

        // --- Export & Store Logic ---
        function toggleExportDropdown() {
            document.getElementById('export-dropdown-panel').classList.toggle('hidden');
        }

        function toggleStoreSearch(show) {
            const panel = document.getElementById('store-search-panel');
            if (show) panel.classList.remove('hidden');
            else setTimeout(() => panel.classList.add('hidden'), 200);
        }

        // --- KPI Card Filter Logic ---
        function filterByStatus(status) {
            const statusSelect = document.querySelector('select[name="Status"]');
            if (statusSelect) {
                statusSelect.value = status;
                document.getElementById('filter-form').submit();
            }
        }

        // --- Filter Chip Logic ---
        function removeFilter(filterName) {
            const form = document.getElementById('filter-form');
            if (filterName === 'DateRange') {
                document.querySelectorAll('.date-pill').forEach(p => {
                    p.classList.remove('bg-primary', 'text-white', 'shadow-sm');
                    p.classList.add('bg-transparent', 'text-slate-500');
                });
                form.querySelectorAll('input[type="date"]').forEach(i => i.value = '');
                document.getElementById('inline-custom-dates').classList.add('hidden');
            } else if (filterName === 'Store') {
                form.querySelector('input[onfocus*="toggleStoreSearch"]').value = '';
            } else if (filterName === 'BatchCode') {
                form.querySelector('select[name="BatchCode"]').value = '';
            } else if (filterName === 'Status') {
                form.querySelector('select[name="Status"]').value = '';
            } else if (filterName === 'SearchTerm') {
                form.querySelector('input[name="SearchTerm"]').value = '';
            }
            form.submit();
        }

        function clearAllFilters() {
            const form = document.getElementById('filter-form');
            form.reset();
            // Also need to manually clear pills and hidden custom dates
            document.querySelectorAll('.date-pill').forEach(p => {
                p.classList.remove('bg-primary', 'text-white', 'shadow-sm');
                p.classList.add('bg-transparent', 'text-slate-500');
            });
            document.getElementById('inline-custom-dates').classList.add('hidden');
            updateTypesLabel();
            form.submit();
        }

        function changePage(page) {
            document.getElementById('page-number-input').value = page;
            document.getElementById('filter-form').submit();
        }

        function toggleSortDropdown() {
            // Since we have a simple Sort: Newest button, let's just cycle or use a simple logic for now
            // or we could show a real dropdown. For now, let's keep it simple as requested.
            // Actually, let's implement a simple sort cycle: date desc -> date asc -> amount desc -> amount asc
            const sortBy = document.getElementById('sort-by-input').value;
            const sortDir = document.getElementById('sort-direction-input').value;

            if (sortBy === 'date' && sortDir === 'desc') {
                applySort('date', 'asc');
            } else if (sortBy === 'date' && sortDir === 'asc') {
                applySort('amount', 'desc');
            } else {
                applySort('date', 'desc');
            }
        }

        function applySort(sortBy, direction) {
            document.getElementById('sort-by-input').value = sortBy;
            document.getElementById('sort-direction-input').value = direction;
            document.getElementById('page-number-input').value = 1;
            document.getElementById('filter-form').submit();
        }

        function viewDetail(id, type) {
            // For now, just show the slide-in panel. In a real app, we'd fetch details via AJAX.
            console.log("Viewing detail for:", id, type);
            toggleDetailPanel();
        }

        document.addEventListener('DOMContentLoaded', function() {
            updateTypesLabel();

            // Date Pill Logic
            const pills = document.querySelectorAll('.date-pill');
            const inlineCustom = document.getElementById('inline-custom-dates');
            
            pills.forEach(pill => {
                pill.addEventListener('click', function() {
                    pills.forEach(p => {
                        p.classList.remove('bg-primary', 'text-white', 'shadow-sm');
                        p.classList.add('bg-transparent', 'text-slate-500');
                    });
                    this.classList.remove('bg-transparent', 'text-slate-500');
                    this.classList.add('bg-primary', 'text-white', 'shadow-sm');

                    if (this.dataset.range === 'custom') {
                        inlineCustom.classList.remove('hidden');
                    } else {
                        inlineCustom.classList.add('hidden');
                    }
                });
            });

            // Close dropdowns on outside click
            document.addEventListener('click', function(e) {
                if (!e.target.closest('#types-dropdown-container')) {
                    document.getElementById('types-dropdown-panel').classList.add('hidden');
                }
                if (!e.target.closest('.ml-auto.relative')) {
                    document.getElementById('export-dropdown-panel').classList.add('hidden');
                }
                if (!e.target.closest('#store-search-container')) {
                    document.getElementById('store-search-panel').classList.add('hidden');
                }
            });
        });
    </script>
}
