@page "/compare"
@model GearZone.Web.Pages.Public.Catalog.CompareModel
@{
    ViewData["Title"] = "Product Comparison";
    var productCount = Model.ComparisonData?.Products.Count ?? 0;
}

<div class="min-h-screen bg-[#f8fafc] pb-24 text-slate-900 selection:bg-blue-600/10">
    @* --- Navigation & Breadcrumbs --- *@
    <div class="max-w-7xl mx-auto px-4 py-8">
        <nav class="flex items-center gap-2 text-xs font-bold text-slate-400">
            <a href="/" class="hover:text-blue-600">Home</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <a href="/catalog" class="hover:text-blue-600">Components</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-slate-600 font-bold">Compare</span>
        </nav>

        <div class="mt-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-200 pb-8">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight text-[#0f172a]">Product Comparison</h1>
                <p class="mt-2 text-slate-500 font-medium">Comparing @productCount high-performance items side-by-side.</p>
            </div>
            <button class="inline-flex items-center gap-2 text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors">
                <span class="material-symbols-outlined text-[20px]">share</span>
                Share Comparison
            </button>
        </div>
    </div>

    @* --- Product Header Cards (Sticky) --- *@
    <div class="sticky top-[80px] z-50 border-b border-slate-200 bg-white/95 backdrop-blur-md shadow-sm">
        <div class="max-w-7xl mx-auto px-4 py-8">
            <div class="grid gap-6 items-stretch" style="grid-template-columns: 240px repeat(4, minmax(0, 1fr));">
                @* Info Cell *@
                <div class="flex flex-col justify-center pr-4">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Specifications</p>
                    <h2 class="text-2xl font-black text-[#0f172a] leading-tight">Compare<br/>Models</h2>
                </div>

                @if (Model.ComparisonData != null)
                {
                    @foreach (var product in Model.ComparisonData.Products)
                    {
                        <div class="relative flex flex-col bg-white rounded-2xl p-4 border border-slate-100 shadow-sm transition-all hover:shadow-md h-full">
                            <button class="absolute -right-2 -top-2 z-10 flex h-7 w-7 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-400 hover:bg-red-50 hover:text-red-500 transition-all shadow-sm">
                                <span class="material-symbols-outlined text-[18px]">close</span>
                            </button>
                            <div class="aspect-square w-full max-w-[120px] mx-auto overflow-hidden rounded-xl bg-slate-50 p-2 flex items-center justify-center">
                                <img src="@product.ImageUrl" alt="@product.Name" class="max-h-full max-w-full object-contain" />
                            </div>
                            <div class="mt-4 flex flex-col flex-grow">
                                <h3 class="line-clamp-2 text-xs font-bold leading-snug text-slate-800 h-9 mb-1">@product.Name</h3>
                                <p class="text-lg font-black text-[#ea580c] mb-3">@product.Price.ToString("N0") <span class="text-[10px] font-bold text-slate-400 uppercase">₫</span></p>
                                <button class="mt-auto w-full rounded-xl bg-primary px-4 py-2.5 text-xs font-black text-white transition-all hover:bg-blue-700 hover:shadow-[0_0_15px_rgba(37,99,235,0.3)] active:scale-95">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    }

                    @if (Model.ComparisonData.Products.Count < 4)
                    {
                        @* Add Product Placeholder *@
                        <div class="flex h-full flex-col">
                            <div class="flex-1 min-h-[140px] flex flex-col items-center justify-center rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50/50 p-6 transition-all hover:border-blue-400 hover:bg-blue-50/50 group cursor-pointer shadow-sm">
                                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-blue-600 shadow-sm border border-slate-100 group-hover:scale-110 group-hover:bg-blue-600 group-hover:text-white transition-all">
                                    <span class="material-symbols-outlined">add</span>
                                </div>
                                <span class="mt-3 text-[10px] font-black text-slate-400 group-hover:text-blue-600 uppercase tracking-widest">Add Product</span>
                            </div>
                        </div>
                    }
                    
                    @* Fill remaining slots if needed *@
                    @for (int i = 0; i < (3 - Model.ComparisonData.Products.Count); i++)
                    {
                        <div class="hidden lg:block"></div>
                    }
                }
            </div>
        </div>
    </div>

    @* --- Comparison Table --- *@
    <div class="max-w-7xl mx-auto px-4 mt-8 pb-12">
        <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-xl shadow-slate-200/40">
            @if (Model.ComparisonData != null && Model.ComparisonData.Rows.Any())
            {
                <div class="w-full">
                    @* SECTION HEADER *@
                    <div class="bg-slate-50/80 border-b border-slate-100 px-8 py-4">
                        <span class="text-[11px] font-black uppercase tracking-[0.2em] text-slate-500">Feature Breakdown</span>
                    </div>

                    @foreach (var row in Model.ComparisonData.Rows)
                    {
                        <div class="grid gap-6 px-8 py-5 border-b border-slate-50 last:border-0 items-center hover:bg-slate-50/30 transition-all" style="grid-template-columns: 200px repeat(4, minmax(0, 1fr));">
                            @* Attribute Label *@
                            <div class="flex flex-col">
                                <span class="font-bold text-slate-400 text-[11px] uppercase tracking-wider">@row.AttributeName</span>
                            </div>

                            @* Values *@
                            @foreach (var val in row.Values)
                            {
                                <div class="px-2 text-center rounded-lg py-1 @(row.IsDifferent ? "bg-emerald-50/40 text-emerald-700 ring-1 ring-emerald-100/50" : "")">
                                    <span class="text-sm font-black text-slate-800 leading-tight">
                                        @val
                                        @if (!string.IsNullOrEmpty(row.Unit)) { <span class="ml-0.5 text-[10px] text-slate-400 uppercase font-bold">@row.Unit</span> }
                                    </span>
                                </div>
                            }
                            
                            @* Empty Slots *@
                            @for (int i = 0; i < (4 - row.Values.Count); i++)
                            {
                                <div class="px-2"></div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="py-40 text-center">
                    <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-3xl bg-slate-50 text-slate-200 mb-6">
                        <span class="material-symbols-outlined text-4xl">compare</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900">No common features to display</h3>
                    <p class="mt-2 text-slate-500 max-w-sm mx-auto">Try comparing products with rich technical implementation details.</p>
                </div>
            }
        </div>
    </div>
</div>

@* --- Sticky Bottom Actions --- *@
<div class="fixed bottom-0 left-0 right-0 z-[60] border-t border-slate-200 bg-white/80 backdrop-blur-xl py-5 shadow-[0_-15px_30px_rgba(0,0,0,0.08)]">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-end gap-3">
        <a href="/compare" class="rounded-xl border border-slate-200 bg-white px-8 py-3.5 text-sm font-black text-slate-500 transition-all hover:bg-slate-50 hover:text-slate-800">
            Clear Selection
        </a>
        <button class="rounded-xl bg-[#0f172a] px-12 py-3.5 text-sm font-black text-white shadow-xl shadow-slate-900/20 transition-all hover:bg-slate-800 hover:translate-y-[-2px] active:translate-y-0 active:shadow-md">
            Proceed to Checkout
        </button>
    </div>
</div>

<style>
    body { 
        background-color: #f8fafc;
        overflow-x: hidden;
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    [material-symbols-outlined] {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .sticky.top-\[80px\] {
        top: 80px;
    }
</style>


