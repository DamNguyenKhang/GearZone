@page "{id:Guid}"
@model GearZone.Web.Pages.StoreOwner.Products.EditModel
@{
    ViewData["Title"] = "Edit Product";
    ViewData["ActivePage"] = "Products";
    ViewData["PageHeader"] = "Edit Product";
    ViewData["Breadcrumb"] = new string[] { "Products", "Edit Product" };
    Layout = "_StoreOwnerLayout";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <form method="post" enctype="multipart/form-data" id="editProductForm">
        <div asp-validation-summary="ModelOnly" class="mb-4 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm font-medium"></div>

        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Edit Product</h1>
                <p class="text-sm text-gray-500 mt-1">Update your product details and variants.</p>
            </div>
            <div class="flex items-center gap-3">
                <a asp-page="./Details" asp-route-id="@Model.ProductId" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Discard</a>
                <button type="submit" class="px-5 py-2.5 text-sm font-medium text-white bg-primary rounded-lg hover:bg-primary-dark transition-colors shadow-sm">Update Product</button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column -->
            <div class="lg:col-span-2 space-y-8">
                
                <!-- Basic Information -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">info</span>
                        <h2 class="text-lg font-bold text-gray-900">Basic Information</h2>
                    </div>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Product Name</label>
                            <input asp-for="Input.Name" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary transition-all bg-gray-50/50" placeholder="e.g., ASUS ROG Strix GeForce RTX 4090 OC Edition" required>
                            <span asp-validation-for="Input.Name" class="text-xs text-red-500 mt-1"></span>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Custom Slug (Optional)</label>
                            <div class="relative">
                                <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 text-sm">/product/</span>
                                <input asp-for="Input.Slug" class="w-full pl-20 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary transition-all bg-gray-50/50 text-sm" placeholder="leave-blank-to-auto-generate">
                            </div>
                            <span asp-validation-for="Input.Slug" class="text-xs text-red-500 mt-1"></span>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                            <textarea asp-for="Input.Description" rows="5" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary transition-all bg-gray-50/50" placeholder="Describe your product..."></textarea>
                            <span asp-validation-for="Input.Description" class="text-xs text-red-500 mt-1"></span>
                        </div>
                    </div>
                </div>

                <!-- Media (Existing and New) -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">image</span>
                        <h2 class="text-lg font-bold text-gray-900">Product Media</h2>
                    </div>

                    <!-- Existing Images -->
                    @if (Model.Input.ExistingImageUrls.Any())
                    {
                        <div class="mb-6">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Current Images</label>
                            <div class="grid grid-cols-5 gap-4">
                                @foreach (var url in Model.Input.ExistingImageUrls)
                                {
                                    <div class="relative group aspect-square rounded-lg overflow-hidden border border-gray-200">
                                        <img src="@url" class="w-full h-full object-cover" />
                                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                            <span class="text-white text-xs font-bold uppercase">Keep</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="border-2 border-dashed border-gray-200 rounded-xl p-8 text-center hover:border-primary transition-colors cursor-pointer bg-gray-50/30">
                        <input type="file" asp-for="Input.NewImages" class="hidden" id="imageUpload" multiple accept="image/*">
                        <label for="imageUpload" class="cursor-pointer block">
                            <span class="material-symbols-outlined text-4xl text-gray-400 mb-2">cloud_upload</span>
                            <p class="text-sm font-medium text-gray-900">Upload New Images</p>
                            <p class="text-xs text-gray-500 mt-1">PNG, JPG up to 10MB (max 5 images total)</p>
                        </label>
                    </div>
                    <div id="imagePreview" class="grid grid-cols-5 gap-4 mt-4"></div>
                </div>
                <!-- Product Specifications -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center justify-between mb-3 gap-3">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">list_alt</span>
                            <h2 class="text-lg font-bold text-gray-900">Category Specifications</h2>
                        </div>
                        <button type="button" id="btnAddSpecAttribute" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-bold text-primary bg-primary/10 rounded-lg hover:bg-primary/20 transition-colors">
                            <span class="material-symbols-outlined text-[16px]">add</span>
                            Add Spec
                        </button>
                    </div>
                    <p class="text-sm text-gray-500 mb-6">Specifications are generated from the selected category template. Update the values you want to compare on the storefront.</p>

                    <!-- Inline Add Spec Form -->
                    <div id="inlineAddSpecForm" class="hidden bg-primary/5 p-4 rounded-xl border border-primary/20 mb-6 space-y-4 animate-in fade-in slide-in-from-top-2 duration-300">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                            <div>
                                <label class="block text-[10px] font-bold text-primary uppercase mb-1">Spec Name *</label>
                                <input type="text" id="newSpecName" class="w-full px-3 py-2 border border-primary/20 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="e.g. GPU Architecture">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-primary uppercase mb-1">Unit (Optional)</label>
                                <input type="text" id="newSpecUnit" class="w-full px-3 py-2 border border-primary/20 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="e.g. MHz, GB">
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-primary uppercase mb-1">Value Type (Optional)</label>
                                <input type="text" id="newSpecValueType" class="w-full px-3 py-2 border border-primary/20 rounded-lg text-sm bg-white focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="e.g. Number, String">
                            </div>
                        </div>
                        <div class="flex justify-end gap-2">
                            <button type="button" id="btnCancelAddSpec" class="px-4 py-1.5 text-xs font-bold text-gray-500 hover:text-gray-700 transition-colors uppercase tracking-wider">Cancel</button>
                            <button type="button" id="btnSaveNewSpec" class="px-5 py-2 text-xs font-bold text-white bg-primary rounded-lg hover:bg-primary-dark transition-all shadow-md shadow-primary/20 uppercase tracking-wider">Save Specification</button>
                        </div>
                    </div>

                    <div id="specsContainer" class="space-y-3">
                        @if (Model.Input.Specifications.Any())
                        {
                            @for (int i = 0; i < Model.Input.Specifications.Count; i++)
                            {
                                <div class="spec-row grid grid-cols-1 md:grid-cols-2 gap-4 items-end bg-gray-50/50 p-4 rounded-lg border border-gray-100">
                                    <input type="hidden" name="Input.Specifications[@i].AttributeId" value="@Model.Input.Specifications[i].AttributeId" />
                                    <input type="hidden" name="Input.Specifications[@i].Unit" value="@Model.Input.Specifications[i].Unit" />
                                    <input type="hidden" name="Input.Specifications[@i].ValueType" value="@Model.Input.Specifications[i].ValueType" />
                                    <div>
                                        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Specification</label>
                                        <input name="Input.Specifications[@i].Key" value="@Model.Input.Specifications[i].Key" readonly class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 font-medium" />
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Value</label>
                                        <div class="relative">
                                            <input name="Input.Specifications[@i].Value" value="@Model.Input.Specifications[i].Value" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-primary focus:border-primary bg-white @(string.IsNullOrWhiteSpace(Model.Input.Specifications[i].Unit) ? string.Empty : "pr-16")" placeholder="Enter @Model.Input.Specifications[i].Key" 
                                                data-val="true" data-val-required="@(Model.Input.Specifications[i].Key) is required" required />
                                            @if (!string.IsNullOrWhiteSpace(Model.Input.Specifications[i].Unit))
                                            {
                                                <span class="absolute inset-y-0 right-3 flex items-center text-xs font-bold text-gray-400 uppercase">@Model.Input.Specifications[i].Unit</span>
                                            }
                                        </div>
                                        <span class="field-validation-valid text-[10px] text-red-500 font-medium" data-valmsg-for="Input.Specifications[@i].Value" data-valmsg-replace="true"></span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div id="emptySpecState" class="rounded-xl border border-dashed border-gray-200 bg-gray-50/60 px-4 py-5 text-sm text-gray-400">
                                Select a category to load the specification template.
                            </div>
                        }
                    </div>
                </div>

                <!-- Variants & Pricing (Simplified logic for now, similar to Create) -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">sell</span>
                            <h2 class="text-lg font-bold text-gray-900">Variants & Pricing</h2>
                        </div>
                        <button type="button" id="btnAddVariant" class="px-3 py-1.5 text-xs font-bold text-primary bg-primary/10 rounded-lg hover:bg-primary/20 transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[16px]">add</span> Add Variant
                        </button>
                    </div>

                    <div id="variantsContainer" class="space-y-4">
                        @for (int i = 0; i < Model.Input.Variants.Count; i++)
                        {
                            <div class="variant-row bg-gray-50/50 border border-gray-200 rounded-lg p-4 relative group">
                                <button type="button" class="btnRemoveRow absolute -top-2 -right-2 bg-red-100 text-red-600 rounded-full p-1 shadow-sm hover:bg-red-200 transition-colors hidden group-hover:block">
                                    <span class="material-symbols-outlined text-[16px]">close</span>
                                </button>
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                                    <div>
                                        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Variant Name</label>
                                        <input asp-for="Input.Variants[i].VariantName" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-white" placeholder="Standard / 16GB RAM" 
                                            data-val="true" data-val-required="Variant name is required" required>
                                        <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[@i].VariantName" data-valmsg-replace="true"></span>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">SKU</label>
                                        <input asp-for="Input.Variants[i].Sku" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-white" placeholder="Unique SKU" readonly="@(Model.Input.Variants[i].Sku != "")" 
                                            data-val="true" data-val-required="SKU is required" required>
                                        <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[@i].Sku" data-valmsg-replace="true"></span>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Price (VND)</label>
                                        <input asp-for="Input.Variants[i].Price" type="number" step="0.01" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-white" 
                                            data-val="true" data-val-required="Price is required" data-val-range="Price must be > 0" data-val-range-min="0" required>
                                        <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[@i].Price" data-valmsg-replace="true"></span>
                                    </div>
                                    <div>
                                        <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Stock</label>
                                        <input asp-for="Input.Variants[i].StockQuantity" type="number" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-white" 
                                            data-val="true" data-val-required="Stock is required" data-val-range="Stock must be >= 0" data-val-range-min="0" required>
                                        <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[@i].StockQuantity" data-valmsg-replace="true"></span>
                                    </div>
                                </div>
                                <div class="mt-4 attributes-wrapper grid grid-cols-2 md:grid-cols-3 gap-3">
                                    @for (int j = 0; j < Model.Input.Variants[i].Attributes.Count; j++)
                                    {
                                        <div class="pre-selected-attribute">
                                            <input type="hidden" class="pre-selected-attr-id" value="@Model.Input.Variants[i].Attributes[j].AttributeId" />
                                            <input type="hidden" class="pre-selected-opt-id" value="@Model.Input.Variants[i].Attributes[j].OptionId" />
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column -->
            <div class="space-y-8">
                <!-- Organization -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">category</span>
                        <h2 class="text-lg font-bold text-gray-900">Organization</h2>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                            <select asp-for="Input.CategoryId" asp-items="Model.CategoryOptions" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/50" required>
                                <option value="">Select Category</option>
                            </select>
                            <span asp-validation-for="Input.CategoryId" class="text-xs text-red-500 mt-1"></span>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Brand</label>
                            <select asp-for="Input.BrandId" asp-items="Model.BrandOptions" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/50" required>
                                <option value="">Select Brand</option>
                            </select>
                            <span asp-validation-for="Input.BrandId" class="text-xs text-red-500 mt-1"></span>
                        </div>
                    </div>
                </div>

                <!-- Status & Global Price -->
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <div class="flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">payments</span>
                        <h2 class="text-lg font-bold text-gray-900">Pricing & Status</h2>
                    </div>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Base Price (VND)</label>
                            <input asp-for="Input.BasePrice" type="number" step="0.01" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/50 font-bold text-primary" placeholder="0">
                            <p class="text-[10px] text-gray-400 mt-1 italic">* Lowest price among variants will be shown as starting price.</p>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                            <span class="text-sm font-medium text-gray-700">Save as Draft</span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" asp-for="Input.IsDraft" class="sr-only peer">
                                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<template id="variantTemplate">
    <div class="variant-row bg-white border border-gray-200 rounded-lg p-4 relative group shadow-sm">
        <button type="button" class="btnRemoveRow absolute -top-2 -right-2 bg-red-100 text-red-600 rounded-full p-1 shadow-sm hover:bg-red-200 transition-colors hidden group-hover:block">
            <span class="material-symbols-outlined text-[16px]">close</span>
        </button>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Variant Name</label>
                <input name="Input.Variants[{index}].VariantName" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/30" placeholder="e.g., White / 128GB" 
                    data-val="true" data-val-required="Variant name is required" required>
                <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[{index}].VariantName" data-valmsg-replace="true"></span>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">SKU</label>
                <input name="Input.Variants[{index}].Sku" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/30" placeholder="SKU-AUTO-123" 
                    data-val="true" data-val-required="SKU is required" required>
                <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[{index}].Sku" data-valmsg-replace="true"></span>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Price (VND)</label>
                <input name="Input.Variants[{index}].Price" type="number" step="0.01" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/30" 
                    data-val="true" data-val-required="Price is required" data-val-range="Price must be > 0" data-val-range-min="0" required>
                <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[{index}].Price" data-valmsg-replace="true"></span>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Stock</label>
                <input name="Input.Variants[{index}].StockQuantity" type="number" class="w-full px-3 py-2 text-sm border border-gray-300 rounded-lg focus:ring-primary focus:border-primary bg-gray-50/30" 
                    data-val="true" data-val-required="Stock is required" data-val-range="Stock must be >= 0" data-val-range-min="0" required>
                <span class="field-validation-valid text-xs text-red-500" data-valmsg-for="Input.Variants[{index}].StockQuantity" data-valmsg-replace="true"></span>
            </div>
        </div>
        <div class="mt-4 attributes-wrapper grid grid-cols-2 md:grid-cols-3 gap-3">
            <!-- Attributes injected here -->
        </div>
    </div>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const $form = $('#editProductForm');

            // Custom validation settings for immediate feedback
            const validator = $form.validate();
            if (validator) {
                validator.settings.onfocusout = function(element) {
                    $(element).valid();
                };
            }

            function reparseValidation() {
                $form.removeData("validator").removeData("unobtrusiveValidation");
                $.validator.unobtrusive.parse($form);
                
                // Re-apply immediate feedback settings
                const newValidator = $form.validate();
                if (newValidator) {
                    newValidator.settings.onfocusout = function(element) {
                        $(element).valid();
                    };
                }
            }
            // Show validation errors as toasts
            @if (!ModelState.IsValid)
            {
                foreach (var modelState in ModelState.Values)
                {
                    foreach (var error in modelState.Errors)
                    {
                        <text>window.showToast?.('error', "@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(error.ErrorMessage))");</text>
                    }
                }
            }

            // Client-side validation toast for main form
            $form.on('invalid-form.validate', function(event, validator) {
                const firstError = validator.errorList[0];
                if (firstError) {
                    window.showToast?.('warning', `Form is missing info: ${firstError.message}`);
                    $(firstError.element).focus();
                }
            });

            // Fix the Add Spec button not working
            $('#btnAddSpecAttribute').click(function() {
                $('#inlineAddSpecForm').removeClass('hidden').addClass('flex flex-col');
                $('#newSpecName').focus();
            });

            $('#btnCancelAddSpec').click(function() {
                $('#inlineAddSpecForm').addClass('hidden').removeClass('flex flex-col');
                $('#newSpecName, #newSpecUnit, #newSpecValueType').val('');
            });

            $('#btnSaveNewSpec').click(function() {
                createSpecificationAttribute();
            });

            function renderSpecifications(specs) {
                const container = $('#specsContainer');
                
                // Collect current values to preserve them if they exist in the new list
                let currentValues = {};
                container.find('.spec-row').each(function() {
                    const key = $(this).find('input[name*=".Key"]').val();
                    const val = $(this).find('input[name*=".Value"]').val();
                    if (key) currentValues[key] = val;
                });

                container.empty();

                if (!specs || specs.length === 0) {
                    container.append(`
                        <div id="emptySpecState" class="rounded-xl border border-dashed border-gray-200 bg-gray-50/60 px-4 py-5 text-sm text-gray-400">
                            This category does not have product-level specifications yet.
                        </div>
                    `);
                    return;
                }

                specs.forEach(function(spec, index) {
                    const unit = spec.unit || '';
                    const value = currentValues[spec.key] || spec.value || ''; // Prefer current typed value
                    const inputPadding = unit ? 'pr-16' : '';
                    container.append(`
                        <div class="spec-row grid grid-cols-1 md:grid-cols-2 gap-4 items-end bg-gray-50/50 p-4 rounded-lg border border-gray-100">
                            <input type="hidden" name="Input.Specifications[${index}].AttributeId" value="${spec.attributeId || 0}" />
                            <input type="hidden" name="Input.Specifications[${index}].Unit" value="${unit}" />
                            <input type="hidden" name="Input.Specifications[${index}].ValueType" value="${spec.valueType || ''}" />
                            <div>
                                <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Specification</label>
                                <input name="Input.Specifications[${index}].Key" value="${spec.key || ''}" readonly class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white text-gray-700 font-medium" />
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Value</label>
                                <div class="relative">
                                    <input name="Input.Specifications[${index}].Value" value="${value}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-primary focus:border-primary bg-white ${inputPadding}" placeholder="Enter ${spec.key || 'value'}" data-val="true" data-val-required="${spec.key} is required" required />
                                    ${unit ? `<span class="absolute inset-y-0 right-3 flex items-center text-xs font-bold text-gray-400 uppercase">${unit}</span>` : ''}
                                </div>
                                <span class="field-validation-valid text-[10px] text-red-500 font-medium" data-valmsg-for="Input.Specifications[${index}].Value" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    `);
                });
                reparseValidation();
            }

            async function createSpecificationAttribute() {
                const categoryId = $('#Input_CategoryId').val();
                if (!categoryId) {
                    window.showToast?.('warning', 'Please select a category first.');
                    return;
                }

                const name = $('#newSpecName').val();
                if (!name || !name.trim()) {
                    window.showToast?.('warning', 'Specification name is required.');
                    $('#newSpecName').focus();
                    return;
                }

                const unit = $('#newSpecUnit').val() || '';
                const valueType = $('#newSpecValueType').val() || '';
                const token = $('input[name="__RequestVerificationToken"]').val();

                const saveBtn = $('#btnSaveNewSpec');
                const originalText = saveBtn.text();
                saveBtn.prop('disabled', true).text('Saving...');

                try {
                    const response = await $.ajax({
                        url: '?handler=CreateSpecificationAttribute',
                        type: 'POST',
                        data: {
                            categoryId: categoryId,
                            name: name.trim(),
                            unit: unit.trim(),
                            valueType: valueType.trim()
                        },
                        headers: { 'RequestVerificationToken': token }
                    });

                    if (!response || !response.success) {
                        window.showToast?.('warning', response?.message || 'Could not create specification.');
                        return;
                    }

                    window.showToast?.('success', 'Specification added to this category.');
                    $('#btnCancelAddSpec').click(); // Hide and clear form
                    loadCategorySpecifications(categoryId);
                } catch (err) {
                    window.showToast?.('error', 'Could not create specification.');
                } finally {
                    saveBtn.prop('disabled', false).text(originalText);
                }
            }
            function loadCategorySpecifications(categoryId) {
                if (!categoryId) {
                    renderSpecifications([]);
                    return;
                }

                $.get('?handler=Specifications&categoryId=' + categoryId, function(data) {
                    renderSpecifications(data || []);
                });
            }

            let currentCategoryAttributes = [];

            function generateAttributesHtml(variantIndex, selectedOptions = {}) {
                if (!currentCategoryAttributes || currentCategoryAttributes.length === 0) return '';
                let html = '';
                currentCategoryAttributes.forEach(function(attr, attrIndex) {
                    const selectedValue = selectedOptions[attr.id] || "";
                    html += `
                        <div class="flex flex-col">
                            <input type="hidden" name="Input.Variants[${variantIndex}].Attributes[${attrIndex}].AttributeId" value="${attr.id}" />
                            <input type="hidden" name="Input.Variants[${variantIndex}].Attributes[${attrIndex}].AttributeName" value="${attr.name}" />
                            <select name="Input.Variants[${variantIndex}].Attributes[${attrIndex}].OptionId" class="w-full px-2 py-1.5 border border-gray-300 rounded-md text-xs bg-gray-50 focus:ring-primary focus:border-primary" required>
                                <option value="">Select ${attr.name}</option>`;

                    attr.options.forEach(function(opt) {
                        const isSelected = opt.id == selectedValue ? 'selected' : '';
                        html += `<option value="${opt.id}" ${isSelected}>${opt.value}</option>`;
                    });

                    html += `
                            </select>
                        </div>
                    `;
                });
                return html;
            }

            function refreshAllVariantAttributes() {
                if (currentCategoryAttributes.length > 0) {
                    $('.variant-row').each(function(index) {
                        const wrapper = $(this).find('.attributes-wrapper');
                        
                        // Extract current/pre-selected values
                        let selected = {};
                        wrapper.find('select').each(function() {
                            const attrId = $(this).closest('div').find('input[name*="AttributeId"]').val();
                            selected[attrId] = $(this).val();
                        });
                        
                        // Check for pre-selected hidden fields (on reload)
                        wrapper.find('.pre-selected-attribute').each(function() {
                            const attrId = $(this).find('.pre-selected-attr-id').val();
                            const optId = $(this).find('.pre-selected-opt-id').val();
                            if (attrId && optId) selected[attrId] = optId;
                        });

                        let attrsHtml = generateAttributesHtml(index, selected);
                        wrapper.html(attrsHtml);
                    });
                } else {
                    $('.attributes-wrapper').empty();
                }
            }

            $('#Input_CategoryId, #Input_BrandId').removeClass('w-full px-4 py-2.5 border border-gray-300 rounded-lg bg-gray-50/50');

            function updateIndices(containerId, rowClass) {
                $(`#${containerId} .${rowClass}`).each(function (index) {
                    $(this).find('input, select').each(function () {
                        const name = $(this).attr('name');
                        if (name) {
                            $(this).attr('name', name.replace(/\[\d+\]/, '[' + index + ']'));
                        }
                    });
                });
                reparseValidation();
            }

            new TomSelect('#Input_CategoryId', {
                create: true,
                placeholder: 'Search/Type new Category...',
                allowEmptyOption: true,
                render: {
                    option_create: function(data, escape) {
                        return '<div class="create px-4 py-2 text-primary font-bold bg-primary/5 hover:bg-primary/10 flex items-center gap-2 cursor-pointer border-t border-slate-100"><span class="material-symbols-outlined text-[18px]">add</span> Add Category: <strong>' + escape(data.input) + '</strong></div>';
                    },
                    no_results: function (data, escape) {
                        return '<div class="no-results px-4 py-2 text-slate-400 text-sm">No results found for "' + escape(data.input) + '"</div>';
                    }
                },
                onChange: function(value) {
                    $('#Input_CategoryId').val(value);
                    loadCategorySpecifications(value);
                    
                    if (value) {
                        $.get('?handler=Attributes&categoryId=' + value, function(data) {
                            currentCategoryAttributes = data || [];
                            refreshAllVariantAttributes();
                        });
                    } else {
                        currentCategoryAttributes = [];
                        refreshAllVariantAttributes();
                    }
                },
                onOptionAdd: function(value) {
                    if (isNaN(value)) {
                        const self = this;
                        const token = $('input[name="__RequestVerificationToken"]').val();

                        $.ajax({
                            url: '?handler=CreateCategory',
                            type: 'POST',
                            data: { name: value },
                            headers: { "RequestVerificationToken": token },
                            success: function(response) {
                                if (response.success) {
                                    self.updateOption(value, { value: response.id, text: response.name });
                                    self.addItem(response.id);
                                    self.removeItem(value);
                                } else {
                                    window.showToast?.('error', response.message || 'Failed to create category');
                                    self.removeOption(value);
                                }
                            },
                            error: function() {
                                window.showToast?.('error', 'An error occurred while creating the category');
                                self.removeOption(value);
                            }
                        });
                    }
                }
            });

            new TomSelect('#Input_BrandId', {
                create: true,
                placeholder: 'Search/Type new Brand...',
                allowEmptyOption: true,
                render: {
                    option_create: function(data, escape) {
                        return '<div class="create px-4 py-2 text-primary font-bold bg-primary/5 hover:bg-primary/10 flex items-center gap-2 cursor-pointer border-t border-slate-100"><span class="material-symbols-outlined text-[18px]">add</span> Add Brand: <strong>' + escape(data.input) + '</strong></div>';
                    },
                    no_results: function (data, escape) {
                        return '<div class="no-results px-4 py-2 text-slate-400 text-sm">No results found for "' + escape(data.input) + '"</div>';
                    }
                },
                onOptionAdd: function(value) {
                    if (isNaN(value)) {
                        const self = this;
                        const token = $('input[name="__RequestVerificationToken"]').val();

                        $.ajax({
                            url: '?handler=CreateBrand',
                            type: 'POST',
                            data: { name: value },
                            headers: { "RequestVerificationToken": token },
                            success: function(response) {
                                if (response.success) {
                                    self.updateOption(value, { value: response.id, text: response.name });
                                    self.addItem(response.id);
                                    self.removeItem(value);
                                } else {
                                    window.showToast?.('error', response.message || 'Failed to create brand');
                                    self.removeOption(value);
                                }
                            },
                            error: function() {
                                window.showToast?.('error', 'An error occurred while creating the brand');
                                self.removeOption(value);
                            }
                        });
                    }
                }
            });

            if ($('#Input_CategoryId').val()) {
                const initialCatId = $('#Input_CategoryId').val();
                
                // Only load SPEC template if the container is empty (prevents overwriting actual product data)
                if ($('#specsContainer .spec-row').length === 0) {
                    loadCategorySpecifications(initialCatId);
                }
                
                $.get('?handler=Attributes&categoryId=' + initialCatId, function(data) {
                    currentCategoryAttributes = data || [];
                    refreshAllVariantAttributes();
                });
            }

            $('#btnAddVariant').click(function () {
                const index = $('#variantsContainer .variant-row').length;
                const html = $('#variantTemplate').html().replace(/{index}/g, index);
                $('#variantsContainer').append(html);
                
                // Re-render attributes for the new variant
                refreshAllVariantAttributes();
                
                updateIndices('variantsContainer', 'variant-row');
                reparseValidation();
            });

            $(document).on('click', '.btnRemoveRow', function () {
                $(this).closest('.variant-row').remove();
                updateIndices('variantsContainer', 'variant-row');
            });

            $('#imageUpload').change(function () {
                const preview = $('#imagePreview');
                preview.empty();
                if (this.files) {
                    Array.from(this.files).forEach(file => {
                        const reader = new FileReader();
                        reader.onload = function (e) {
                            preview.append(`
                                <div class="aspect-square rounded-lg overflow-hidden border border-gray-200">
                                    <img src="${e.target.result}" class="w-full h-full object-cover" />
                                </div>
                            `);
                        };
                        reader.readAsDataURL(file);
                    });
                }
            });

            reparseValidation();
        });
    </script>
    <style>
        /* Highlight invalid fields */
        input.input-validation-error, select.input-validation-error, textarea.input-validation-error {
            border-color: #ef4444 !important;
            background-color: #fef2f2 !important;
            border-width: 2px;
        }
        
        input.input-validation-error:focus, select.input-validation-error:focus, textarea.input-validation-error:focus {
            ring-color: #ef4444 !important;
            box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.2) !important;
        }

        .field-validation-error {
            display: block;
            margin-top: 0.25rem;
            color: #ef4444;
            font-size: 0.75rem;
            font-weight: 500;
        }

        /* TomSelect validation styling */
        .ts-wrapper.input-validation-error .ts-control,
        select.input-validation-error + .ts-wrapper .ts-control {
            border-color: #ef4444 !important;
            background-color: #fef2f2 !important;
            box-shadow: 0 0 0 1px #ef4444 !important;
        }
    </style>
}




