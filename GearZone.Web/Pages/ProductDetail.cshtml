@page "/product/{slug}"
@model GearZone.Web.Pages.ProductDetailModel
@{
    ViewData["Title"] = Model.Product.Name + " | GearZone";
    var totalStock = Model.Product.Variants.Sum(v => v.StockQuantity);
}

<div class="max-w-7xl mx-auto px-4 py-4">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-4">
        <a href="/" class="hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-[18px]">home</span>
        </a>
        @foreach (var crumb in Model.Product.Breadcrumbs)
        {
            <span class="material-symbols-outlined text-[16px] text-gray-300">chevron_right</span>
            @if (crumb.Slug != null)
            {
                <a href="/category/@crumb.Slug" class="hover:text-primary transition-colors">@crumb.Name</a>
            }
            else
            {
                <span>@crumb.Name</span>
            }
        }
        <span class="material-symbols-outlined text-[16px] text-gray-300">chevron_right</span>
        <span class="text-gray-700 font-medium truncate max-w-[250px]">@Model.Product.Name</span>
    </nav>

    <!-- ==================== SECTION 1: Product Main ==================== -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-4">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

            <!-- === LEFT: Image Gallery (2 cols) === -->
            <div class="lg:col-span-2">
                <!-- Main Image -->
                <div class="relative aspect-square bg-gray-50 rounded-lg overflow-hidden mb-3 border border-gray-200">
                    @if (Model.Product.Images.Any())
                    {
                        <img id="mainImage" src="@Model.Product.Images.First().ImageUrl" alt="@Model.Product.Name"
                             class="w-full h-full object-contain transition-all duration-300" />
                    }
                    else
                    {
                        <div class="flex items-center justify-center h-full">
                            <span class="material-symbols-outlined text-8xl text-gray-300">image</span>
                        </div>
                    }
                </div>
                <!-- Thumbnails -->
                @if (Model.Product.Images.Count > 1)
                {
                    <div class="flex gap-2 overflow-x-auto pb-1">
                        @foreach (var image in Model.Product.Images)
                        {
                            <button onclick="setMainImage('@image.ImageUrl', this)"
                                    class="flex-shrink-0 w-16 h-16 rounded-lg overflow-hidden border-2 transition-all
                                           @(image.IsPrimary ? "border-primary ring-2 ring-primary/20" : "border-gray-200 hover:border-gray-400") thumbnail-btn">
                                <img src="@image.ImageUrl" alt="" class="w-full h-full object-cover" />
                            </button>
                        }
                    </div>
                }
            </div>

            <!-- === RIGHT: Product Info (3 cols) === -->
            <div class="lg:col-span-3">
                <!-- Product Name -->
                <h1 class="text-xl lg:text-2xl font-bold text-gray-900 leading-tight mb-3">@Model.Product.Name</h1>

                <!-- Rating | Review Count | Category -->
                <div class="flex items-center gap-4 mb-4 pb-4 border-b border-gray-100">
                    <div class="flex items-center gap-1.5">
                        <span class="text-base font-bold underline" style="color: #D97706">@Model.Product.AverageRating.ToString("F1")</span>
                        <div class="flex items-center gap-0.5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var isFilled = i <= (int)Math.Round(Model.Product.AverageRating);
                                <span class="material-symbols-outlined text-[16px] star-fill" style="color: @(isFilled ? "#FBBF24" : "#D1D5DB")">star</span>
                            }
                        </div>
                    </div>
                    <div class="w-px h-5 bg-gray-300"></div>
                    <div class="flex items-center gap-1">
                        <span class="text-base font-bold text-gray-800">@Model.Product.ReviewCount</span>
                        <span class="text-sm text-gray-500">Đánh Giá</span>
                    </div>
                    <div class="w-px h-5 bg-gray-300"></div>
                    <div class="flex items-center gap-1">
                        <span class="text-sm text-gray-500">@Model.Product.CategoryName</span>
                    </div>
                </div>

                <!-- Price Box -->
                <div class="rounded-lg p-4 mb-5" style="background: linear-gradient(135deg, #FFF7ED 0%, #FEF2F2 100%)">
                    @if (Model.Product.MinPrice == Model.Product.MaxPrice || Model.Product.Variants.Count <= 1)
                    {
                        <div class="text-3xl font-bold" style="color: #EF4444">
                            @Model.Product.MinPrice.ToString("N0") ₫
                        </div>
                    }
                    else
                    {
                        <div class="text-3xl font-bold" style="color: #EF4444">
                            @Model.Product.MinPrice.ToString("N0") ₫ - @Model.Product.MaxPrice.ToString("N0") ₫
                        </div>
                    }
                </div>

                <!-- Vận chuyển info -->
                <div class="flex items-center gap-3 mb-5 text-sm">
                    <span class="text-gray-500 w-24">Vận Chuyển</span>
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] text-green-500">local_shipping</span>
                        <span class="text-gray-700">Miễn phí vận chuyển</span>
                    </div>
                </div>

                <!-- Variants -->
                @if (Model.Product.Variants.Any())
                {
                    <div class="mb-5">
                        <div class="flex items-start gap-3">
                            <span class="text-gray-500 text-sm w-24 pt-2">Phân Loại</span>
                            <div class="flex flex-wrap gap-2 flex-1">
                                @foreach (var variant in Model.Product.Variants)
                                {
                                    <button onclick="selectVariant('@variant.Id', '@variant.Price', this)"
                                            class="variant-btn px-4 py-2 border-2 rounded-lg text-sm transition-all
                                                   border-gray-200 hover:border-primary hover:text-primary">
                                        @variant.VariantName
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Quantity -->
                <div class="flex items-center gap-3 mb-2">
                    <span class="text-gray-500 text-sm w-24">Số Lượng</span>
                    <div class="flex items-center border border-gray-300 rounded-lg overflow-hidden">
                        <button onclick="changeQty(-1)" class="w-9 h-9 flex items-center justify-center hover:bg-gray-100 transition-colors text-gray-600">
                            <span class="material-symbols-outlined text-[18px]">remove</span>
                        </button>
                        <input id="qtyInput" type="number" value="1" min="1" max="@totalStock"
                               class="w-20 h-9 text-center text-sm font-medium border-x border-gray-300 outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none"
                               oninput="validateQty()" />
                        <button onclick="changeQty(1)" class="w-9 h-9 flex items-center justify-center hover:bg-gray-100 transition-colors text-gray-600">
                            <span class="material-symbols-outlined text-[18px]">add</span>
                        </button>
                    </div>
                    <span class="text-sm text-gray-400">@totalStock sản phẩm có sẵn</span>
                </div>
                <div id="qtyWarning" class="hidden ml-28 mb-3 text-xs text-red-500 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">error</span>
                    <span id="qtyWarningText"></span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-3 pt-4 border-t border-gray-100">
                    <button class="flex-1 py-3 border-2 border-primary text-primary font-semibold rounded-lg
                                   hover:bg-primary/5 transition-all flex items-center justify-center gap-2
                                   @(totalStock <= 0 ? "opacity-50 cursor-not-allowed" : "")"
                            @(totalStock <= 0 ? "disabled" : "")>
                        <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                        Thêm Vào Giỏ Hàng
                    </button>
                    <button style="background-color: #F97316" class="flex-1 py-3 text-white font-bold rounded-lg
                                   hover:opacity-90 transition-all flex items-center justify-center gap-2
                                   @(totalStock <= 0 ? "opacity-50 cursor-not-allowed" : "")"
                            @(totalStock <= 0 ? "disabled" : "")>
                        Mua Ngay
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== SECTION 2: Store Info ==================== -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-4">
        <div class="flex items-center gap-5">
            <!-- Store Avatar -->
            <div class="flex items-center gap-4 flex-shrink-0">
                <div class="w-16 h-16 bg-white rounded-full border-2 border-gray-200 overflow-hidden flex items-center justify-center">
                    @if (!string.IsNullOrEmpty(Model.Product.Store.LogoUrl))
                    {
                        <img src="@Model.Product.Store.LogoUrl" alt="@Model.Product.Store.StoreName" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-3xl text-gray-400">storefront</span>
                    }
                </div>
                <div>
                    <p class="font-bold text-gray-900 text-base">@Model.Product.Store.StoreName</p>
                    <p class="text-xs text-gray-400 mt-0.5">Online</p>
                    <div class="flex gap-2 mt-2">
                        <a href="/store/@Model.Product.Store.Slug"
                           class="px-3 py-1.5 border border-primary text-primary text-xs font-semibold rounded hover:bg-primary/5 transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">storefront</span>
                            Xem Shop
                        </a>
                    </div>
                </div>
            </div>

            <!-- Store Stats -->
            <!-- TODO: Cần lấy dữ liệu thực từ StoreInfoViewModel (số SP, ngày tham gia, tỉ lệ phản hồi, thời gian phản hồi, followers) -->
            <div class="hidden md:grid grid-cols-3 gap-x-10 gap-y-2 ml-auto text-sm">
                <div class="flex items-center gap-2">
                    <span class="text-gray-500">Đánh Giá</span>
                    <span class="font-semibold" style="color: #F97316">@Model.Product.ReviewCount</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-gray-500">Sản Phẩm</span>
                    <span class="font-semibold" style="color: #F97316">—</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-gray-500">Tham Gia</span>
                    <span class="font-semibold" style="color: #F97316">—</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-gray-500">Tỉ Lệ Phản Hồi</span>
                    <span class="font-semibold" style="color: #F97316">—</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-gray-500">Thời Gian Phản Hồi</span>
                    <span class="font-semibold" style="color: #F97316">—</span>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-gray-500">Người Theo Dõi</span>
                    <span class="font-semibold" style="color: #F97316">—</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ==================== SECTION 3: Chi Tiết & Mô Tả ==================== -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-4">
        <!-- Chi Tiết Sản Phẩm (Specs Table) -->
        <h2 class="text-lg font-bold text-gray-900 mb-4 uppercase tracking-wide">Chi Tiết Sản Phẩm</h2>

        @if (Model.Product.Specs.Any())
        {
            <div class="mb-6">
                <!-- Category row -->
                <div class="flex py-3 border-b border-gray-50">
                    <span class="text-gray-500 text-sm w-44 flex-shrink-0">Danh Mục</span>
                    <div class="text-sm">
                        @foreach (var crumb in Model.Product.Breadcrumbs)
                        {
                            <a href="/category/@crumb.Slug" class="text-primary hover:underline">@crumb.Name</a>
                            <span class="text-gray-400 mx-1">›</span>
                        }
                        <span class="text-gray-700">@Model.Product.CategoryName</span>
                    </div>
                </div>
                @foreach (var spec in Model.Product.Specs)
                {
                    <div class="flex py-3 border-b border-gray-50" style="background-color: @(Model.Product.Specs.ToList().IndexOf(spec) % 2 == 0 ? "#FAFAFA" : "white")">
                        <span class="text-gray-500 text-sm w-44 flex-shrink-0">@spec.Key</span>
                        <span class="text-sm text-gray-900 font-medium">@spec.Value</span>
                    </div>
                }
            </div>
        }

        <!-- Mô Tả Sản Phẩm -->
        <h2 class="text-lg font-bold text-gray-900 mb-4 uppercase tracking-wide">Mô Tả Sản Phẩm</h2>
        @if (!string.IsNullOrWhiteSpace(Model.Product.Description))
        {
            <div class="text-gray-700 leading-relaxed whitespace-pre-line text-sm">@Model.Product.Description</div>
        }
        else
        {
            <p class="text-gray-400 italic text-sm">Chưa có mô tả cho sản phẩm này.</p>
        }
    </div>

    <!-- ==================== SECTION 4: Đánh Giá Sản Phẩm ==================== -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 mb-4">
        <h2 class="text-lg font-bold text-gray-900 mb-4 uppercase tracking-wide">Đánh Giá Sản Phẩm</h2>

        <!-- Rating Summary -->
        <div class="rounded-lg p-5 mb-6 border" style="border-color: #FBBF24; background-color: #FFFBEB">
            <div class="flex flex-col md:flex-row gap-8">
                <div class="flex flex-col items-center justify-center min-w-[140px]">
                    <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-bold" style="color: #F97316">@Model.ReviewResult.Summary.AverageRating.ToString("F1")</span>
                        <span class="text-xl text-gray-400">trên 5</span>
                    </div>
                    <div class="flex items-center gap-0.5 mt-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var filled = i <= Math.Round(Model.ReviewResult.Summary.AverageRating);
                            <span class="material-symbols-outlined text-[20px] star-fill" style="color: @(filled ? "#FBBF24" : "#D1D5DB")">star</span>
                        }
                    </div>
                </div>
                <!-- Filter buttons -->
                <div class="flex flex-wrap gap-2 items-center" id="reviewFilterBtns">
                    <button onclick="filterReviews(null)" data-rating=""
                            class="filter-btn px-4 py-2 rounded-lg border text-sm font-medium transition-colors bg-primary text-white border-primary">
                        Tất Cả
                    </button>
                    @for (int s = 5; s >= 1; s--)
                    {
                        var cnt = Model.ReviewResult.Summary.RatingDistribution[s - 1];
                        <button onclick="filterReviews(@s)" data-rating="@s"
                                class="filter-btn px-4 py-2 rounded-lg border text-sm font-medium transition-colors border-gray-300 text-gray-600 hover:border-primary hover:text-primary">
                            @s Sao (<span class="rating-count-@s">@cnt</span>)
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Review List Container (AJAX target) -->
        <div id="reviewListContainer">
        @if (Model.ReviewResult.Reviews.Any())
        {
            <div class="divide-y divide-gray-100">
                @foreach (var review in Model.ReviewResult.Reviews)
                {
                    <div class="py-5">
                        <div class="flex items-start gap-3">
                            <!-- Avatar -->
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm flex-shrink-0">
                                @(review.UserName.Length > 0 ? review.UserName[0].ToString().ToUpper() : "?")
                            </div>
                            <div class="flex-1 min-w-0">
                                <!-- Username -->
                                <p class="font-medium text-sm text-gray-800">@review.UserName</p>
                                <!-- Stars -->
                                <div class="flex items-center gap-0.5 mt-0.5">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="material-symbols-outlined text-[14px] star-fill" style="color: @(i <= review.Rating ? "#FBBF24" : "#D1D5DB")">star</span>
                                    }
                                </div>
                                <!-- Date + Variant -->
                                <p class="text-xs text-gray-400 mt-1">@review.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                                @if (review.IsVerifiedPurchase)
                                {
                                    <p class="text-xs text-gray-500 mt-0.5">
                                        <span class="inline-flex items-center gap-1 text-green-600">
                                            <span class="material-symbols-outlined text-[12px]">check</span>
                                            Đã mua hàng
                                        </span>
                                    </p>
                                }
                                <!-- Title & Comment -->
                                @if (!string.IsNullOrWhiteSpace(review.Title))
                                {
                                    <p class="font-semibold text-gray-800 mt-3 text-sm">@review.Title</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(review.Comment))
                                {
                                    <p class="text-gray-700 text-sm mt-1 leading-relaxed">@review.Comment</p>
                                }
                                <!-- Helpful button -->
                                <div class="flex items-center gap-4 mt-3">
                                    <button class="flex items-center gap-1 text-xs text-gray-400 hover:text-gray-600 transition-colors">
                                        <span class="material-symbols-outlined text-[16px]">thumb_up</span>
                                        Hữu ích?
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.ReviewResult.TotalPages > 1)
            {
                <div class="flex justify-center gap-2 pt-4 border-t border-gray-100" id="reviewPagination">
                    @for (int p = 1; p <= Model.ReviewResult.TotalPages; p++)
                    {
                        var isActive = p == Model.ReviewResult.CurrentPage;
                        <button onclick="fetchReviews(@p)" class="px-3.5 py-1.5 rounded text-sm font-medium @(isActive ? "bg-primary text-white" : "bg-white border border-gray-300 text-gray-600 hover:border-primary hover:text-primary") transition-colors">
                            @p
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <div class="text-center py-10 text-gray-400">
                <span class="material-symbols-outlined text-6xl text-gray-200 block mx-auto mb-3">chat_bubble_outline</span>
                <p class="text-base font-medium text-gray-500">Chưa có đánh giá nào</p>
                <p class="text-sm text-gray-400 mt-1">Hãy là người đầu tiên đánh giá sản phẩm này!</p>
            </div>
        }
        </div>

        <!-- Review Form -->
        <div class="border-t border-gray-200 pt-5 mt-5">
            <h3 class="text-base font-bold text-gray-900 mb-4">Viết đánh giá của bạn</h3>

            @if (!string.IsNullOrWhiteSpace(Model.ReviewMessage))
            {
                <div class="mb-4 p-3 rounded-lg text-sm @(Model.ReviewSuccess ? "bg-green-50 text-green-700 border border-green-200" : "bg-red-50 text-red-700 border border-red-200")">
                    @Model.ReviewMessage
                </div>
            }

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form method="post" asp-page-handler="Review" asp-route-slug="@Model.Product.Slug">
                    <input type="hidden" asp-for="ReviewInput.ProductId" value="@Model.Product.Id" />

                    <!-- Star Rating -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Đánh giá sao *</label>
                        <div class="flex gap-1" id="star-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="button" onclick="setRating(@i)" class="star-btn transition-colors" style="color: #FBBF24">
                                    <span class="material-symbols-outlined text-[32px] star-fill">star</span>
                                </button>
                            }
                        </div>
                        <input type="hidden" asp-for="ReviewInput.Rating" id="ratingInput" value="5" />
                    </div>

                    <!-- Title -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tiêu đề</label>
                        <input type="text" asp-for="ReviewInput.Title" placeholder="Tóm tắt đánh giá..."
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm" />
                    </div>

                    <!-- Comment -->
                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nội dung đánh giá</label>
                        <textarea asp-for="ReviewInput.Comment" rows="4" placeholder="Chia sẻ trải nghiệm của bạn..."
                                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-sm resize-none"></textarea>
                    </div>

                    <button type="submit" style="background-color: #F97316"
                            class="text-white px-6 py-2.5 rounded-lg font-semibold text-sm hover:opacity-90 transition-colors">
                        Gửi đánh giá
                    </button>
                </form>
            }
            else
            {
                <div class="text-center py-6 bg-gray-50 rounded-lg">
                    <p class="text-gray-500 mb-3 text-sm">Bạn cần đăng nhập để viết đánh giá</p>
                    <a href="/Login" class="inline-block bg-primary text-white px-6 py-2 rounded-lg font-semibold text-sm hover:bg-primary/90 transition-colors">
                        Đăng nhập
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Gallery: switch main image
        function setMainImage(url, btn) {
            document.getElementById('mainImage').src = url;
            document.querySelectorAll('.thumbnail-btn').forEach(b => {
                b.classList.remove('border-primary', 'ring-2', 'ring-primary/20');
                b.classList.add('border-gray-200');
            });
            btn.classList.add('border-primary', 'ring-2', 'ring-primary/20');
            btn.classList.remove('border-gray-200');
        }

        // Variant selector
        function selectVariant(id, price, btn) {
            document.querySelectorAll('.variant-btn').forEach(b => {
                b.classList.remove('border-primary', 'text-primary', 'bg-primary/5');
                b.classList.add('border-gray-200');
            });
            btn.classList.add('border-primary', 'text-primary', 'bg-primary/5');
            btn.classList.remove('border-gray-200');
        }

        // Quantity
        function changeQty(delta) {
            const input = document.getElementById('qtyInput');
            let val = parseInt(input.value || '1') + delta;
            const max = parseInt(input.max) || 999;
            if (val < 1) val = 1;
            if (val > max) val = max;
            input.value = val;
            validateQty();
        }

        function validateQty() {
            const input = document.getElementById('qtyInput');
            const warning = document.getElementById('qtyWarning');
            const warningText = document.getElementById('qtyWarningText');
            const max = parseInt(input.max) || 999;
            let val = parseInt(input.value);

            if (isNaN(val) || val < 1) {
                warning.classList.remove('hidden');
                warningText.textContent = 'Số lượng tối thiểu là 1';
                return;
            }
            if (val > max) {
                warning.classList.remove('hidden');
                warningText.textContent = 'Số lượng không được vượt quá ' + max + ' (tồn kho hiện tại)';
                input.value = max;
                return;
            }
            warning.classList.add('hidden');
        }

        // Star rating
        function setRating(rating) {
            document.getElementById('ratingInput').value = rating;
            document.querySelectorAll('.star-btn').forEach((btn, i) => {
                btn.style.color = i < rating ? '#FBBF24' : '#D1D5DB';
            });
        }
        document.addEventListener('DOMContentLoaded', () => setRating(5));

        // AJAX Review Filter
        let currentFilterRating = null;
        let currentReviewPage = 1;
        const productId = '@Model.Product.Id';
        const productSlug = '@Model.Product.Slug';

        function filterReviews(rating) {
            currentFilterRating = rating;
            currentReviewPage = 1;
            // Update button styles
            document.querySelectorAll('.filter-btn').forEach(btn => {
                const btnRating = btn.dataset.rating;
                const isActive = (rating === null && btnRating === '') || (String(rating) === btnRating);
                if (isActive) {
                    btn.className = 'filter-btn px-4 py-2 rounded-lg border text-sm font-medium transition-colors bg-primary text-white border-primary';
                } else {
                    btn.className = 'filter-btn px-4 py-2 rounded-lg border text-sm font-medium transition-colors border-gray-300 text-gray-600 hover:border-primary hover:text-primary';
                }
            });
            fetchReviews(1);
        }

        function fetchReviews(page) {
            currentReviewPage = page;
            let url = `/product/${productSlug}?handler=ReviewsJson&productId=${productId}&reviewPage=${page}`;
            if (currentFilterRating !== null) {
                url += `&filterRating=${currentFilterRating}`;
            }
            const container = document.getElementById('reviewListContainer');
            container.innerHTML = '<div class="text-center py-10"><div class="inline-block w-6 h-6 border-2 border-primary border-t-transparent rounded-full animate-spin"></div><p class="text-sm text-gray-400 mt-2">Đang tải...</p></div>';

            fetch(url)
                .then(res => res.json())
                .then(data => renderReviews(data))
                .catch(err => {
                    container.innerHTML = '<div class="text-center py-10 text-red-500">Có lỗi khi tải đánh giá.</div>';
                });
        }

        function renderReviews(data) {
            const container = document.getElementById('reviewListContainer');
            let html = '';

            if (data.reviews && data.reviews.length > 0) {
                html += '<div class="divide-y divide-gray-100">';
                data.reviews.forEach(r => {
                    const initial = r.userName && r.userName.length > 0 ? r.userName[0].toUpperCase() : '?';
                    let stars = '';
                    for (let i = 1; i <= 5; i++) {
                        const color = i <= r.rating ? '#FBBF24' : '#D1D5DB';
                        stars += `<span class="material-symbols-outlined text-[14px] star-fill" style="color: ${color}">star</span>`;
                    }
                    const verified = r.isVerifiedPurchase ? `<p class="text-xs text-gray-500 mt-0.5"><span class="inline-flex items-center gap-1 text-green-600"><span class="material-symbols-outlined text-[12px]">check</span>Đã mua hàng</span></p>` : '';
                    const title = r.title ? `<p class="font-semibold text-gray-800 mt-3 text-sm">${escHtml(r.title)}</p>` : '';
                    const comment = r.comment ? `<p class="text-gray-700 text-sm mt-1 leading-relaxed">${escHtml(r.comment)}</p>` : '';

                    html += `<div class="py-5"><div class="flex items-start gap-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0" style="background-color: rgba(37,99,235,0.1); color: #2563EB">${initial}</div>
                        <div class="flex-1 min-w-0">
                            <p class="font-medium text-sm text-gray-800">${escHtml(r.userName)}</p>
                            <div class="flex items-center gap-0.5 mt-0.5">${stars}</div>
                            <p class="text-xs text-gray-400 mt-1">${r.createdAt}</p>
                            ${verified}${title}${comment}
                            <div class="flex items-center gap-4 mt-3">
                                <button class="flex items-center gap-1 text-xs text-gray-400 hover:text-gray-600 transition-colors">
                                    <span class="material-symbols-outlined text-[16px]">thumb_up</span>Hữu ích?
                                </button>
                            </div>
                        </div>
                    </div></div>`;
                });
                html += '</div>';

                // Pagination
                if (data.totalPages > 1) {
                    html += '<div class="flex justify-center gap-2 pt-4 border-t border-gray-100">';
                    for (let p = 1; p <= data.totalPages; p++) {
                        const cls = p === data.currentPage
                            ? 'bg-primary text-white'
                            : 'bg-white border border-gray-300 text-gray-600 hover:border-primary hover:text-primary';
                        html += `<button onclick="fetchReviews(${p})" class="px-3.5 py-1.5 rounded text-sm font-medium ${cls} transition-colors">${p}</button>`;
                    }
                    html += '</div>';
                }
            } else {
                html = `<div class="text-center py-10 text-gray-400">
                    <span class="material-symbols-outlined text-6xl text-gray-200 block mx-auto mb-3">chat_bubble_outline</span>
                    <p class="text-base font-medium text-gray-500">Không có đánh giá nào cho bộ lọc này</p>
                    <p class="text-sm text-gray-400 mt-1">Thử chọn bộ lọc khác.</p>
                </div>`;
            }
            container.innerHTML = html;
        }

        function escHtml(str) {
            if (!str) return '';
            const div = document.createElement('div');
            div.textContent = str;
            return div.innerHTML;
        }
    </script>
}
