@page "/admin/finance/wallet"
@model GearZone.Web.Pages.Admin.Wallet.IndexModel
@using GearZone.Application.Features.Admin.Dtos
@using GearZone.Domain.Enums
@{
    ViewData["Title"] = "Wallet Management";
    ViewData["PageHeader"] = "Wallet Management";
    ViewData["ActivePage"] = "Wallet";
    ViewData["Breadcrumb"] = new string[] { "Finance", "Wallet" };
    Layout = "_AdminLayout";

    string StatusClass(WalletStatusLevel lvl) => lvl switch {
        WalletStatusLevel.Low => "red",
        WalletStatusLevel.Warning => "amber",
        _ => "emerald"
    };
    string StatusLabel(WalletStatusLevel lvl) => lvl switch {
        WalletStatusLevel.Low => "Low Balance",
        WalletStatusLevel.Warning => "Warning",
        _ => "Healthy"
    };
    string StatusDesc(WalletStatusLevel lvl) => lvl switch {
        WalletStatusLevel.Low => "Top-up required before next payout",
        WalletStatusLevel.Warning => "Balance may be insufficient for pending payouts",
        _ => "Balance is sufficient for upcoming payouts"
    };

    string TypeBadgeClass(WalletTransactionType t) => t switch {
        WalletTransactionType.Topup => "bg-emerald-50 text-emerald-700 border-emerald-100",
        WalletTransactionType.Payout => "bg-blue-50 text-blue-700 border-blue-100",
        WalletTransactionType.Refund => "bg-red-50 text-red-700 border-red-100",
        _ => "bg-slate-100 text-slate-600 border-slate-200"
    };
    string StatusBadgeClass(WalletTransactionStatus s) => s switch {
        WalletTransactionStatus.Completed => "bg-emerald-50 text-emerald-700 border-emerald-100",
        WalletTransactionStatus.Failed => "bg-red-50 text-red-700 border-red-100",
        WalletTransactionStatus.Reversed => "bg-slate-100 text-slate-500 border-slate-200",
        _ => "bg-amber-50 text-amber-700 border-amber-100"
    };
    string StatusDotClass(WalletTransactionStatus s) => s switch {
        WalletTransactionStatus.Completed => "bg-emerald-500",
        WalletTransactionStatus.Failed => "bg-red-500",
        WalletTransactionStatus.Reversed => "bg-slate-400",
        _ => "bg-amber-500 animate-pulse"
    };

    var sc = StatusClass(Model.Summary.StatusLevel);
}

<div class="flex flex-col gap-6 pb-10">
    <!-- Topup + Refresh Buttons -->
    <div class="flex justify-end gap-3">
        <button type="button" class="flex items-center gap-2 px-4 py-2.5 rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 font-semibold text-sm shadow-sm transition-all" onclick="location.reload()">
            <span class="material-symbols-outlined text-[20px]">refresh</span>
            Refresh Balance
        </button>
        <button type="button" class="flex items-center gap-2 bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-lg text-sm font-bold shadow-soft transition-all" onclick="openTopupModal()">
            <span class="material-symbols-outlined text-[20px]">add_circle</span>
            Topup Wallet
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 px-5 py-3.5 bg-emerald-50 border border-emerald-200 rounded-xl text-emerald-700 font-medium text-sm">
            <span class="material-symbols-outlined text-emerald-500">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }

    <!-- Section 1: Wallet Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Available Balance -->
        <div class="bg-white p-5 rounded-xl shadow-card border border-slate-100 flex flex-col gap-4">
            <div class="flex items-center justify-between">
                <div class="size-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50">
                    <span class="material-symbols-outlined text-[26px]">account_balance_wallet</span>
                </div>
                @if (Model.Summary.IsBalanceLive)
                {
                    <span class="text-[10px] font-bold text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full uppercase tracking-wider border border-emerald-100">Live</span>
                }
                else
                {
                    <span class="text-[10px] font-bold text-slate-400 bg-slate-50 px-2.5 py-1 rounded-full uppercase tracking-wider border border-slate-200">Offline</span>
                }
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1">Available Balance</p>
                <h3 class="text-2xl font-black text-slate-900 leading-tight">
                    @if (Model.Summary.IsBalanceLive && Model.Summary.AvailableBalanceRaw.HasValue)
                    {
                        @:đ @Model.Summary.AvailableBalanceRaw.Value.ToString("N0")
                    }
                    else
                    {
                        <span class="text-slate-400">N/A</span>
                    }
                </h3>
                <p class="text-[11px] text-slate-400 mt-2 font-medium">Current BaoKim wallet balance</p>
            </div>
        </div>

        <!-- Pending Payout -->
        <div class="bg-white p-5 rounded-xl shadow-card border border-slate-100 flex flex-col gap-4">
            <div class="size-12 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center border border-amber-100/50">
                <span class="material-symbols-outlined text-[26px]">schedule_send</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1">Pending Payout</p>
                <h3 class="text-2xl font-black text-slate-900 leading-tight">đ @Model.Summary.PendingPayoutAmount.ToString("N0")</h3>
                <p class="text-[11px] text-slate-400 mt-2 font-medium">Approved/Processing batches</p>
            </div>
        </div>

        <!-- Next Batch Required -->
        <div class="bg-white p-5 rounded-xl shadow-card border border-slate-100 flex flex-col gap-4">
            <div class="size-12 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center border border-purple-100/50">
                <span class="material-symbols-outlined text-[26px]">account_balance</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1">Next Batch Required</p>
                <h3 class="text-2xl font-black text-slate-900 leading-tight">đ @Model.Summary.NextBatchRequiredAmount.ToString("N0")</h3>
                <p class="text-[11px] text-slate-400 mt-2 font-medium">Pending approval batches</p>
            </div>
        </div>

        <!-- Wallet Status -->
        <div class="bg-white p-5 rounded-xl shadow-card border-2 border-@(sc)-100 flex flex-col gap-4 relative overflow-hidden">
            <div class="flex items-center justify-between">
                <div class="size-12 rounded-lg bg-@(sc)-50 text-@(sc)-600 flex items-center justify-center border border-@(sc)-100/50">
                    <span class="material-symbols-outlined text-[26px]">
                        @(Model.Summary.StatusLevel == WalletStatusLevel.Healthy ? "check_circle" : "notification_important")
                    </span>
                </div>
                @if (Model.Summary.StatusLevel != WalletStatusLevel.Healthy)
                {
                    <span class="flex h-2 w-2 relative">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-@(sc)-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-@(sc)-500"></span>
                    </span>
                }
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-1">Wallet Status</p>
                <h3 class="text-2xl font-black text-@(sc)-600 leading-tight">@StatusLabel(Model.Summary.StatusLevel)</h3>
                <p class="text-[11px] text-@(sc)-500/80 mt-2 font-medium">@StatusDesc(Model.Summary.StatusLevel)</p>
            </div>
        </div>
    </div>

    <!-- Section 2: Balance Chart -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/30">
            <div>
                <h3 class="text-base font-bold text-slate-900">Wallet Balance History</h3>
                <p class="text-xs text-slate-500 mt-0.5 font-medium">Balance trend over recent completed transactions</p>
            </div>
        </div>
        <div class="p-6">
            <div class="h-[280px] w-full relative">
                <canvas id="walletHistoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Section 3: Transactions Table -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
        <!-- Filters -->
        <div class="p-5 border-b border-slate-100 bg-slate-50/50">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-base font-bold text-slate-900 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[22px]">history</span>
                    Wallet Transactions
                    <span class="ml-2 px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 text-xs font-bold">@Model.Transactions.TotalCount</span>
                </h3>
            </div>

            <form method="get" id="filter-form">
                <input type="hidden" name="Query.PageNumber" value="1" />
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-3">
                    <!-- Search -->
                    <div class="lg:col-span-2 relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400 pointer-events-none">
                            <span class="material-symbols-outlined text-[20px]">search</span>
                        </span>
                        <input type="text" name="Query.Search" value="@Model.Query.Search"
                               placeholder="Search by code, reference, or note…"
                               class="form-input block w-full pl-10 pr-4 py-2 bg-white border-slate-200 rounded-lg text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all font-medium placeholder:text-slate-400" />
                    </div>

                    <!-- Type -->
                    <select name="Query.Type" class="form-select bg-white border-slate-200 rounded-lg text-sm font-medium text-slate-700 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all">
                        <option value="">All Types</option>
                        @foreach (WalletTransactionType t in Enum.GetValues<WalletTransactionType>())
                        {
                            <option value="@t" selected="@(Model.Query.Type == t)">@t</option>
                        }
                    </select>

                    <!-- Status -->
                    <select name="Query.Status" class="form-select bg-white border-slate-200 rounded-lg text-sm font-medium text-slate-700 focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all">
                        <option value="">All Statuses</option>
                        @foreach (WalletTransactionStatus s in Enum.GetValues<WalletTransactionStatus>())
                        {
                            <option value="@s" selected="@(Model.Query.Status == s)">@s</option>
                        }
                    </select>

                    <!-- Submit -->
                    <div class="flex gap-2">
                        <button type="submit" class="flex-1 flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-4 py-2 rounded-lg text-sm font-bold transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[18px]">search</span> Apply
                        </button>
                        <a asp-page="/Admin/Wallet/Index" class="flex items-center justify-center p-2 rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 transition-colors bg-white shadow-sm" title="Reset filters">
                            <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                        </a>
                    </div>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-max">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100 text-slate-500">
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">Code</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">Date & Time</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">Type</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">Reference</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest whitespace-nowrap">Description / Note</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest text-right whitespace-nowrap">Amount</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest text-right whitespace-nowrap">Balance After</th>
                        <th class="py-3.5 px-5 text-[10px] font-bold uppercase tracking-widest text-center whitespace-nowrap">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 text-sm">
                    @if (!Model.Transactions.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="py-20 text-center">
                                <div class="flex flex-col items-center gap-3 text-slate-400">
                                    <span class="material-symbols-outlined text-[48px] text-slate-200">account_balance_wallet</span>
                                    <p class="text-base font-semibold">No transactions found</p>
                                    <p class="text-xs">Try adjusting your search or filter criteria</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var tx in Model.Transactions.Items)
                    {
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="py-4 px-5 font-mono font-bold text-primary text-xs">@tx.TransactionCode</td>
                            <td class="py-4 px-5 whitespace-nowrap text-slate-500 font-medium text-xs">
                                <div>@tx.CreatedAt.ToString("MMM dd, yyyy")</div>
                                <div class="text-slate-400">@tx.CreatedAt.ToString("HH:mm:ss")</div>
                            </td>
                            <td class="py-4 px-5">
                                <span class="px-2.5 py-1 rounded-md text-[10px] font-black uppercase border @TypeBadgeClass(tx.Type)">
                                    @tx.Type
                                </span>
                            </td>
                            <td class="py-4 px-5">
                                @if (!string.IsNullOrEmpty(tx.PayoutBatchCode))
                                {
                                    <span class="text-xs font-bold text-primary bg-blue-50/50 px-2.5 py-1 rounded-lg">@tx.PayoutBatchCode</span>
                                }
                                else if (!string.IsNullOrEmpty(tx.ReferenceCode))
                                {
                                    <span class="text-xs font-bold text-slate-700 bg-slate-100 px-2.5 py-1 rounded-lg">@tx.ReferenceCode</span>
                                }
                                else
                                {
                                    <span class="text-slate-300">—</span>
                                }
                            </td>
                            <td class="py-4 px-5 text-slate-600 font-medium italic text-xs max-w-[200px] truncate">
                                @(string.IsNullOrEmpty(tx.Note) ? "—" : tx.Note)
                            </td>
                            <td class="py-4 px-5 text-right font-black whitespace-nowrap @(tx.Direction == TransactionDirection.IN ? "text-emerald-600" : "text-red-500")">
                                @(tx.Direction == TransactionDirection.IN ? "+" : "−") đ @tx.Amount.ToString("N0")
                            </td>
                            <td class="py-4 px-5 text-right font-bold text-slate-800 whitespace-nowrap">
                                @if (tx.Status == WalletTransactionStatus.Completed)
                                {
                                    @:đ @tx.BalanceAfter.ToString("N0")
                                }
                                else
                                {
                                    <span class="text-slate-400">—</span>
                                }
                            </td>
                            <td class="py-4 px-5 text-center">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[10px] font-bold border @StatusBadgeClass(tx.Status)">
                                    <span class="size-1.5 rounded-full @StatusDotClass(tx.Status)"></span>
                                    @tx.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.Transactions.TotalPages > 1)
        {
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-3">
                <span class="text-xs font-medium text-slate-500">
                    Showing @((Model.Query.PageNumber - 1) * Model.Query.PageSize + 1)–@(Math.Min(Model.Query.PageNumber * Model.Query.PageSize, Model.Transactions.TotalCount))
                    of @Model.Transactions.TotalCount results
                </span>
                <nav class="flex items-center gap-1">
                    @if (Model.Transactions.PageNumber > 1)
                    {
                        <a asp-page="/Admin/Wallet/Index"
                           asp-route-Query.PageNumber="@(Model.Transactions.PageNumber - 1)"
                           asp-route-Query.Search="@Model.Query.Search"
                           asp-route-Query.Type="@Model.Query.Type"
                           asp-route-Query.Status="@Model.Query.Status"
                           class="p-2 rounded-lg border border-slate-200 text-slate-600 hover:bg-white hover:text-primary transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </a>
                    }
                    else
                    {
                        <span class="p-2 rounded-lg border border-slate-100 text-slate-300 bg-slate-50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </span>
                    }

                    @for (int i = Math.Max(1, Model.Transactions.PageNumber - 2); i <= Math.Min(Model.Transactions.TotalPages, Model.Transactions.PageNumber + 2); i++)
                    {
                        <a asp-page="/Admin/Wallet/Index"
                           asp-route-Query.PageNumber="@i"
                           asp-route-Query.Search="@Model.Query.Search"
                           asp-route-Query.Type="@Model.Query.Type"
                           asp-route-Query.Status="@Model.Query.Status"
                           class="min-w-[36px] h-9 flex items-center justify-center rounded-lg text-sm font-bold transition-all @(i == Model.Transactions.PageNumber ? "bg-primary text-white shadow-sm" : "border border-transparent text-slate-600 hover:border-slate-200 hover:bg-white hover:text-primary")">
                            @i
                        </a>
                    }

                    @if (Model.Transactions.PageNumber < Model.Transactions.TotalPages)
                    {
                        <a asp-page="/Admin/Wallet/Index"
                           asp-route-Query.PageNumber="@(Model.Transactions.PageNumber + 1)"
                           asp-route-Query.Search="@Model.Query.Search"
                           asp-route-Query.Type="@Model.Query.Type"
                           asp-route-Query.Status="@Model.Query.Status"
                           class="p-2 rounded-lg border border-slate-200 text-slate-600 hover:bg-white hover:text-primary transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </a>
                    }
                    else
                    {
                        <span class="p-2 rounded-lg border border-slate-100 text-slate-300 bg-slate-50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </span>
                    }
                </nav>
            </div>
        }
    </div>
</div>

<!-- Topup Modal -->
<div id="topupModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen px-4">
        <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeTopupModal()"></div>

        <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-lg p-8 animate-in fade-in zoom-in duration-200">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                    <div class="size-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100">
                        <span class="material-symbols-outlined text-[22px]">account_balance_wallet</span>
                    </div>
                    <h3 class="text-xl font-black text-slate-900">Topup Platform Wallet</h3>
                </div>
                <button type="button" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-100 rounded-full transition-colors" onclick="closeTopupModal()">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <form method="post" asp-page-handler="Topup">
                @Html.AntiForgeryToken()
                <div class="space-y-5">
                    <!-- Amount -->
                    <div class="space-y-1.5">
                        <label asp-for="TopupInput.Amount" class="block text-[11px] font-black text-slate-500 uppercase tracking-widest pl-1">Amount (VND) *</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400 font-bold">đ</span>
                            <input asp-for="TopupInput.Amount" type="number" min="1" step="1000"
                                   class="form-input block w-full pl-8 pr-4 py-3 bg-slate-50 border-slate-200 rounded-xl text-lg font-black text-slate-900 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all placeholder:text-slate-300"
                                   placeholder="0" />
                        </div>
                        <span asp-validation-for="TopupInput.Amount" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Provider Transaction ID -->
                    <div class="space-y-1.5">
                        <label asp-for="TopupInput.ProviderTransactionId" class="block text-[11px] font-black text-slate-500 uppercase tracking-widest pl-1">Provider Transaction ID *</label>
                        <input asp-for="TopupInput.ProviderTransactionId" type="text"
                               class="form-input block w-full px-4 py-2.5 bg-slate-50 border-slate-200 rounded-xl text-sm font-semibold font-mono text-slate-900 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all"
                               placeholder="e.g. BK12345678" />
                        <span asp-validation-for="TopupInput.ProviderTransactionId" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Note -->
                    <div class="space-y-1.5">
                        <label asp-for="TopupInput.Note" class="block text-[11px] font-black text-slate-500 uppercase tracking-widest pl-1">Note (Optional)</label>
                        <textarea asp-for="TopupInput.Note" rows="3"
                                  class="form-input block w-full px-4 py-2.5 bg-slate-50 border-slate-200 rounded-xl text-sm font-medium text-slate-900 focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all resize-none"
                                  placeholder="Add details about this top-up..."></textarea>
                    </div>
                </div>

                <div class="mt-8 flex gap-3">
                    <button type="button" onclick="closeTopupModal()" class="flex-1 px-4 py-3 bg-white border border-slate-200 text-slate-600 font-bold rounded-xl hover:bg-slate-50 transition-all">Cancel</button>
                    <button type="submit" class="flex-1 px-4 py-3 bg-primary hover:bg-primary-dark text-white font-black rounded-xl shadow-soft transition-all">Confirm Topup</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function openTopupModal() {
            document.getElementById('topupModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
        function closeTopupModal() {
            document.getElementById('topupModal').classList.add('hidden');
            document.body.style.overflow = '';
        }

        // Balance History Chart - from real data
        const historyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.BalanceHistory.OrderBy(x => x.CreatedAt).Select(x => new {
                date = x.CreatedAt.ToString("MMM dd"),
                balance = x.BalanceAfter
            }).ToList()
        ));

        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('walletHistoryChart').getContext('2d');

            let labels, data;
            if (historyData.length > 0) {
                labels = historyData.map(x => x.date);
                data = historyData.map(x => x.balance);
            } else {
                // Placeholder when no history exists
                labels = ['No Data'];
                data = [0];
            }

            const gradient = ctx.createLinearGradient(0, 0, 0, 260);
            gradient.addColorStop(0, 'rgba(26, 86, 219, 0.15)');
            gradient.addColorStop(1, 'rgba(26, 86, 219, 0)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Balance (VND)',
                        data: data,
                        borderColor: '#1A56DB',
                        borderWidth: 2.5,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        pointRadius: historyData.length < 20 ? 4 : 0,
                        pointHoverRadius: 6,
                        pointBackgroundColor: '#FFFFFF',
                        pointBorderColor: '#1A56DB',
                        pointBorderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: '#0F172A',
                            titleFont: { family: "'Inter', sans-serif", size: 11, weight: 'bold' },
                            bodyFont: { family: "'Inter', sans-serif", size: 12 },
                            padding: 12,
                            cornerRadius: 8,
                            callbacks: {
                                label: ctx => 'đ ' + ctx.parsed.y.toLocaleString('en-US')
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { font: { family: "'Inter', sans-serif", size: 10, weight: '600' }, color: '#94A3B8', maxRotation: 0 }
                        },
                        y: {
                            beginAtZero: false,
                            grid: { color: '#F1F5F9' },
                            ticks: {
                                font: { family: "'Inter', sans-serif", size: 10, weight: '600' }, color: '#94A3B8',
                                callback: v => v >= 1000000 ? 'đ' + (v / 1000000).toFixed(0) + 'M' : 'đ' + v.toLocaleString()
                            }
                        }
                    },
                    interaction: { intersect: false, mode: 'index' }
                }
            });
        });
    </script>
}
