@page "{id:Guid}"
@model GearZone.Web.Pages.StoreOwner.Products.DetailsModel
@{
    ViewData["Title"] = "Product Details - " + Model.Product.Name;
    ViewData["ActivePage"] = "Products";
    ViewData["PageHeader"] = "Product Details";
    ViewData["Breadcrumb"] = new string[] { "Products", "Details" };
    Layout = "_StoreOwnerLayout";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header Actions -->
    <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-4">
            <a asp-page="./Index" class="p-2 rounded-lg bg-white border border-gray-200 text-gray-500 hover:text-primary hover:border-primary transition-all">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-gray-900">@Model.Product.Name</h1>
                <p class="text-sm text-gray-500">ID: @Model.Product.Id</p>
            </div>
        </div>
        <div class="flex items-center gap-3">
            <a asp-page="./Edit" asp-route-id="@Model.Product.Id" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Edit Product</a>
            <span class="px-3 py-1.5 rounded-full text-xs font-bold @(Model.Product.Status == "Active" ? "bg-green-100 text-green-700" : "bg-gray-100 text-gray-700")">
                @Model.Product.Status
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left Column: Media & Details -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- Gallery -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h2 class="text-lg font-bold text-gray-900 mb-6">Product Gallery</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="aspect-square rounded-xl overflow-hidden bg-gray-50 border border-gray-100">
                        @if (Model.Product.ImageUrls.Any())
                        {
                            <img src="@Model.Product.ImageUrls[0]" class="w-full h-full object-cover" alt="Primary Image">
                        }
                        else
                        {
                            <div class="w-full h-full flex flex-col items-center justify-center text-gray-300">
                                <span class="material-symbols-outlined text-6xl">image</span>
                                <p class="text-sm font-medium">No Image</p>
                            </div>
                        }
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        @for (int i = 1; i < 5; i++)
                        {
                            <div class="aspect-square rounded-xl overflow-hidden bg-gray-50 border border-gray-100">
                                @if (Model.Product.ImageUrls.Count > i)
                                {
                                    <img src="@Model.Product.ImageUrls[i]" class="w-full h-full object-cover">
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-gray-200">
                                        <span class="material-symbols-outlined text-4xl">add_photo_alternate</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Description</h2>
                <div class="prose max-w-none text-gray-600">
                    @Html.Raw(Model.Product.Description)
                </div>
            </div>

            <!-- Variants Table -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h2 class="text-lg font-bold text-gray-900 mb-6">Product Variants</h2>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Variant</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Attributes</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">SKU</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Price</th>
                                <th class="px-4 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Stock</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var variant in Model.Product.Variants)
                            {
                                <tr>
                                    <td class="px-4 py-4 text-sm font-medium text-gray-900">@variant.VariantName</td>
                                    <td class="px-4 py-4 text-sm text-gray-500">
                                        @if (variant.Attributes.Any())
                                        {
                                            <div class="flex flex-wrap gap-1">
                                                @foreach (var attr in variant.Attributes)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                                                        @attr.AttributeName: @attr.OptionValue
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400 italic">None</span>
                                        }
                                    </td>
                                    <td class="px-4 py-4 text-sm text-gray-500">@variant.Sku</td>
                                    <td class="px-4 py-4 text-sm font-bold text-gray-900">@variant.Price.ToString("N0")₫</td>
                                    <td class="px-4 py-4 text-sm">
                                        <span class="@(variant.StockQuantity < 10 ? "text-red-600 font-bold" : "text-gray-900")">
                                            @variant.StockQuantity
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Column: Specs & Info -->
        <div class="space-y-8">
            <!-- Basic Info Card -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h2 class="text-sm font-bold text-gray-900 mb-6 uppercase tracking-wider">Information</h2>
                <div class="space-y-4">
                    <div class="flex justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Category</span>
                        <span class="text-sm font-bold text-gray-900">@Model.Product.CategoryName</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Brand</span>
                        <span class="text-sm font-bold text-gray-900">@Model.Product.BrandName</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Base Price</span>
                        <span class="text-sm font-bold text-primary">@Model.Product.BasePrice.ToString("N0")₫</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Sold Count</span>
                        <span class="text-sm font-bold text-gray-900">@Model.Product.SoldCount unit(s)</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-gray-50">
                        <span class="text-sm text-gray-500">Created At</span>
                        <span class="text-sm text-gray-900">@Model.Product.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
            </div>



            <!-- Quick Tips -->
            <div class="bg-primary/5 rounded-xl p-6 border border-primary/10">
                <div class="flex items-start gap-3">
                    <span class="material-symbols-outlined text-primary">analytics</span>
                    <div>
                        <h4 class="text-sm font-bold text-gray-900 mb-1">Stock Alert</h4>
                        <p class="text-xs text-gray-600 leading-relaxed">
                            Some variants are running low on stock. Consider restocking soon to maintain your search ranking.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
