@page
@model GearZone.Web.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Category Management";
    ViewData["PageHeader"] = "Category Management";
    ViewData["ActivePage"] = "Categories";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Category Management" };
    Layout = "_AdminLayout";
}

<div class="flex flex-col gap-6">
    <!-- Filters & Actions Bar -->
    <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex flex-col lg:flex-row gap-4 justify-between items-start lg:items-end">
        <form method="get" class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto flex-1">
            <!-- Search -->
            <div class="relative w-full sm:max-w-xs">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                    <span class="material-symbols-outlined text-[20px]">search</span>
                </span>
                <input asp-for="Query.SearchTerm" class="form-input w-full rounded-lg border-slate-200 bg-slate-50 pl-10 pr-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-primary focus:ring-primary" placeholder="Search by name or slug..." type="text" />
            </div>
            <!-- Status Filter -->
            <div class="w-full sm:w-40">
                <select asp-for="Query.IsActive" class="form-select w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 text-sm text-slate-900 focus:border-primary focus:ring-primary" onchange="this.form.submit()">
                    <option value="">All Status</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
            <!-- Search Submit Button -->
            <button type="submit" class="hidden">Search</button>
            <!-- Reset Button -->
            <a asp-page="/Admin/Categories/Index" class="flex items-center justify-center px-4 py-2.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 hover:text-slate-900 transition-colors">
                <span class="material-symbols-outlined text-[20px]">restart_alt</span>
            </a>
        </form>
        <!-- Add Button -->
        <button id="add-category-btn" class="w-full lg:w-auto flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-lg font-medium shadow-sm shadow-blue-500/30 transition-all">
            <span class="material-symbols-outlined text-[20px]">add</span>
            <span>Add New Category</span>
        </button>
    </div>

    <!-- Categories Table Card -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden flex flex-col">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="py-4 px-6 text-xs font-semibold uppercase tracking-wider text-slate-500 w-[50px]">
                            ID
                        </th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 w-1/4">Name</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 w-1/4">Slug</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 w-1/4 hidden md:table-cell">Parent Category</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 w-1/6">Status</th>
                        <th class="py-4 pl-3 pr-6 text-xs font-semibold uppercase tracking-wider text-slate-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Categories.Items.Any())
                    {
                        foreach (var category in Model.Categories.Items)
                        {
                            <tr class="group hover:bg-slate-50 transition-all cursor-pointer">
                                <td class="py-4 px-6 text-sm text-slate-500">
                                    #@category.Id
                                </td>
                                <td class="py-4 px-3">
                                    <span class="text-sm font-semibold text-slate-900 group-hover:text-primary transition-colors">@category.Name</span>
                                </td>
                                <td class="py-4 px-3">
                                    <span class="text-sm text-slate-600">@category.Slug</span>
                                </td>
                                <td class="py-4 px-3 hidden md:table-cell">
                                    @if (category.ParentId.HasValue)
                                    {
                                        <span class="inline-flex items-center rounded-lg bg-indigo-50 px-2.5 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                                            @category.ParentName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-400 italic">None (Root)</span>
                                    }
                                </td>
                                <td class="py-4 px-3">
                                    @if (category.IsActive)
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 px-2.5 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
                                            <span class="size-1.5 rounded-full bg-green-600"></span> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/20">
                                            <span class="size-1.5 rounded-full bg-slate-400"></span> Inactive
                                        </span>
                                    }
                                </td>
                                <td class="py-4 pl-3 pr-6 text-right">
                                    <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity stop-propagation">
                                        <button class="edit-category-btn text-slate-400 hover:text-amber-500 transition-colors p-1" title="Edit Category" data-id="@category.Id">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </button>
                                        <button class="delete-category-btn text-slate-400 hover:text-red-600 transition-colors p-1" title="Delete Category" data-id="@category.Id">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-8 text-center text-slate-500">
                                <div class="flex flex-col items-center justify-center space-y-3">
                                    <span class="material-symbols-outlined text-4xl text-slate-300">search_off</span>
                                    <p class="text-base font-medium">No categories found</p>
                                    <p class="text-sm">Try adjusting your filters or search term.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="border-t border-slate-100 px-6 py-4 bg-slate-50/30 flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="text-sm text-slate-500">
                Showing <span class="font-medium text-slate-900">@((Model.Categories.PageNumber - 1) * Model.Categories.PageSize + (Model.Categories.Items.Any() ? 1 : 0))</span> to
                <span class="font-medium text-slate-900">
                    @(Math.Min(Model.Categories.PageNumber * Model.Categories.PageSize, Model.Categories.TotalCount))
                </span> of
                <span class="font-medium text-slate-900">@Model.Categories.TotalCount</span> categories
            </div>

            @if (Model.Categories.TotalPages > 1)
            {
                <nav aria-label="Pagination" class="flex items-center gap-1">
                    <a asp-page="/Admin/Categories/Index"
                       asp-route-Query.PageNumber="@(Model.Categories.PageNumber - 1)"
                       asp-route-Query.SearchTerm="@Model.Query.SearchTerm"
                       asp-route-Query.IsActive="@Model.Query.IsActive"
                       class="@(Model.Categories.PageNumber <= 1 ? "pointer-events-none opacity-50" : "") p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm" title="Previous">
                        <span class="material-symbols-outlined text-lg leading-none">chevron_left</span>
                    </a>

                    <div class="flex items-center gap-1 px-1">
                        @for (int i = 1; i <= Model.Categories.TotalPages; i++)
                        {
                            <a asp-page="/Admin/Categories/Index"
                               asp-route-Query.PageNumber="@i"
                               asp-route-Query.SearchTerm="@Model.Query.SearchTerm"
                               asp-route-Query.IsActive="@Model.Query.IsActive"
                               class="min-w-[36px] h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-all @(i == Model.Categories.PageNumber ? "bg-primary text-white shadow-sm shadow-blue-500/20" : "border border-transparent text-slate-600 hover:border-slate-200 hover:bg-white hover:text-primary")">
                                @i
                            </a>
                        }
                    </div>

                    <a asp-page="/Admin/Categories/Index"
                       asp-route-Query.PageNumber="@(Model.Categories.PageNumber + 1)"
                       asp-route-Query.SearchTerm="@Model.Query.SearchTerm"
                       asp-route-Query.IsActive="@Model.Query.IsActive"
                       class="@(Model.Categories.PageNumber >= Model.Categories.TotalPages ? "pointer-events-none opacity-50" : "") p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm" title="Next">
                        <span class="material-symbols-outlined text-lg leading-none">chevron_right</span>
                    </a>
                </nav>
            }
        </div>
    </div>
</div>

<!-- Add New Category Modal -->
<div id="add-category-modal" class="fixed inset-0 z-[60] hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity"></div>

    <!-- Modal Content -->
    <div class="absolute inset-0 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-xl max-h-[90vh] overflow-hidden flex flex-col animate-in fade-in zoom-in duration-200">
            <!-- Header -->
            <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-white sticky top-0 z-10">
                <h3 class="text-xl font-bold text-slate-900">Add New Category</h3>
                <button type="button" class="close-modal-btn p-2 rounded-full text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-all">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <!-- Body -->
            <div class="p-6 overflow-y-auto custom-scrollbar">
                <form id="add-category-form" method="post" asp-page-handler="Create" class="space-y-6">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                    
                    <div class="space-y-4">
                        <div class="flex items-center gap-2 pb-1 border-b border-slate-100">
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Category Details</span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="CreateCategoryRequest.Name" class="block text-sm font-semibold text-slate-700"></label>
                            <div class="relative group">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400 group-focus-within:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-xl">category</span>
                                </span>
                                <input asp-for="CreateCategoryRequest.Name" placeholder="e.g. Mechanical Keyboards" class="w-full rounded-xl border-slate-200 bg-slate-50/50 pl-11 pr-4 py-2.5 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" />
                            </div>
                            <span asp-validation-for="CreateCategoryRequest.Name" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="CreateCategoryRequest.Slug" class="block text-sm font-semibold text-slate-700"></label>
                            <div class="relative group">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400 group-focus-within:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-xl">link</span>
                                </span>
                                <input asp-for="CreateCategoryRequest.Slug" placeholder="e.g. mechanical-keyboards" class="w-full rounded-xl border-slate-200 bg-slate-50/50 pl-11 pr-4 py-2.5 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-all" />
                            </div>
                            <span asp-validation-for="CreateCategoryRequest.Slug" class="text-xs text-red-500"></span>
                        </div>
                        
                        <div class="space-y-1.5">
                            <label asp-for="CreateCategoryRequest.ParentId" class="block text-sm font-semibold text-slate-700">Parent Category</label>
                            <div class="relative group">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400 group-focus-within:text-primary transition-colors">
                                    <span class="material-symbols-outlined text-xl">account_tree</span>
                                </span>
                                <select asp-for="CreateCategoryRequest.ParentId" class="appearance-none w-full rounded-xl border border-slate-200 bg-slate-50/50 pl-11 pr-10 py-2.5 text-sm focus:border-primary focus:ring-4 focus:ring-primary/10 transition-colors duration-200 cursor-pointer bg-none">
                                    <option value="">None (Root Category)</option>
                                    @if (Model.AllCategories != null)
                                    {
                                        foreach (var cat in Model.AllCategories)
                                        {
                                            <option value="@cat.Id">@cat.Name</option>
                                        }
                                    }
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-slate-400">
                                    <span class="material-symbols-outlined text-[20px]">expand_more</span>
                                </div>
                            </div>
                            <span asp-validation-for="CreateCategoryRequest.ParentId" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1.5 pt-2">
                            <label class="block text-sm font-semibold text-slate-700">Category Status</label>
                            <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/30 flex items-center justify-between group hover:border-primary/20 transition-colors duration-200">
                                <div class="flex flex-col">
                                    <span class="text-sm font-medium text-slate-900">Is Active?</span>
                                    <span class="text-xs text-slate-500">Enable category visibility</span>
                                </div>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input asp-for="CreateCategoryRequest.IsActive" class="sr-only peer" checked>
                                    <div class="w-11 h-6 bg-slate-200 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary shadow-sm"></div>
                                </label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>

            <!-- Footer -->
            <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50 flex justify-end gap-3">
                <button type="button" class="close-modal-btn px-5 py-2.5 rounded-xl border border-slate-200 bg-white text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:border-slate-300 transition-all shadow-sm">
                    Cancel
                </button>
                <button type="submit" form="add-category-form" class="px-6 py-2.5 rounded-xl bg-primary text-sm font-bold text-white hover:bg-primary-dark transition-all shadow-md shadow-primary/20">
                    Create Category
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
