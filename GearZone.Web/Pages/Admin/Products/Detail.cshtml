@page "/admin/products/{id?}"
@model GearZone.Web.Pages.Admin.Products.DetailModel
@{
    ViewData["Title"] = "Product Details - " + Model.Product.Name;
    ViewData["PageHeader"] = "Product Details";
    ViewData["ActivePage"] = "Products";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Product Management", Model.Product.Name };
    Layout = "_AdminLayout";

    var p = Model.Product;
}

<div class="flex flex-col gap-6 relative pb-28 w-full max-w-[1440px] mx-auto">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Left Column -->
        <div class="lg:col-span-7 xl:col-span-8 flex flex-col gap-6">
            <!-- Main Info Card -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 p-6 flex flex-col">
                <!-- Gallery -->
                <div class="mb-6">
                    @if (p.Images?.Any() == true)
                    {
                        var mainImg = p.Images.First();
                        <div class="w-full aspect-[16/9] lg:aspect-[21/9] xl:aspect-[16/9] bg-slate-50 rounded-xl mb-4 overflow-hidden relative group border border-slate-100 shadow-sm">
                            <div class="w-full h-full bg-center bg-no-repeat bg-contain" style="background-image: url('@mainImg');"></div>
                            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors cursor-pointer"></div>
                        </div>
                        
                        <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-3">
                            @foreach (var img in p.Images)
                            {
                                <div class="aspect-square rounded-lg border @(img == mainImg ? "border-primary" : "border-slate-200") cursor-pointer overflow-hidden hover:border-primary/50 transition-colors shadow-sm">
                                    <div class="w-full h-full bg-center bg-cover" style="background-image: url('@img');"></div>
                                </div>
                            }
                            <div class="aspect-square rounded-lg border border-slate-200 flex items-center justify-center bg-slate-50 cursor-pointer text-slate-400 hover:text-primary transition-colors shadow-sm hover:border-primary/50">
                                <span class="material-symbols-outlined">add_photo_alternate</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="w-full aspect-[16/9] bg-slate-50 rounded-xl border border-dashed border-slate-300 flex items-center justify-center flex-col gap-2 text-slate-400 mb-6">
                            <span class="material-symbols-outlined text-4xl">image_not_supported</span>
                            <span>No images uploaded</span>
                        </div>
                    }
                </div>

                <!-- Header Details -->
                <div class="flex flex-col gap-2 pt-2">
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-600 font-semibold text-[10px] uppercase tracking-wider">@p.Category?.Name</span>
                            
                            @if (p.Status == "Active")
                            {
                                <span class="px-2.5 py-0.5 rounded-full bg-green-50 text-green-700 text-xs font-bold border border-green-200 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">check_circle</span> Active
                                </span>
                            }
                            else if (p.Status == "Pending")
                            {
                                <span class="px-2.5 py-0.5 rounded-full bg-amber-50 text-amber-700 text-xs font-bold border border-amber-200 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">pendingActions</span> Pending Approval
                                </span>
                            }
                            else if (p.Status == "Suspended")
                            {
                                <span class="px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-700 text-xs font-bold border border-slate-300 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">block</span> Suspended
                                </span>
                            }
                            else
                            {
                                <span class="px-2.5 py-0.5 rounded-full bg-red-50 text-red-700 text-xs font-bold border border-red-200 flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">cancel</span> Rejected
                                </span>
                            }
                        </div>
                    </div>
                    
                    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 leading-tight">@p.Name</h1>
                    
                    <div class="flex flex-wrap items-center gap-y-2 gap-x-6 text-sm text-slate-500 mt-2">
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">label</span>
                            <span class="font-medium text-slate-700">Brand:</span> @p.Brand?.Name
                        </span>
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">qr_code_2</span>
                            <span class="font-medium text-slate-700">SKU:</span> <span class="font-mono">@p.Sku</span>
                        </span>
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-[16px]">storefront</span>
                            <span class="font-medium text-slate-700">Store:</span>
                            <a class="text-primary hover:underline font-bold flex items-center gap-0.5" href="#">
                                @p.Store?.Name
                                <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                            </a>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Product Attributes / Technical Specs -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center gap-2">
                    <span class="material-symbols-outlined text-slate-400">tune</span>
                    <h3 class="font-semibold text-lg text-slate-900">Technical Specifications</h3>
                </div>
                <div class="p-0 overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <tbody class="divide-y divide-slate-100">
                            @if (p.Specs != null && p.Specs.Count > 0)
                            {
                                foreach (var spec in p.Specs)
                                {
                                    <tr class="group hover:bg-slate-50">
                                        <td class="px-6 py-3 font-medium text-slate-600 bg-slate-50/30 w-1/3 align-top">@spec.AttributeName</td>
                                        <td class="px-6 py-3 text-slate-900">
                                            @if (spec.Values.Count == 1)
                                            {
                                                <span>@spec.Values[0]</span>
                                            }
                                            else
                                            {
                                                <div class="flex flex-wrap gap-1.5">
                                                    @foreach (var val in spec.Values)
                                                    {
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-slate-100 text-slate-700 text-xs font-medium border border-slate-200">@val</span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="px-6 py-8 text-center text-slate-400">
                                    <div class="flex flex-col items-center gap-2">
                                        <span class="material-symbols-outlined text-3xl text-slate-300">rule</span>
                                        <span class="text-sm">No category attribute specifications found for this product.</span>
                                    </div>
                                </td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Variants Detailed Table -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex items-center gap-2">
                    <span class="material-symbols-outlined text-slate-400">style</span>
                    <h3 class="font-semibold text-lg text-slate-900">Product Variants</h3>
                </div>
                <div class="p-0 overflow-x-auto">
                    <table class="w-full text-sm text-left">
                        <thead class="bg-slate-50">
                            <tr>
                                <th class="px-6 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">SKU</th>
                                <th class="px-6 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">Variant Name</th>
                                <th class="px-6 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">Attributes</th>
                                <th class="px-6 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider text-right">Price</th>
                                <th class="px-6 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider text-right">Stock</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @if (p.Variants != null && p.Variants.Count > 0)
                            {
                                foreach (var v in p.Variants)
                                {
                                    <tr class="group hover:bg-slate-50">
                                        <td class="px-6 py-3 text-slate-500 font-mono text-xs">@v.Sku</td>
                                        <td class="px-6 py-3 font-medium text-slate-900">
                                            @{
                                                var displayName = (!string.IsNullOrWhiteSpace(v.Name))
                                                    ? v.Name
                                                    : (p.Variants.Count == 1 ? p.Name : "—");
                                            }
                                            @displayName
                                        </td>
                                        <td class="px-6 py-3">
                                            @if (v.Attributes != null && v.Attributes.Any())
                                            {
                                                <div class="flex flex-wrap gap-1.5">
                                                    @foreach (var attr in v.Attributes)
                                                    {
                                                        <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md bg-white border border-slate-200 text-xs font-medium text-slate-600 tracking-wide shadow-sm">
                                                            <span class="text-slate-400">@attr.AttributeName:</span>
                                                            <span class="text-slate-900 text-xs">@attr.Value</span>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                        <td class="px-6 py-3 text-slate-900 text-right font-medium text-primary whitespace-nowrap">@v.Price.ToString("N0") ₫</td>
                                        <td class="px-6 py-3 text-slate-900 text-right">
                                            @if (v.Stock > 0)
                                            {
                                                <span class="px-2 py-0.5 bg-slate-100 rounded-md font-bold">@v.Stock</span>
                                            }
                                            else
                                            {
                                                <span class="px-2 py-0.5 bg-red-50 text-red-600 rounded-md font-bold">0</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="px-6 py-4 text-center text-slate-500">No variants. Product uses base configuration.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
        </div>

        <!-- Right Column -->
        <div class="lg:col-span-5 xl:col-span-4 flex flex-col gap-6">
            
            <!-- Commercial Details Card -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 p-6 relative overflow-hidden">
                <!-- Decorative element -->
                <div class="absolute -top-4 -right-4 size-24 bg-primary/5 rounded-full blur-xl pointer-events-none"></div>

                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-slate-400 text-[20px]">payments</span>
                    <h3 class="font-bold text-lg text-slate-900">Commercial Insights</h3>
                </div>
                
                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="p-4 bg-slate-50 border border-slate-100 rounded-xl">
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1.5 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">sell</span> Base Price</label>
                        <div class="text-xl font-black text-slate-900">@p.BasePrice.ToString("N0") <span class="text-sm font-semibold text-slate-500">₫</span></div>
                    </div>
                </div>

                <div class="h-px bg-slate-100 w-full mb-6"></div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="p-4 bg-white border border-slate-200 shadow-sm rounded-xl text-center">
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Total Inventory</label>
                        <div class="flex items-center justify-center gap-2">
                            <span class="text-2xl font-black text-slate-900">@p.Stock</span>
                            @if (p.Stock > 0)
                            {
                                <span class="material-symbols-outlined text-green-500">check_circle</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-red-500">error</span>
                            }
                        </div>
                    </div>
                    <div class="p-4 bg-gradient-to-br from-blue-50 to-white border border-blue-100 shadow-sm rounded-xl relative overflow-hidden text-center">
                        <div class="absolute -bottom-2 -right-2 text-blue-100 opacity-50"><span class="material-symbols-outlined text-6xl">account_balance_wallet</span></div>
                        <label class="block text-[10px] font-bold text-primary/70 uppercase tracking-widest mb-2 relative z-10">Platform Fee</label>
                        <div class="text-2xl font-black text-primary relative z-10">@p.CommissionRate.ToString("0.##")%</div>
                    </div>
                </div>
            </div>

            <!-- Description Card -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 p-6 flex flex-col">
                <div class="flex items-center gap-2 mb-4">
                    <span class="material-symbols-outlined text-slate-400 text-[20px]">description</span>
                    <h3 class="font-bold text-lg text-slate-900">About Product</h3>
                </div>
                <div class="prose prose-slate prose-sm max-w-none text-slate-600 bg-slate-50/50 p-4 rounded-xl border border-slate-100 max-h-[300px] overflow-y-auto custom-scrollbar">
                    @Html.Raw(p.Description)
                </div>
                
                <div class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-400 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[16px]">history</span>
                    <span>Created: <strong>@p.CreatedAt.ToString("MMM dd, yyyy")</strong></span>
                    <span class="mx-1">•</span>
                    <span>Updated: <strong>@(p.UpdatedAt?.ToString("MMM dd, yyyy") ?? "Never")</strong></span>
                </div>
            </div>

            <!-- Vendor Info Mini Card -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 p-5 group flex flex-col gap-4">
                <div class="flex items-center gap-4">
                    <div class="size-14 rounded-full bg-slate-100 flex-shrink-0 bg-cover bg-center border border-slate-200 group-hover:border-primary/50 transition-colors shadow-sm" style="background-image: url('@(p.Store?.AvatarUrl ?? "")');"></div>
                    <div class="flex-1 min-w-0">
                        <h4 class="text-base font-bold text-slate-900 truncate">@(p.Store?.Name ?? "N/A")</h4>
                        <p class="text-xs font-medium text-slate-500 mt-0.5">@(p.Store?.VendorId ?? "")</p>
                    </div>
                </div>
                <div class="bg-slate-50 rounded-lg p-3 border border-slate-100 text-xs flex justify-between items-center">
                    <span class="text-slate-500">Joined Date</span>
                    <span class="font-bold text-slate-700">@(p.Store != null ? p.Store.JoinedAt.ToString("MMM yyyy") : "N/A")</span>
                </div>
                <a href="#" class="w-full py-2 bg-slate-50 hover:bg-slate-100 text-slate-700 font-bold text-sm text-center border border-slate-200 transition-colors rounded-lg flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">store</span>
                    Visit Store Profile
                </a>
            </div>

        </div>
    </div>
</div>

<!-- Sticky Bottom Action Bar inside Main Container -->
<div class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur-sm border-t border-slate-200 p-4 shadow-[0_-10px_15px_-3px_rgba(0,0,0,0.05)] z-40 mx-[-24px] px-[24px]">
    <div class="max-w-[1440px] mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="w-full sm:w-auto">
            <button class="text-red-500 hover:text-red-700 text-sm font-bold hover:bg-red-50 px-3 py-2 rounded-lg flex items-center justify-center gap-1.5 transition-colors w-full sm:w-auto">
                <span class="material-symbols-outlined text-[18px]">delete</span>
                Delete Product
            </button>
        </div>
        
        <div class="flex flex-wrap items-center justify-end gap-3 w-full sm:w-auto">
            <button class="px-4 py-2.5 rounded-lg border border-slate-300 text-slate-700 font-bold text-sm hover:bg-slate-50 transition-colors flex items-center gap-2 shadow-sm bg-white">
                <span class="material-symbols-outlined text-[18px]">visibility_off</span>
                Hide / Suspend
            </button>
            
            <a href="#" class="px-4 py-2.5 rounded-lg border border-primary/20 text-primary font-bold text-sm hover:bg-primary/5 transition-colors flex items-center gap-2 shadow-sm bg-white">
                <span class="material-symbols-outlined text-[18px]">edit</span>
                Edit Spec
            </a>
            
            <div class="hidden sm:block w-px h-8 bg-slate-200 mx-1"></div>

            @if (p.Status == "Pending")
            {
                <button class="px-4 py-2.5 rounded-lg border border-red-200 text-red-600 font-bold text-sm hover:bg-red-50 transition-colors flex items-center gap-2 shadow-sm">
                    <span class="material-symbols-outlined text-[18px]">close</span>
                    Reject
                </button>
                <button class="px-6 py-2.5 rounded-lg bg-green-600 hover:bg-green-700 text-white font-bold text-sm shadow-md transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    Approve Request
                </button>
            }
            else
            {
                <button disabled title="Product is currently @p.Status" class="px-6 py-2.5 rounded-lg bg-slate-100 text-slate-400 font-bold text-sm shadow-inner transition-colors border border-slate-200 cursor-not-allowed flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">gpp_good</span>
                    Approved
                </button>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Very simple gallery script for prototype
            $('.aspect-square.cursor-pointer').not('.flex.items-center').click(function() {
                // Ignore the "Add photo" button
                var imgUrl = $(this).find('div').css('background-image');
                
                // Keep the border active state
                $('.aspect-square').removeClass('border-primary').addClass('border-slate-200');
                $(this).removeClass('border-slate-200').addClass('border-primary');

                // Update main image
                $('.aspect-\\[16\\/9\\] > div:first-child').css('background-image', imgUrl);
                
                // Add tiny bounce animation to main image wrapper
                const mainWrapper = $('.aspect-\\[16\\/9\\]');
                mainWrapper.addClass('scale-[0.98] opacity-90 transition-all duration-150');
                setTimeout(() => {
                    mainWrapper.removeClass('scale-[0.98] opacity-90');
                }, 150);
            });
        });
    </script>
}
