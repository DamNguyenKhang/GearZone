                        <button type="button" onclick="autoGenerateSlug('edit')" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-primary font-semibold hover:text-primary-dark transition-colors px-2 py-1 rounded-lg hover:bg-primary/5">Generate</button>
                    </div>
                    <p class="text-xs text-slate-400">Used for SEO-friendly URLs. Auto-generated from name.</p>
                </div>
                <!-- Logo Picker (Edit) -->
                <div class="space-y-1.5">
                    <label class="block text-sm font-semibold text-slate-700">Brand Logo</label>
                    <!-- Hidden real file input -->
                    <input type="file" id="edit-logo-file-input" asp-for="EditInput.LogoFile" accept="image/*" class="hidden" />
                    <!-- Drop zone / Preview area -->
                    <div id="edit-logo-dropzone"
                         class="relative group w-full h-40 rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50 hover:border-primary/50 hover:bg-primary/5 transition-all cursor-pointer overflow-hidden flex items-center justify-center"
                         onclick="document.getElementById('edit-logo-file-input').click()">
                        <!-- Placeholder state -->
                        <div id="edit-logo-placeholder" class="flex flex-col items-center gap-2 text-slate-400 pointer-events-none select-none">
                            <div class="w-12 h-12 rounded-xl bg-slate-200 group-hover:bg-primary/10 flex items-center justify-center transition-colors">
                                <span class="material-symbols-outlined text-[28px] text-slate-400 group-hover:text-primary transition-colors">add_photo_alternate</span>
                            </div>
                            <div class="text-center">
                                <p class="text-sm font-semibold text-slate-600">Click to upload image</p>
                                <p class="text-xs text-slate-400 mt-0.5">PNG, JPG, WEBP up to 5MB</p>
                            </div>
                        </div>
                        <!-- Preview state -->
                        <img id="edit-logo-preview" src="" alt="Logo preview"
                             class="hidden absolute inset-0 w-full h-full object-contain p-3" />
                        <!-- Clear button -->
                        <button type="button" id="edit-logo-clear"
                                class="hidden absolute top-2 right-2 w-7 h-7 rounded-full bg-red-500 hover:bg-red-600 text-white shadow-md flex items-center justify-center transition-all z-10"
                                onclick="clearLogo('edit'); event.stopPropagation();">
                            <span class="material-symbols-outlined text-[16px]">close</span>
                        </button>
                        <!-- Source badge -->
                        <span id="edit-logo-badge" class="hidden absolute bottom-2 left-2 text-[10px] font-bold px-2 py-0.5 rounded-full bg-slate-800/60 text-white backdrop-blur-sm"></span>
                    </div>
                    <!-- URL input -->
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-300">
                            <span class="material-symbols-outlined text-[18px]">link</span>
                        </span>
                        <input asp-for="EditInput.LogoUrl" id="edit-logo-url-input"
                               class="w-full rounded-xl border border-slate-200 bg-slate-50 pl-9 pr-4 py-2.5 text-sm focus:border-primary focus:ring-1 focus:ring-primary transition-all"
                               placeholder="Or paste image URL: https://..."
                               oninput="onLogoUrlInput('edit')" />
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" asp-for="EditInput.IsApproved" id="edit-approved-input" class="sr-only peer">
                        <div class="w-9 h-5 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-green-500"></div>
                    </label>
                    <span class="text-sm font-medium text-slate-700">Approved explicitly?</span>
                </div>
                
                <!-- Form Actions -->
                <div class="pt-4 flex items-center justify-end gap-3 border-t border-slate-100 mt-6 !mb-0">
                    <button type="button" class="px-5 py-2.5 rounded-xl border border-slate-200 bg-white text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors" onclick="closeEditModal()">Cancel</button>
                    <button type="submit" class="px-5 py-2.5 rounded-xl bg-primary text-sm font-bold text-white hover:bg-primary-dark transition-all shadow-md shadow-blue-500/20 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">save</span> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── Slug ──────────────────────────────────────────────────────────────────
        function toSlug(t) {
            return t.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
                .replace(/[đĐ]/g, 'd').replace(/[^a-z0-9\s-]/g, '')
                .replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
        }
        function autoGenerateSlug(mode) {
            const nameVal = document.getElementById(mode + '-name-input').value;
            document.getElementById(mode + '-slug-input').value = toSlug(nameVal);
        }

        // ── Logo picker helpers ───────────────────────────────────────────────────
        function showLogoPreview(mode, src, sourceLabel) {
            const preview   = document.getElementById(mode + '-logo-preview');
            const placeholder = document.getElementById(mode + '-logo-placeholder');
            const clearBtn  = document.getElementById(mode + '-logo-clear');
            const badge     = document.getElementById(mode + '-logo-badge');
            const dropzone  = document.getElementById(mode + '-logo-dropzone');

            preview.src = src;
            preview.classList.remove('hidden');
            placeholder.classList.add('hidden');
            clearBtn.classList.remove('hidden');
            badge.textContent = sourceLabel;
            badge.classList.remove('hidden');
            dropzone.classList.add('border-primary/40', 'bg-primary/5');
            dropzone.classList.remove('border-slate-200', 'bg-slate-50');
        }

        function clearLogo(mode) {
            const preview   = document.getElementById(mode + '-logo-preview');
            const placeholder = document.getElementById(mode + '-logo-placeholder');
            const clearBtn  = document.getElementById(mode + '-logo-clear');
            const badge     = document.getElementById(mode + '-logo-badge');
            const dropzone  = document.getElementById(mode + '-logo-dropzone');
            const fileInput = document.getElementById(mode + '-logo-file-input');
            const urlInput  = document.getElementById(mode + '-logo-url-input');

            preview.src = '';
            preview.classList.add('hidden');
            placeholder.classList.remove('hidden');
            clearBtn.classList.add('hidden');
            badge.classList.add('hidden');
            dropzone.classList.remove('border-primary/40', 'bg-primary/5');
            dropzone.classList.add('border-slate-200', 'bg-slate-50');
            fileInput.value = '';
            if (urlInput) urlInput.value = '';
        }

        // Wire up file inputs
        ['create', 'edit'].forEach(mode => {
            const fileInput = document.getElementById(mode + '-logo-file-input');
            fileInput.addEventListener('change', function () {
                const file = this.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = e => {
                    // Clear URL input when file chosen
                    const urlInput = document.getElementById(mode + '-logo-url-input');
                    if (urlInput) urlInput.value = '';
                    showLogoPreview(mode, e.target.result, '📁 Local file');
                };
                reader.readAsDataURL(file);
            });
        });

        // URL input debounce
        let urlDebounce = {};
        function onLogoUrlInput(mode) {
            clearTimeout(urlDebounce[mode]);
            urlDebounce[mode] = setTimeout(() => {
                const urlInput = document.getElementById(mode + '-logo-url-input');
                const val = urlInput.value.trim();
                if (!val) { clearLogo(mode); return; }
                // Reset file input when URL typed
                document.getElementById(mode + '-logo-file-input').value = '';
                showLogoPreview(mode, val, '🔗 URL');
            }, 400);
        }

        // ── Modals ────────────────────────────────────────────────────────────────
        function openCreateModal() {
            document.getElementById('create-modal').classList.remove('hidden');
        }
        function closeCreateModal() {
            document.getElementById('create-modal').classList.add('hidden');
            clearLogo('create');
            document.getElementById('create-name-input').value = '';
            document.getElementById('create-slug-input').value = '';
        }

        function openEditModal(id, name, slug, logoUrl, isApproved) {
            document.getElementById('edit-id-input').value = id;
            document.getElementById('edit-name-input').value = name;
            document.getElementById('edit-slug-input').value = slug;
            document.getElementById('edit-approved-input').checked = isApproved;
            // Set logo preview if existing URL
            clearLogo('edit');
            if (logoUrl) {
                document.getElementById('edit-logo-url-input').value = logoUrl;
                showLogoPreview('edit', logoUrl, '🔗 Current logo');
            }
            document.getElementById('edit-modal').classList.remove('hidden');
        }
        function closeEditModal() {
            document.getElementById('edit-modal').classList.add('hidden');
            clearLogo('edit');
        }

        // Close modals on Escape key
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                closeCreateModal();
                closeEditModal();
            }
        });
    </script>
}
