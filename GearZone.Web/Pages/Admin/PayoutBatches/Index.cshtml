@page
@model GearZone.Web.Pages.Admin.PayoutBatches.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Payout Batches";
    ViewData["PageHeader"] = "Payout Batches";
    ViewData["ActivePage"] = "PayoutBatches";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Payout Batches" };
}

<div class="flex flex-col gap-6">

    <!-- Flash messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
            <span class="material-symbols-outlined text-green-600 text-[20px]">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center gap-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
            <span class="material-symbols-outlined text-red-600 text-[20px]">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- Filter Bar -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
        <form method="get" id="filter-form" class="flex flex-col">
            <input type="hidden" name="Query.PageNumber" id="page-number-input" value="@Model.Query.PageNumber" />

            <!-- Primary toolbar -->
            <div class="flex flex-col lg:flex-row gap-3 p-4 items-start lg:items-center">
                <!-- Search -->
                <div class="relative flex-1 w-full">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400 pointer-events-none">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                    </span>
                    <input asp-for="Query.SearchTerm"
                           class="form-input w-full rounded-lg border-slate-200 bg-slate-50 pl-10 pr-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-primary focus:ring-primary transition-colors"
                           placeholder="Search by batch code…"
                           type="text" autocomplete="off" />
                </div>

                <!-- Status filter -->
                <div class="shrink-0 w-full lg:w-52">
                    <select asp-for="Query.Status"
                            class="form-select w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 text-sm text-slate-900 focus:border-primary focus:ring-primary shadow-sm"
                            onchange="this.form.submit()">
                        <option value="">All Statuses</option>
                        @foreach (var s in Enum.GetValues<GearZone.Domain.Enums.PayoutBatchStatus>())
                        {
                            <option value="@s" selected="@(Model.Query.Status == s)">@s</option>
                        }
                    </select>
                </div>

                <!-- Actions -->
                <div class="flex items-center gap-2 shrink-0 w-full lg:w-auto">
                    <button type="submit"
                            class="flex-1 lg:flex-none flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-4 py-2.5 rounded-lg text-sm font-medium shadow-sm transition-all">
                        <span class="material-symbols-outlined text-[18px]">search</span>
                        <span>Search</span>
                    </button>
                    <a asp-page="/Admin/PayoutBatches/Index"
                       class="flex items-center justify-center p-2.5 rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-colors bg-white shadow-sm"
                       title="Reset filters">
                        <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                    </a>
                </div>
            </div>
        </form>
    </div>

    <!-- Batches Table -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden flex flex-col">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50">
                        <th class="py-4 pl-6 pr-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Batch Code</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Period</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 text-right">Gross / Net</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 text-center">Stores</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 text-center">OK / Failed</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500 text-center">Status</th>
                        <th class="py-4 px-3 text-xs font-semibold uppercase tracking-wider text-slate-500">Created</th>
                        <th class="py-4 pr-6 pl-3 text-xs font-semibold uppercase tracking-wider text-slate-500 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (Model.Batches.Items.Any())
                    {
                        @foreach (var b in Model.Batches.Items)
                        {
                            <tr class="group hover:bg-slate-50 transition-all cursor-default data-row" data-href="/Admin/PayoutBatches/Details/@b.Id">
                                <td class="py-4 pl-6 pr-3 align-middle font-mono text-sm font-semibold text-slate-900">@b.BatchCode</td>
                                <td class="py-4 px-3 align-middle whitespace-nowrap">
                                    <span class="text-xs text-slate-600">@b.PeriodStart.ToString("dd/MM/yy") – @b.PeriodEnd.ToString("dd/MM/yy")</span>
                                </td>
                                <td class="py-4 px-3 text-right align-middle whitespace-nowrap">
                                    <div class="text-sm font-semibold text-slate-900">@b.TotalGrossAmount.ToString("N0") ₫</div>
                                    <div class="text-xs text-green-600 font-medium mt-0.5">@b.TotalNetAmount.ToString("N0") ₫</div>
                                </td>
                                <td class="py-4 px-3 text-center text-sm text-slate-700 align-middle">@b.TotalStores</td>
                                <td class="py-4 px-3 text-center align-middle whitespace-nowrap">
                                    <span class="text-green-600 font-semibold">@b.SuccessCount</span>
                                    <span class="text-slate-300 mx-1">/</span>
                                    <span class="text-red-500 font-semibold">@b.FailedCount</span>
                                </td>
                                <td class="py-4 px-3 text-center align-middle">
                                    @{
                                        var (bg, text) = b.Status switch
                                        {
                                            GearZone.Domain.Enums.PayoutBatchStatus.Draft => ("bg-slate-50 text-slate-600 ring-slate-500/20", "Draft"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.PendingApproval => ("bg-amber-50 text-amber-700 ring-amber-600/20", "Pending Approval"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.Approved => ("bg-blue-50 text-blue-700 ring-blue-600/20", "Approved"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.Processing => ("bg-violet-50 text-violet-700 ring-violet-600/20", "Processing"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.Completed => ("bg-green-50 text-green-700 ring-green-600/20", "Completed"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.PartialFailed => ("bg-orange-50 text-orange-700 ring-orange-600/20", "Partial Failed"),
                                            GearZone.Domain.Enums.PayoutBatchStatus.OnHold => ("bg-red-50 text-red-700 ring-red-600/20", "On Hold"),
                                            _ => ("bg-slate-50 text-slate-600 ring-slate-500/20", b.Status.ToString())
                                        };
                                    }
                                    <span class="inline-flex items-center gap-1.5 rounded-full @bg px-2.5 py-1 text-xs font-semibold ring-1 ring-inset whitespace-nowrap">@text</span>
                                </td>
                                <td class="py-4 px-3 align-middle whitespace-nowrap text-sm text-slate-500">@b.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td class="py-4 pr-6 pl-3 align-middle text-right whitespace-nowrap">
                                    <div class="flex items-center justify-end gap-1.5">
                                        <a asp-page="/Admin/PayoutBatches/Details" asp-route-id="@b.Id"
                                           class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 text-xs font-medium transition-colors"
                                           onclick="event.stopPropagation()">
                                            <span class="material-symbols-outlined text-[14px]">open_in_new</span> Details
                                        </a>
                                        @if (b.Status == GearZone.Domain.Enums.PayoutBatchStatus.PendingApproval)
                                        {
                                            <button type="button"
                                                    onclick="openApproveModal('@b.Id'); event.stopPropagation()"
                                                    class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-blue-50 border border-blue-200 text-blue-700 hover:bg-blue-100 text-xs font-medium transition-colors">
                                                <span class="material-symbols-outlined text-[14px]">verified</span> Approve
                                            </button>
                                        }
                                        @if (b.Status == GearZone.Domain.Enums.PayoutBatchStatus.Approved)
                                        {
                                            <button type="button"
                                                    onclick="openProcessModal('@b.Id', '@b.BatchCode'); event.stopPropagation()"
                                                    class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-violet-50 border border-violet-200 text-violet-700 hover:bg-violet-100 text-xs font-medium transition-colors">
                                                <span class="material-symbols-outlined text-[14px]">play_arrow</span> Process
                                            </button>
                                        }
                                        @if (b.Status != GearZone.Domain.Enums.PayoutBatchStatus.Completed &&
                                             b.Status != GearZone.Domain.Enums.PayoutBatchStatus.OnHold)
                                        {
                                            <button type="button"
                                                    onclick="openHoldModal('@b.Id'); event.stopPropagation()"
                                                    class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg bg-red-50 border border-red-200 text-red-600 hover:bg-red-100 text-xs font-medium transition-colors">
                                                <span class="material-symbols-outlined text-[14px]">pause</span> Hold
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="py-12 text-center text-slate-500">
                                <div class="flex flex-col items-center justify-center space-y-3">
                                    <div class="size-16 rounded-full bg-slate-50 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-4xl text-slate-300">account_balance_wallet</span>
                                    </div>
                                    <p class="text-sm font-medium">No payout batches found</p>
                                    <p class="text-xs text-slate-400">Try adjusting your filters</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.Batches.TotalPages > 1)
        {
            <div class="flex items-center justify-between border-t border-slate-100 px-6 py-4">
                <span class="text-sm text-slate-500">
                    Showing @((Model.Batches.PageNumber - 1) * Model.Batches.PageSize + 1)–@(Math.Min(Model.Batches.PageNumber * Model.Batches.PageSize, Model.Batches.TotalCount)) of @Model.Batches.TotalCount.ToString("N0") batches
                </span>
                <nav class="flex items-center gap-1.5">
                    @if (Model.Batches.PageNumber > 1)
                    {
                        <button type="button" onclick="gotoPage(@(Model.Batches.PageNumber - 1))" class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm">
                            <span class="material-symbols-outlined text-lg leading-none">chevron_left</span>
                        </button>
                    }
                    <span class="px-3 py-1.5 text-sm font-medium text-slate-700">@Model.Batches.PageNumber / @Model.Batches.TotalPages</span>
                    @if (Model.Batches.PageNumber < Model.Batches.TotalPages)
                    {
                        <button type="button" onclick="gotoPage(@(Model.Batches.PageNumber + 1))" class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:bg-white hover:text-primary hover:border-primary transition-all shadow-sm">
                            <span class="material-symbols-outlined text-lg leading-none">chevron_right</span>
                        </button>
                    }
                </nav>
            </div>
        }
    </div>
</div>

<!-- Approve Modal -->
<div id="approve-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-2">Approve Batch</h3>
        <p class="text-sm text-slate-500 mb-5">Are you sure you want to approve this payout batch? This action cannot be undone.</p>
        <form method="post" id="approve-form">
            <input type="hidden" name="id" id="approve-batch-id" />
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeModal('approve-modal')" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" asp-page-handler="ApproveBatch" class="px-5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold shadow-sm transition-colors">Approve</button>
            </div>
        </form>
    </div>
</div>

<!-- Hold Modal -->
<div id="hold-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-2">Hold Batch</h3>
        <p class="text-sm text-slate-500 mb-3">Please provide a reason for placing this batch on hold.</p>
        <form method="post" id="hold-form">
            <input type="hidden" name="id" id="hold-batch-id" />
            <textarea name="reason" rows="3" class="form-input w-full rounded-lg border-slate-200 py-2 px-3 text-sm mb-4 focus:ring-primary focus:border-primary" placeholder="Hold reason…" required></textarea>
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeModal('hold-modal')" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" asp-page-handler="HoldBatch" class="px-5 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-sm font-semibold shadow-sm transition-colors">Confirm Hold</button>
            </div>
        </form>
    </div>
</div>

<!-- Process Modal -->
<div id="process-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
        <h3 class="text-lg font-bold text-slate-900 mb-2">Process Batch</h3>
        <p class="text-sm text-slate-500 mb-5">This will initiate all pending payout transactions in this batch via PayOS. Continue?</p>
        <form method="post" id="process-form">
            <input type="hidden" name="id" id="process-batch-id" />
            <input type="hidden" name="batchCode" id="process-batch-code" />
            <div class="flex gap-3 justify-end">
                <button type="button" onclick="closeModal('process-modal')" class="px-4 py-2 rounded-lg border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors">Cancel</button>
                <button type="submit" asp-page-handler="ProcessBatch" class="px-5 py-2 rounded-lg bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold shadow-sm transition-colors">Process</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function gotoPage(page) {
            document.getElementById('page-number-input').value = page;
            document.getElementById('filter-form').submit();
        }

        function openApproveModal(id) {
            document.getElementById('approve-batch-id').value = id;
            document.getElementById('approve-modal').classList.remove('hidden');
        }

        function openHoldModal(id) {
            document.getElementById('hold-batch-id').value = id;
            document.getElementById('hold-modal').classList.remove('hidden');
        }

        function openProcessModal(id, code) {
            document.getElementById('process-batch-id').value = id;
            document.getElementById('process-batch-code').value = code;
            document.getElementById('process-modal').classList.remove('hidden');
        }

        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }

        // Row click navigate
        document.querySelectorAll('.data-row').forEach(row => {
            row.addEventListener('click', function (e) {
                if (!e.target.closest('a') && !e.target.closest('button')) {
                    window.location.href = this.dataset.href;
                }
            });
        });
    </script>
}
