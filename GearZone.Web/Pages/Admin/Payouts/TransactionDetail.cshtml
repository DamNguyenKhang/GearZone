@page "/admin/payouts/transactions/{id?}"
@model GearZone.Web.Pages.Admin.Payouts.TransactionDetailModel
@{
    ViewData["Title"] = "Transaction Detail";
    ViewData["PageHeader"] = "Payout Transaction Detail";
    ViewData["ActivePage"] = "Payouts";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Finance", "Payouts", Model.Transaction.TransactionCode };
    Layout = "_AdminLayout";
}

<div class="flex flex-col gap-6">

    <!-- Header Block -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div class="flex flex-col gap-1">
            <div class="flex items-center gap-3 mb-1">
                <a asp-page="/Admin/PayoutBatches/Details" asp-route-id="@Model.Transaction.PayoutBatchId" class="flex items-center gap-1 text-slate-500 hover:text-slate-700 transition-colors py-1">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    <span class="text-sm font-medium">Back to Payout Batch</span>
                </a>
            </div>
            <h1 class="text-[22px] font-bold text-slate-900 leading-tight">Payout Transaction Detail</h1>
            <p class="font-mono text-[13px] text-slate-500">@Model.Transaction.TransactionCode · @Model.Transaction.BatchCode · Created @Model.Transaction.CreatedAt.ToString("MMM dd, yyyy")</p>
            <div class="flex flex-wrap gap-2 mt-3">
                @{
                    var (tbg, ttx, tdt) = Model.Transaction.Status switch
                    {
                        GearZone.Domain.Enums.PayoutTransactionStatus.Queued => ("bg-slate-50 text-slate-600 ring-slate-500/20", "Queued", "bg-slate-400"),
                        GearZone.Domain.Enums.PayoutTransactionStatus.Processing => ("bg-blue-50 text-blue-700 ring-blue-600/20", "Processing", "bg-blue-500"),
                        GearZone.Domain.Enums.PayoutTransactionStatus.Success => ("bg-green-50 text-green-700 ring-green-600/20", "Success", "bg-green-500"),
                        GearZone.Domain.Enums.PayoutTransactionStatus.Failed => ("bg-red-50 text-red-700 ring-red-600/20", "Failed", "bg-red-500"),
                        GearZone.Domain.Enums.PayoutTransactionStatus.ManualRequired => ("bg-orange-50 text-orange-700 ring-orange-600/20", "Manual Req", "bg-orange-500"),
                        GearZone.Domain.Enums.PayoutTransactionStatus.Excluded => ("bg-slate-100 text-slate-500 ring-slate-400/20", "Excluded", "bg-slate-400"),
                        _ => ("bg-slate-50 text-slate-600 ring-slate-500/20", Model.Transaction.Status.ToString(), "bg-slate-400")
                    };
                }
                <span class="flex items-center gap-1.5 px-3 py-1 rounded-full @tbg text-xs font-bold border">
                    <span class="w-1.5 h-1.5 rounded-full @tdt"></span> @ttx
                </span>
                <span class="flex items-center gap-1 px-3 py-1 rounded-full bg-green-50 text-green-700 text-xs font-bold border border-green-200">
                    <span class="material-symbols-outlined text-[14px]">shield_with_heart</span> Bank Snapshot
                </span>
            </div>
        </div>
        <div class="flex items-center gap-3 h-fit">
            @if (Model.Transaction.Status == GearZone.Domain.Enums.PayoutTransactionStatus.Failed || Model.Transaction.Status == GearZone.Domain.Enums.PayoutTransactionStatus.ManualRequired)
            {
                <button type="button" class="flex items-center justify-center gap-2 bg-primary text-white px-4 py-2 rounded-lg font-medium hover:bg-primary-dark transition-all shadow-sm text-sm">
                    <span class="material-symbols-outlined text-[18px]">refresh</span> Retry Disbursement
                </button>
            }
        </div>
    </div>

    <!-- Payout Calculation Card -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 border-t-4 border-t-primary overflow-hidden">
        <div class="px-6 py-4 flex justify-between items-center border-b border-slate-100">
            <h2 class="text-base font-bold text-slate-900">Payout Calculation</h2>
            <div class="flex items-center gap-2 text-[13px] text-slate-500">
                <span class="material-symbols-outlined text-[16px]">calendar_today</span>
                Snapshotted on: @Model.Transaction.CreatedAt.ToString("MMM dd, yyyy HH:mm")
            </div>
        </div>
        <div class="p-6">
            <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
                <!-- Gross -->
                <div class="flex-1 w-full p-5 rounded-lg bg-sky-50 border border-sky-200">
                    <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-2">Gross Revenue</p>
                    <div class="text-[28px] font-bold text-slate-900 leading-tight">@Model.Transaction.GrossAmount.ToString("N0") ₫</div>
                    <div class="mt-2 space-y-0.5">
                        <p class="text-[13px] text-slate-500">@Model.Transaction.OrderCount orders in this period</p>
                    </div>
                </div>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 text-slate-400 font-bold text-xlshrink-0">−</div>
                <!-- Commission -->
                <div class="flex-1 w-full p-5 rounded-lg bg-blue-50 border border-blue-200">
                    <p class="text-[11px] font-bold text-teal-600 uppercase tracking-wider mb-2">Platform Commission</p>
                    <div class="text-[24px] font-bold text-teal-600 leading-tight">@Model.Transaction.CommissionAmount.ToString("N0") ₫</div>
                    <div class="mt-2 space-y-0.5">
                        <p class="text-[13px] text-slate-500">Rate: @Model.Transaction.StoreCommissionRate%</p>
                    </div>
                </div>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 text-slate-400 font-bold text-xl shrink-0">=</div>
                <!-- Net -->
                <div class="flex-1 w-full p-5 rounded-lg bg-emerald-50 border-2 border-emerald-300 shadow-lg shadow-emerald-500/15">
                    <p class="text-[11px] font-bold text-green-600 uppercase tracking-wider mb-2">Net Payout to Store</p>
                    <div class="text-[36px] font-bold text-green-600 leading-tight">@Model.Transaction.NetAmount.ToString("N0") ₫</div>
                    <div class="mt-2 space-y-0.5">
                        <p class="text-[13px] text-slate-500">Transfer amount via PayOS</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- Left Column: Store/Bank Info & Previous Payouts & Related -->
        <div class="lg:col-span-7 flex flex-col gap-6">
            <!-- Store & Bank Info -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 p-6">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-base font-bold text-slate-900">Store &amp; Bank Info</h3>
                    <button class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                        <span class="material-symbols-outlined text-[16px]">edit</span> Edit Bank
                    </button>
                </div>

                <!-- Store Details -->
                <div class="flex items-start gap-4 mb-8">
                    <div class="w-11 h-11 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold overflow-hidden">
                        <span class="text-lg">@Model.Transaction.StoreName[0]</span>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-2">
                            <h4 class="text-base font-bold text-slate-900">@Model.Transaction.StoreName</h4>
                            <span class="px-2 py-0.5 rounded bg-green-50 text-green-700 text-[10px] font-bold border border-green-200 uppercase">Active</span>
                        </div>
                        <p class="font-mono text-[12px] text-slate-500">store-id: @Model.Transaction.StoreId.ToString().Substring(0,8)...</p>
                        <a class="text-[12px] text-primary font-medium hover:underline mt-1 block" asp-page="/Admin/Stores/Details" asp-route-id="@Model.Transaction.StoreId">View Store →</a>
                    </div>
                </div>

                <div class="space-y-4 mb-8">
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Owner</span>
                        <span class="text-slate-900">@Model.Transaction.StoreOwnerName</span>
                    </div>
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Email</span>
                        <span class="text-slate-900">@Model.Transaction.StoreEmail</span>
                    </div>
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Phone</span>
                        <span class="text-slate-900">@Model.Transaction.StorePhone</span>
                    </div>
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Commission</span>
                        <span class="text-slate-900">@Model.Transaction.StoreCommissionRate% <span class="text-slate-400 italic">(at batch creation)</span></span>
                    </div>
                </div>

                <!-- Bank Info Divider -->
                <div class="flex items-center gap-4 mb-6">
                    <div class="flex-1 h-px bg-slate-100"></div>
                    <span class="text-[11px] font-bold text-slate-400 tracking-widest uppercase">Bank Account (Snapshot)</span>
                    <div class="flex-1 h-px bg-slate-100"></div>
                </div>

                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center gap-3">
                        <span class="text-lg font-bold text-slate-900">@Model.Transaction.BankName</span>
                        <span class="flex items-center gap-1 px-2 py-0.5 rounded bg-green-50 text-green-700 text-[11px] font-bold border border-green-200">
                            <span class="material-symbols-outlined text-[14px]">verified</span> Recorded
                        </span>
                    </div>
                </div>

                <div class="space-y-4 mb-6">
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Account No.</span>
                        <div class="flex-1 flex items-center justify-between">
                            <span class="font-mono text-slate-900">@Model.Transaction.BankAccountNumber</span>
                        </div>
                    </div>
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Account Name</span>
                        <span class="font-bold text-slate-900 uppercase">@Model.Transaction.BankAccountName</span>
                    </div>
                    <div class="flex text-[14px]">
                        <span class="w-[130px] text-slate-500">Bank Name</span>
                        <span class="text-slate-900">@Model.Transaction.BankName</span>
                    </div>
                </div>

                <div class="p-3 bg-slate-50 border border-slate-200 rounded-lg flex gap-3">
                    <span class="material-symbols-outlined text-slate-400 text-[20px] shrink-0">info</span>
                    <p class="text-[12px] italic text-slate-500 leading-relaxed">
                        Bank details are snapshotted at batch creation. Editing here updates Store record but does <span class="font-bold">NOT</span> affect this batch — applies from next batch only.
                    </p>
                </div>
            </div>

            <!-- Previous Payouts -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
                <div class="p-6 pb-4 flex justify-between items-center">
                    <h3 class="text-base font-bold text-slate-900 leading-tight">Previous Payouts<br/><span class="text-xs text-slate-400 font-medium">TechStore Official</span></h3>
                    <a class="text-sm font-bold text-primary hover:underline shrink-0" href="#">View All →</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-[13px]">
                        <thead>
                            <tr class="bg-slate-50 text-slate-500 text-[10px] uppercase font-bold border-y border-slate-100">
                                <th class="px-6 py-2 text-left">Batch</th>
                                <th class="px-6 py-2 text-right">Net Amount</th>
                                <th class="px-6 py-2 text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            <tr class="bg-amber-50">
                                <td class="px-6 py-3">
                                    <p class="font-bold text-slate-700">W44</p>
                                    <p class="text-[11px] text-slate-400">Oct 28–Nov 03</p>
                                </td>
                                <td class="px-6 py-3 text-right font-medium">₫12,993,000</td>
                                <td class="px-6 py-3">
                                    <div class="flex justify-center">
                                        <span class="w-2 h-2 rounded-full bg-amber-500" title="Queued"></span>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-6 py-3">
                                    <p class="font-bold text-slate-700">W43</p>
                                    <p class="text-[11px] text-slate-400">Oct 21–27</p>
                                </td>
                                <td class="px-6 py-3 text-right font-medium">₫10,431,000</td>
                                <td class="px-6 py-3">
                                    <div class="flex justify-center items-center flex-col gap-0.5">
                                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                        <span class="text-[10px] text-slate-400">Oct 28</span>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-6 py-3">
                                    <p class="font-bold text-slate-700">W42</p>
                                    <p class="text-[11px] text-slate-400">Oct 14–20</p>
                                </td>
                                <td class="px-6 py-3 text-right font-medium">₫8,326,500</td>
                                <td class="px-6 py-3 text-center">
                                    <div class="flex justify-center items-center flex-col gap-0.5">
                                        <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                        <span class="text-[10px] text-slate-400">Oct 21</span>
                                    </div>
                                </td>
                            </tr>
                            <tr class="bg-red-50">
                                <td class="px-6 py-3">
                                    <p class="font-bold text-slate-700">W41</p>
                                    <p class="text-[11px] text-slate-400">Oct 07–13</p>
                                </td>
                                <td class="px-6 py-3 text-right font-medium line-through text-slate-400">₫8,967,000</td>
                                <td class="px-6 py-3">
                                    <div class="flex justify-center items-center flex-col gap-0.5">
                                        <span class="w-2 h-2 rounded-full bg-red-600"></span>
                                        <span class="text-[10px] text-red-600 italic">Oct 14</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="px-6 py-3 bg-slate-50 border-t border-slate-100 flex justify-between items-center">
                    <span class="text-xs text-slate-500 font-medium italic">Invalid bank account (W41)</span>
                    <div class="text-indigo-600 font-bold text-sm">
                        Total paid: ₫31,727,500
                    </div>
                </div>
            </div>
            
            <!-- Cards (Related Records) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <!-- Batch Card -->
                <div class="bg-white rounded-xl shadow-card border border-slate-100 p-5 flex flex-col">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center">
                            <span class="material-symbols-outlined text-[24px]">package_2</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-primary">BATCH-2025-W44</p>
                            <span class="flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 text-[10px] font-bold border border-amber-200">
                                Pending Approval
                            </span>
                        </div>
                    </div>
                    <div class="space-y-1 mb-6 flex-1">
                        <p class="text-[13px] text-slate-500">Period: Oct 28–Nov 03 · 18 stores</p>
                        <p class="text-[13px] text-slate-500">Total: ₫124,500,000</p>
                    </div>
                    <button type="button" class="w-full h-[36px] rounded-lg border border-amber-500 text-amber-600 text-[13px] font-bold hover:bg-amber-50 transition-colors">
                        View Batch Detail →
                    </button>
                </div>
                <!-- 47 Orders Summary -->
                <div class="bg-white rounded-xl shadow-card border border-slate-100 p-5 flex flex-col">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 rounded-lg bg-green-50 text-green-600 flex items-center justify-center">
                            <span class="material-symbols-outlined text-[24px]">shopping_bag</span>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-slate-900">47 Completed Orders</p>
                            <p class="text-[10px] text-slate-400 font-medium">Period: Oct 28–Nov 03</p>
                        </div>
                    </div>
                    <div class="space-y-1 mb-6 flex-1">
                        <p class="text-[13px] text-slate-800 font-medium">Total value: ₫14,200,000</p>
                        <p class="text-[13px] text-teal-600 font-bold">Commission: ₫1,207,000</p>
                    </div>
                    <button type="button" onclick="document.getElementById('orders-section').scrollIntoView({behavior: 'smooth'})" class="w-full h-[36px] rounded-lg border border-slate-300 text-slate-600 text-[13px] font-bold hover:bg-slate-50 transition-colors">
                        View Orders Table
                    </button>
                </div>
            </div>

        </div>

        <!-- Right Column: Transfer Status & Audit Trail -->
        <div class="lg:col-span-5 flex flex-col gap-6">
            <!-- PayOS Transfer Status -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
                <div class="px-6 py-4 border-b border-slate-100">
                    <h3 class="text-base font-bold text-slate-900">PayOS Transfer Status</h3>
                </div>
                <!-- Preview Tabs -->
                <div class="flex border-b border-slate-100 bg-slate-50/50">
                    <button class="flex-1 py-3 text-[12px] font-bold text-amber-600 border-b-2 border-amber-500 bg-white">
                        ⏳ Queued
                    </button>
                    <button class="flex-1 py-3 text-[12px] font-bold text-slate-400 hover:text-green-600 transition-colors">
                        ✅ Success
                    </button>
                    <button class="flex-1 py-3 text-[12px] font-bold text-slate-400 hover:text-red-600 transition-colors">
                        ❌ Failed
                    </button>
                </div>
                <!-- QUEUED STATE -->
                <div class="p-8 text-center">
                    <div class="mb-4 inline-flex items-center justify-center w-16 h-16 rounded-full bg-amber-50 text-amber-600 border border-amber-100">
                        <span class="material-symbols-outlined text-[48px]">schedule</span>
                    </div>
                    <h4 class="text-[16px] font-bold text-amber-600 mb-2">Awaiting Batch Approval</h4>
                    <p class="text-[13px] text-slate-500 mb-6 max-w-[280px] mx-auto">
                        Transfer will be initiated once Admin approves batch <span class="font-bold text-slate-700">BATCH-2025-W44</span>
                    </p>
                    <div class="h-px bg-slate-100 my-6"></div>
                    <div class="flex items-center justify-between text-sm mb-6">
                        <span class="text-slate-500 font-medium">Batch Status:</span>
                        <span class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-bold border border-amber-200">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Pending Approval
                        </span>
                    </div>
                    <button class="w-full py-2.5 bg-amber-500 text-white rounded-lg font-bold text-sm hover:bg-amber-600 transition-colors">
                        Go to Batch Detail →
                    </button>
                </div>
            </div>

            <!-- Audit Trail -->
            <div class="bg-white rounded-xl shadow-card border border-slate-100 p-6 flex-1">
                <div class="mb-6">
                    <h3 class="text-base font-bold text-slate-900">Audit Trail</h3>
                    <p class="text-[13px] text-slate-500">Every state change for this transaction</p>
                </div>
                <div class="relative pl-8 space-y-8">
                    <!-- Vertical Line -->
                    <div class="absolute left-1.5 top-2 bottom-0 w-[2px] bg-slate-200"></div>
                    <!-- Entry 1 (Current) -->
                    <div class="relative">
                        <div class="absolute -left-[31px] top-1 w-[10px] h-[10px] rounded-full bg-amber-500 border-4 border-amber-200 ring-4 ring-amber-50 animate-pulse"></div>
                        <div class="flex flex-col md:items-start gap-4">
                            <div class="w-full p-4 rounded-lg bg-amber-50 border-l-[3px] border-amber-400 border border-slate-100">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-bold text-slate-900">Awaiting approval</span>
                                        <span class="px-2 py-0.5 rounded bg-slate-200 text-slate-600 text-[10px] font-bold uppercase tracking-wider">⚙ System</span>
                                    </div>
                                    <span class="text-[12px] text-slate-400 font-mono">Nov 04, 00:01:06 AM</span>
                                </div>
                                <p class="text-sm text-slate-700">Status set to Queued — awaiting batch approval</p>
                            </div>
                        </div>
                    </div>
                    <!-- Entry 2 -->
                    <div class="relative">
                        <div class="absolute -left-[31px] top-1 w-[10px] h-[10px] rounded-full bg-primary ring-4 ring-white"></div>
                        <div class="flex flex-col md:items-start gap-4">
                            <div class="w-full p-4 rounded-lg bg-slate-50 border border-slate-100">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-bold text-slate-900">Bank details snapshotted</span>
                                        <span class="px-2 py-0.5 rounded bg-slate-200 text-slate-600 text-[10px] font-bold uppercase tracking-wider">⚙ System</span>
                                    </div>
                                    <span class="text-[12px] text-slate-400 font-mono">Nov 04, 00:01:05 AM</span>
                                </div>
                                <p class="text-sm text-slate-700 mb-1">Vietcombank · ****4521 · NGUYEN VAN AN</p>
                                <p class="text-xs text-green-600 font-bold flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[14px]">check_circle</span> Verified: Yes
                                </p>
                            </div>
                        </div>
                    </div>
                    <!-- Entry 3 -->
                    <div class="relative">
                        <div class="absolute -left-[31px] top-1 w-[10px] h-[10px] rounded-full bg-slate-400 ring-4 ring-white"></div>
                        <div class="flex flex-col md:items-start gap-4">
                            <div class="w-full p-4 rounded-lg bg-slate-50 border border-slate-100">
                                <div class="flex items-center justify-between mb-2">
                                    <div class="flex items-center gap-2">
                                        <span class="text-sm font-bold text-slate-900">Transaction created</span>
                                        <span class="px-2 py-0.5 rounded bg-slate-200 text-slate-600 text-[10px] font-bold uppercase tracking-wider">⚙ System</span>
                                    </div>
                                    <span class="text-[12px] text-slate-400 font-mono">Nov 04, 00:01:05 AM</span>
                                </div>
                                <p class="text-sm text-slate-700 mb-1 font-mono">PTX-2025-W44-001 created</p>
                                <p class="text-xs text-slate-500">
                                    Calculated: 47 orders · ₫14,200,000 gross · ₫1,207,000 commission · ₫12,993,000 net
                                </p>
                            </div>
                        </div>
                    </div>
                    <!-- Future Steps Styling -->
                    <div class="absolute left-[5px] top-[calc(100%-80px)] h-32 w-[2px] bg-slate-200 -z-10 bg-[length:100%_10px] bg-[linear-gradient(to_bottom,currentColor_50%,transparent_50%)] text-slate-300 border-none"></div>
                    <!-- Future Step 1 -->
                    <div class="relative opacity-50 italic">
                        <div class="absolute -left-[31px] top-1 w-[10px] h-[10px] rounded-full bg-slate-50 border-2 border-slate-300 ring-4 ring-white"></div>
                        <div class="flex flex-col md:items-start gap-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-sm font-bold text-slate-600">Admin approves BATCH-2025-W44</span>
                                </div>
