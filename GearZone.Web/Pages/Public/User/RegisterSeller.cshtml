@page "{step:int?}"
@model GearZone.Web.Pages.Public.User.RegisterSellerModel
@{
    ViewData["Title"] = "Đăng Ký Bán Hàng - GearZone";
    Layout = "_Layout";
    var step = Model.CurrentStep;
    if (ViewContext.HttpContext.Request.Query.ContainsKey("step"))
    {
        int.TryParse(ViewContext.HttpContext.Request.Query["step"], out int queryStep);
        if (queryStep >= 1 && queryStep <= 4) step = queryStep;
    }
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Header -->
    <div class="text-center mb-10">
        <span class="material-symbols-outlined text-5xl text-primary mb-3 block">storefront</span>
        <h1 class="text-3xl font-bold text-gray-900">Đăng Ký Bán Hàng</h1>
        <p class="text-gray-500 mt-2">Hoàn thành các bước bên dưới để mở cửa hàng trên GearZone</p>
    </div>

    <!-- Stepper -->
    <div class="flex items-center justify-between mb-10 relative">
        <!-- Progress Bar Background -->
        <div class="absolute top-5 left-[12.5%] right-[12.5%] h-1 bg-gray-200 rounded-full z-0"></div>
        <!-- Progress Bar Fill -->
        <div class="absolute top-5 left-[12.5%] h-1 bg-primary rounded-full z-[1] transition-all duration-500"
             style="width: calc(@((step - 1) * 33.33)% * 0.75)"></div>

        @{
            var steps = new[] {
                ("store", "Cửa Hàng"),
                ("badge", "Xác Minh"),
                ("account_balance", "Thanh Toán"),
                ("check_circle", "Hoàn Tất")
            };
        }

        @for (int i = 0; i < steps.Length; i++)
        {
            var idx = i + 1;
            var isCompleted = idx < step;
            var isCurrent = idx == step;
            var iconName = steps[i].Item1;
            var label = steps[i].Item2;

            <div class="flex flex-col items-center z-10 relative" style="width: 25%;">
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold border-2 transition-all duration-300
                    @(isCompleted ? "bg-primary border-primary text-white shadow-lg shadow-primary/30" :
                      isCurrent ? "bg-white border-primary text-primary shadow-lg shadow-primary/20 ring-4 ring-primary/10" :
                      "bg-white border-gray-300 text-gray-400")">
                    @if (isCompleted)
                    {
                        <span class="material-symbols-outlined text-[18px]">check</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-[18px]">@iconName</span>
                    }
                </div>
                <span class="text-xs font-semibold mt-2 @(isCurrent ? "text-primary" : isCompleted ? "text-gray-700" : "text-gray-400")">
                    Bước @idx
                </span>
                <span class="text-[10px] @(isCurrent ? "text-primary font-bold" : isCompleted ? "text-gray-600" : "text-gray-400")">
                    @label
                </span>
            </div>
        }
    </div>

    <!-- Step Content -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

        <!-- ========== STEP 1: Store Info ========== -->
        @if (step == 1)
        {
            <div class="bg-gradient-to-r from-primary/5 to-blue-50 border-b border-primary/10 p-6">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-2xl text-primary">store</span>
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Thông Tin Cửa Hàng</h2>
                        <p class="text-sm text-gray-500">Nhập thông tin cơ bản về cửa hàng của bạn</p>
                    </div>
                </div>
            </div>

            <form method="post" asp-page-handler="Step1" class="p-6 md:p-8 space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên cửa hàng <span class="text-red-500">*</span></label>
                    <input asp-for="Step1Input.StoreName" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="VD: Acme Electronics" />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Loại hình kinh doanh <span class="text-red-500">*</span></label>
                    <select asp-for="Step1Input.BusinessType" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all bg-white" required>
                        <option value="0">Cá nhân</option>
                        <option value="1">Hộ kinh doanh</option>
                        <option value="2">Doanh nghiệp</option>
                    </select>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số điện thoại <span class="text-red-500">*</span></label>
                        <input asp-for="Step1Input.Phone" type="tel" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="0xxx xxx xxx" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email liên hệ <span class="text-red-500">*</span></label>
                        <input asp-for="Step1Input.Email" type="email" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="lienhe@store.com" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Địa chỉ <span class="text-red-500">*</span></label>
                    <input asp-for="Step1Input.AddressLine" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="Số nhà, tên đường, phường/xã" />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tỉnh / Thành phố <span class="text-red-500">*</span></label>
                    <input asp-for="Step1Input.Province" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="VD: Hồ Chí Minh" />
                </div>

                <div class="flex justify-end pt-4 border-t border-gray-100">
                    <button type="submit" class="px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-primary/20 flex items-center gap-2">
                        Tiếp tục
                        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                    </button>
                </div>
            </form>
        }

        <!-- ========== STEP 2: Identity Verification ========== -->
        @if (step == 2)
        {
            <div class="bg-gradient-to-r from-amber-50 to-orange-50 border-b border-amber-100 p-6">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-2xl text-amber-600">badge</span>
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Xác Minh Danh Tính</h2>
                        <p class="text-sm text-gray-500">Xác minh thông tin nhân thân của chủ cửa hàng</p>
                    </div>
                </div>
            </div>

            <form method="post" asp-page-handler="Step2" class="p-6 md:p-8 space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Họ và tên (theo CCCD) <span class="text-red-500">*</span></label>
                    <input asp-for="Step2Input.FullName" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="Nguyễn Văn A" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số CCCD <span class="text-red-500">*</span></label>
                        <input asp-for="Step2Input.IdentityNumber" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="001234567890" maxlength="12" />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Mã số thuế <span class="text-red-500">*</span></label>
                        <input asp-for="Step2Input.TaxCode" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="10 hoặc 13 chữ số" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Ngày cấp <span class="text-red-500">*</span></label>
                        <input asp-for="Step2Input.IdentityIssuedDate" type="date" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required />
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Nơi cấp <span class="text-red-500">*</span></label>
                        <input asp-for="Step2Input.IdentityIssuedPlace" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="Cục CS ĐKQL cư trú và DLQG về dân cư" />
                    </div>
                </div>

                <div class="flex justify-between pt-4 border-t border-gray-100">
                    <a asp-page="./RegisterSeller" asp-route-step="1" class="px-6 py-3 text-gray-600 font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                        Quay lại
                    </a>
                    <button type="submit" class="px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-primary/20 flex items-center gap-2">
                        Tiếp tục
                        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                    </button>
                </div>
            </form>
        }

        <!-- ========== STEP 3: Banking ========== -->
        @if (step == 3)
        {
            <div class="bg-gradient-to-r from-emerald-50 to-green-50 border-b border-emerald-100 p-6">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-2xl text-emerald-600">account_balance</span>
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Thông Tin Thanh Toán</h2>
                        <p class="text-sm text-gray-500">Tài khoản ngân hàng để nhận thanh toán từ GearZone</p>
                    </div>
                </div>
            </div>

            <form method="post" asp-page-handler="Step3" class="p-6 md:p-8 space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên ngân hàng <span class="text-red-500">*</span></label>
                    <select asp-for="Step3Input.BankName" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all bg-white" required>
                        <option value="">— Chọn ngân hàng —</option>
                        <option value="Vietcombank">Vietcombank (VCB)</option>
                        <option value="BIDV">BIDV</option>
                        <option value="VietinBank">VietinBank (CTG)</option>
                        <option value="Agribank">Agribank</option>
                        <option value="Techcombank">Techcombank (TCB)</option>
                        <option value="VPBank">VPBank</option>
                        <option value="MBBank">MBBank (MB)</option>
                        <option value="ACB">ACB</option>
                        <option value="TPBank">TPBank</option>
                        <option value="Sacombank">Sacombank (STB)</option>
                        <option value="HDBank">HDBank</option>
                        <option value="SHB">SHB</option>
                        <option value="MSB">MSB</option>
                        <option value="OCB">OCB</option>
                        <option value="LienVietPostBank">LienVietPostBank</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Số tài khoản <span class="text-red-500">*</span></label>
                    <input asp-for="Step3Input.BankAccountNumber" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all" required placeholder="Nhập số tài khoản" />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Tên chủ tài khoản <span class="text-red-500">*</span></label>
                    <input asp-for="Step3Input.BankAccountName" class="block w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary focus:border-primary transition-all uppercase" required placeholder="NGUYEN VAN A" />
                    <p class="text-xs text-gray-400 mt-1">Tên chủ tài khoản nên khớp với tên trên CCCD</p>
                </div>

                <div class="flex justify-between pt-4 border-t border-gray-100">
                    <a asp-page="./RegisterSeller" asp-route-step="2" class="px-6 py-3 text-gray-600 font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                        Quay lại
                    </a>
                    <button type="submit" class="px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-blue-700 transition-all shadow-lg shadow-primary/20 flex items-center gap-2">
                        Tiếp tục
                        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                    </button>
                </div>
            </form>
        }

        <!-- ========== STEP 4: Review & Submit ========== -->
        @if (step == 4)
        {
            <div class="bg-gradient-to-r from-violet-50 to-purple-50 border-b border-violet-100 p-6">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-2xl text-violet-600">check_circle</span>
                    <div>
                        <h2 class="text-lg font-bold text-gray-900">Xem Lại & Gửi Đơn</h2>
                        <p class="text-sm text-gray-500">Kiểm tra thông tin trước khi gửi đơn đăng ký</p>
                    </div>
                </div>
            </div>

            <div class="p-6 md:p-8 space-y-6">

                <!-- Store Info Summary -->
                <div class="bg-gray-50/80 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold text-gray-800 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-[18px]">store</span>
                            Thông Tin Cửa Hàng
                        </h3>
                        <a asp-page="./RegisterSeller" asp-route-step="1" class="text-xs text-primary font-semibold hover:underline flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">edit</span> Sửa
                        </a>
                    </div>
                    <div class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
                        <div><span class="text-gray-500">Tên cửa hàng:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step1Input.StoreName</div>
                        <div><span class="text-gray-500">Loại hình:</span></div>
                        <div class="font-medium text-gray-800">
                            @(Model.Step1Input.BusinessType == GearZone.Domain.Enums.BusinessType.Individual ? "Cá nhân" :
                              Model.Step1Input.BusinessType == GearZone.Domain.Enums.BusinessType.HouseholdBusiness ? "Hộ kinh doanh" : "Doanh nghiệp")
                        </div>
                        <div><span class="text-gray-500">Điện thoại:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step1Input.Phone</div>
                        <div><span class="text-gray-500">Email:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step1Input.Email</div>
                        <div><span class="text-gray-500">Địa chỉ:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step1Input.AddressLine, @Model.Step1Input.Province</div>
                    </div>
                </div>

                <!-- Identity Summary -->
                <div class="bg-gray-50/80 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold text-gray-800 flex items-center gap-2">
                            <span class="material-symbols-outlined text-amber-600 text-[18px]">badge</span>
                            Xác Minh Danh Tính
                        </h3>
                        <a asp-page="./RegisterSeller" asp-route-step="2" class="text-xs text-primary font-semibold hover:underline flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">edit</span> Sửa
                        </a>
                    </div>
                    <div class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
                        <div><span class="text-gray-500">Họ và tên:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step2Input.FullName</div>
                        <div><span class="text-gray-500">Số CCCD:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step2Input.IdentityNumber</div>
                        <div><span class="text-gray-500">Ngày cấp:</span></div>
                        <div class="font-medium text-gray-800">@(Model.Step2Input.IdentityIssuedDate?.ToString("dd/MM/yyyy") ?? "—")</div>
                        <div><span class="text-gray-500">Nơi cấp:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step2Input.IdentityIssuedPlace</div>
                        <div><span class="text-gray-500">Mã số thuế:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step2Input.TaxCode</div>
                    </div>
                </div>

                <!-- Banking Summary -->
                <div class="bg-gray-50/80 rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="font-bold text-gray-800 flex items-center gap-2">
                            <span class="material-symbols-outlined text-emerald-600 text-[18px]">account_balance</span>
                            Thông Tin Thanh Toán
                        </h3>
                        <a asp-page="./RegisterSeller" asp-route-step="3" class="text-xs text-primary font-semibold hover:underline flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">edit</span> Sửa
                        </a>
                    </div>
                    <div class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm">
                        <div><span class="text-gray-500">Ngân hàng:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step3Input.BankName</div>
                        <div><span class="text-gray-500">Số tài khoản:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step3Input.BankAccountNumber</div>
                        <div><span class="text-gray-500">Chủ tài khoản:</span></div>
                        <div class="font-medium text-gray-800">@Model.Step3Input.BankAccountName</div>
                    </div>
                </div>

                <!-- Agreement & Submit -->
                <form method="post" asp-page-handler="Submit">
                    <div class="pt-4 border-t border-gray-100 space-y-4">
                        <label class="flex items-start gap-3 cursor-pointer select-none">
                            <input type="checkbox" id="agreeTerms" class="mt-1 w-4 h-4 rounded border-gray-300 text-primary focus:ring-primary" required />
                            <span class="text-sm text-gray-600">
                                Tôi đã đọc và đồng ý với
                                <a href="#" class="text-primary font-semibold hover:underline">Điều khoản & Điều kiện</a>
                                bán hàng trên GearZone.
                            </span>
                        </label>

                        <div class="flex justify-between">
                            <a asp-page="./RegisterSeller" asp-route-step="3" class="px-6 py-3 text-gray-600 font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-all flex items-center gap-2">
                                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                                Quay lại
                            </a>
                            <button type="submit" id="submitBtn" class="px-8 py-3.5 bg-gradient-to-r from-primary to-blue-600 text-white font-bold rounded-xl hover:from-blue-700 hover:to-blue-800 transition-all shadow-lg shadow-primary/30 flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                                <span class="material-symbols-outlined text-[20px]">send</span>
                                Gửi Đơn Đăng Ký
                            </button>
                        </div>
                    </div>
                </form>

            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        // Enable/disable submit button based on checkbox
        const checkbox = document.getElementById('agreeTerms');
        const submitBtn = document.getElementById('submitBtn');
        if (checkbox && submitBtn) {
            checkbox.addEventListener('change', function () {
                submitBtn.disabled = !this.checked;
            });
        }
    </script>
}
