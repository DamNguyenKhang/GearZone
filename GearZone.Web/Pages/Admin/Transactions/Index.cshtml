@section Scripts {
    <script>
        function toggleDetailPanel() {
            const panel = document.getElementById('detailPanel');
            if (panel.classList.contains('translate-x-full')) {
                panel.classList.remove('translate-x-full');
            } else {
                panel.classList.add('translate-x-full');
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Toggle advanced filters
            const toggleAdvancedBtn = document.getElementById('toggle-advanced-btn');
            const advancedFilters = document.getElementById('advanced-filters');
            
            if (toggleAdvancedBtn && advancedFilters) {
                toggleAdvancedBtn.addEventListener('click', function() {
                    advancedFilters.classList.toggle('hidden');
                    if (advancedFilters.classList.contains('hidden')) {
                        this.classList.remove('bg-slate-50', 'text-slate-900', 'border-slate-300');
                    } else {
                        this.classList.add('bg-slate-50', 'text-slate-900', 'border-slate-300');
                    }
                });
            }

            // Custom date toggle logic
            const dateButtons = document.querySelectorAll('.date-btn');
            const customDateInputs = document.getElementById('custom-date-inputs');
            
            dateButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Remove active styles from all buttons
                    dateButtons.forEach(b => {
                        b.classList.remove('bg-slate-100', 'text-slate-900');
                        b.classList.add('bg-transparent', 'text-slate-500');
                    });
                    
                    // Add active style to the clicked one
                    this.classList.remove('bg-transparent', 'text-slate-500');
                    this.classList.add('bg-slate-100', 'text-slate-900');
                    
                    if (this.id === 'btn-custom-date') {
                        customDateInputs.classList.remove('hidden');
                    } else {
                        customDateInputs.classList.add('hidden');
                    }
                });
            });
        });
    </script>
}
