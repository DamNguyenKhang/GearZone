@model GearZone.Application.Abstractions.Services.ProductCardViewModel

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
    <!-- Image Section -->
    <a href="/product/@Model.Slug" class="block">
        <div class="relative aspect-[4/3] bg-gray-100 overflow-hidden">
            @if (!string.IsNullOrEmpty(Model.PrimaryImageUrl))
            {
                <img alt="@Model.Name"
                     class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
                     src="@Model.PrimaryImageUrl" />
            }
            else
            {
                <div class="w-full h-full flex items-center justify-center text-gray-400">
                    <span class="material-symbols-outlined text-5xl">image</span>
                </div>
            }

            @if (Model.DiscountPercent.HasValue && Model.DiscountPercent > 0)
            {
                <div class="absolute top-3 left-3 bg-red-600 text-white text-xs font-bold px-2 py-1 rounded">
                    -@Model.DiscountPercent%
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.StoreName))
            {
                <div class="absolute top-3 right-3 bg-white/90 backdrop-blur text-xs font-semibold px-2 py-1 rounded text-primary border border-gray-100 shadow-sm flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">verified</span>
                    @Model.StoreName
                </div>
            }
        </div>
    </a>

    <!-- Info Section -->
    <div class="p-4">
        <a href="/product/@Model.Slug">
            <h3 class="text-gray-900 font-medium line-clamp-2 min-h-[3rem] mb-2 group-hover:text-primary transition-colors">
                @Model.Name
            </h3>
        </a>

        <!-- Rating Stars -->
        <div class="flex items-center gap-1 mb-3">
            <div class="flex text-yellow-400 text-sm">
                @for (int i = 0; i < Model.FullStars; i++)
                {
                    <span class="material-symbols-outlined text-[16px] star-fill">star</span>
                }
                @if (Model.HasHalfStar)
                {
                    <span class="material-symbols-outlined text-[16px] star-fill">star_half</span>
                }
                @for (int i = 0; i < Model.EmptyStars; i++)
                {
                    <span class="material-symbols-outlined text-[16px] star-fill text-gray-300">star</span>
                }
            </div>
            <span class="text-xs text-gray-500">(@Model.ReviewCount)</span>
        </div>

        <!-- Price -->
        <div class="flex items-baseline gap-2 mb-4">
            <span class="text-xl font-bold text-secondary">@Model.FormattedPrice</span>
            @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.MinPrice)
            {
                <span class="text-sm text-gray-400 line-through">@Model.FormattedOriginalPrice</span>
            }
        </div>

        <!-- Action Buttons -->
        <div class="flex gap-2">
            <button class="flex-1 py-2.5 rounded-lg border border-primary text-primary font-medium hover:bg-primary hover:text-white transition-colors flex items-center justify-center gap-2"
                    data-product-id="@Model.Id">
                <span class="material-symbols-outlined text-[18px]">add_shopping_cart</span>
                Thêm vào giỏ
            </button>
            <button class="compare-toggle-btn px-3 py-2.5 rounded-lg border border-gray-200 text-gray-400 hover:text-primary hover:border-primary transition-colors"
                    data-product-id="@Model.Id"
                    data-product-name="@Model.Name"
                    data-product-image="@Model.PrimaryImageUrl"
                    onclick="toggleCompare(this.dataset.productId, this.dataset.productName, this.dataset.productImage)"
                    title="So sánh">
                <span class="material-symbols-outlined text-[18px]">compare_arrows</span>
            </button>
        </div>
    </div>
</div>
