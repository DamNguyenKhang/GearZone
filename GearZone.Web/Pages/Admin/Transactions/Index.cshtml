@page "/admin/transactions"
@model GearZone.Web.Pages.Admin.Transactions.IndexModel
@{
    ViewData["Title"] = "Platform Transactions";
    ViewData["PageHeader"] = "Platform Transactions";
    ViewData["ActivePage"] = "Transactions";
    ViewData["Breadcrumb"] = new string[] { "Dashboard", "Finance", "Transactions" };
    Layout = "_AdminLayout";
}

<div class="flex flex-col gap-6 relative overflow-hidden">
    <!-- Live Stats Bar -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        <!-- Card 1 -->
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100/50 shrink-0">
                <span class="material-symbols-outlined">payments</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Today's Volume</p>
                <div class="flex flex-col">
                    <h3 class="text-xl font-bold text-slate-900 leading-tight">₫48,200,000</h3>
                    <p class="text-[11px] text-slate-500 mt-1">247 transactions</p>
                </div>
            </div>
        </div>
        <!-- Card 2 -->
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-green-50 text-green-600 flex items-center justify-center border border-green-100/50 shrink-0">
                <span class="material-symbols-outlined">account_balance_wallet</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Week Revenue In</p>
                <div class="flex flex-col">
                    <h3 class="text-xl font-bold text-slate-900 leading-tight">₫312,400,000</h3>
                    <p class="text-[11px] text-slate-500 mt-1">Order payments received</p>
                </div>
            </div>
        </div>
        <!-- Card 3 -->
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100/50 shrink-0">
                <span class="material-symbols-outlined">account_balance</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Week Paid Out</p>
                <div class="flex flex-col">
                    <h3 class="text-xl font-bold text-slate-900 leading-tight">₫124,500,000</h3>
                    <p class="text-[11px] text-slate-500 mt-1 font-mono hover:text-primary cursor-pointer">BATCH-2025-W44</p>
                </div>
            </div>
        </div>
        <!-- Card 4 -->
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-teal-50 text-teal-600 flex items-center justify-center border border-teal-100/50 shrink-0">
                <span class="material-symbols-outlined">local_atm</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Commission</p>
                <div class="flex flex-col">
                    <h3 class="text-xl font-bold text-slate-900 leading-tight">₫26,554,000</h3>
                    <p class="text-[11px] text-slate-500 mt-1">Collected this week</p>
                </div>
            </div>
        </div>
        <!-- Card 5 -->
        <div class="bg-white p-4 rounded-xl shadow-card border border-slate-100 flex items-center gap-4">
            <div class="size-12 rounded-lg bg-red-50 text-red-600 flex items-center justify-center border border-red-100/50 shrink-0">
                <span class="material-symbols-outlined">receipt_long</span>
            </div>
            <div>
                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider mb-1">Refunds</p>
                <div class="flex flex-col">
                    <h3 class="text-xl font-bold text-slate-900 leading-tight">₫8,200,000</h3>
                    <p class="text-[11px] text-slate-500 mt-1">12 refunds this week</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters & Actions Bar -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden">
        <form method="get" id="filter-form" class="flex flex-col">
            <input type="hidden" name="Query.PageNumber" id="page-number-input" value="1" />
            
            <!-- Primary toolbar -->
            <div class="flex flex-col lg:flex-row gap-3 p-4 items-start lg:items-center">

                <!-- Search box -->
                <div class="relative flex-1 w-full">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-slate-400 pointer-events-none">
                        <span class="material-symbols-outlined text-[20px]">search</span>
                    </span>
                    <input class="form-input w-full rounded-lg border-slate-200 bg-slate-50 pl-10 pr-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-primary focus:ring-primary focus:bg-white transition-colors"
                           placeholder="Search by ref, order code, store name…" type="text" autocomplete="off" />
                </div>

                <!-- Status quick-filter -->
                <div class="shrink-0 w-full lg:w-40">
                    <select class="form-select w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 text-sm text-slate-900 focus:border-primary focus:ring-primary shadow-sm">
                        <option value="">All Statuses</option>
                        <option value="Completed">Completed</option>
                        <option value="Pending">Pending</option>
                        <option value="Failed">Failed</option>
                        <option value="Reversed">Reversed</option>
                    </select>
                </div>

                <!-- Type quick-filter -->
                <div class="shrink-0 w-full lg:w-44">
                    <select class="form-select w-full rounded-lg border-slate-200 bg-slate-50 py-2.5 text-sm text-slate-900 focus:border-primary focus:ring-primary shadow-sm">
                        <option value="">All Types</option>
                        <option value="OrderRevenue">Order Revenue</option>
                        <option value="Commission">Commission</option>
                        <option value="Payout">Payout</option>
                        <option value="Refund">Refund</option>
                    </select>
                </div>

                <!-- Toolbar actions -->
                <div class="flex items-center gap-2 shrink-0 w-full lg:w-auto">
                    <button type="submit" class="flex-1 lg:flex-none flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-4 py-2.5 rounded-lg text-sm font-medium shadow-sm shadow-blue-500/20 transition-all">
                        <span class="material-symbols-outlined text-[18px]">search</span>
                        <span>Search</span>
                    </button>

                    <button type="button" id="toggle-advanced-btn" class="flex items-center justify-center gap-1.5 px-3.5 py-2.5 rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 hover:border-slate-300 transition-colors shadow-sm text-sm whitespace-nowrap">
                        <span class="material-symbols-outlined text-[18px]">tune</span>
                        <span class="hidden sm:inline font-medium">Filters</span>
                    </button>

                    <a href="#" class="flex items-center justify-center p-2.5 rounded-lg border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-slate-800 transition-colors bg-white shadow-sm" title="Reset all filters">
                        <span class="material-symbols-outlined text-[18px]">restart_alt</span>
                    </a>

                    <button type="button" class="flex items-center justify-center gap-1.5 px-3.5 py-2.5 rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-50 transition-colors shadow-sm text-sm whitespace-nowrap">
                        <span class="material-symbols-outlined text-[18px]">file_download</span>
                        <span class="hidden sm:inline font-medium">Export</span>
                    </button>
                </div>
            </div>

            <!-- Advanced Filters (Collapsible) -->
            <div id="advanced-filters" class="hidden border-t border-slate-100 bg-slate-50/40 px-4 pt-4 pb-5 flex flex-col gap-5">
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
                    
                    <!-- Store -->
                    <div class="space-y-1">
                        <label class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">storefront</span> Store
                        </label>
                        <select class="form-select w-full rounded-lg border-slate-200 bg-white py-2 text-sm text-slate-900 focus:border-primary focus:ring-primary shadow-sm">
                            <option value="">All Stores</option>
                            <option value="1">TechStore Official</option>
                            <option value="2">Gaming Haven</option>
                        </select>
                    </div>

                    <!-- Date Range Selection -->
                    <div class="space-y-1">
                        <label class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">calendar_today</span> Date Range
                        </label>
                        <div class="flex items-center bg-white rounded-lg border border-slate-200 p-1 shadow-sm h-[38px]">
                            <button type="button" class="date-btn flex-1 h-full px-2 text-[11px] font-medium rounded-md bg-slate-100 text-slate-900">Today</button>
                            <button type="button" class="date-btn flex-1 h-full px-2 text-[11px] font-medium rounded-md bg-transparent text-slate-500 hover:text-slate-900">Week</button>
                            <button type="button" class="date-btn flex-1 h-full px-2 text-[11px] font-medium rounded-md bg-transparent text-slate-500 hover:text-slate-900">Month</button>
                            <button type="button" id="btn-custom-date" class="date-btn flex-1 h-full px-2 text-[11px] font-medium rounded-md bg-transparent text-slate-500 hover:text-slate-900">Custom</button>
                        </div>
                    </div>

                    <!-- Custom Date Inputs (Hidden by default) -->
                    <div id="custom-date-inputs" class="hidden space-y-1 md:col-span-2 xl:col-span-1 xl:border-l border-slate-200 xl:pl-4 transition-all">
                        <label class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">edit_calendar</span> Custom Range
                        </label>
                        <div class="flex items-center gap-1.5 h-[38px]">
                            <input type="date" class="form-input min-w-0 w-full h-full rounded-lg border-slate-200 bg-white py-1.5 text-xs px-2 shadow-sm" />
                            <span class="text-slate-300 flex-shrink-0 text-lg font-light">—</span>
                            <input type="date" class="form-input min-w-0 w-full h-full rounded-lg border-slate-200 bg-white py-1.5 text-xs px-2 shadow-sm" />
                        </div>
                    </div>

                    <!-- Amount Range -->
                    <div class="space-y-1">
                        <label class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">payments</span> Amount Range (₫)
                        </label>
                        <div class="flex items-center gap-1.5">
                            <input type="number" placeholder="Min" class="form-input min-w-0 w-full rounded-lg border-slate-200 bg-white py-2 text-sm px-2.5 shadow-sm" />
                            <span class="text-slate-300 flex-shrink-0 text-lg font-light">—</span>
                            <input type="number" placeholder="Max" class="form-input min-w-0 w-full rounded-lg border-slate-200 bg-white py-2 text-sm px-2.5 shadow-sm" />
                        </div>
                    </div>
                </div>

                <!-- Row 2: Toggles + Actions -->
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-2">
                    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                        <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-tight mr-2">Direction</label>
                        <div class="flex items-center gap-4">
                            <label class="flex items-center gap-2 cursor-pointer select-none">
                                <input type="radio" name="direction" value="all" checked class="text-primary focus:ring-primary h-4 w-4 border-slate-300" />
                                <span class="text-sm font-medium text-slate-700">All</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer select-none">
                                <input type="radio" name="direction" value="in" class="text-primary focus:ring-primary h-4 w-4 border-slate-300" />
                                <span class="text-sm font-medium text-slate-700">In (Credit)</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer select-none">
                                <input type="radio" name="direction" value="out" class="text-primary focus:ring-primary h-4 w-4 border-slate-300" />
                                <span class="text-sm font-medium text-slate-700">Out (Debit)</span>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="w-full sm:w-auto flex items-center justify-center gap-2 bg-slate-800 hover:bg-slate-900 text-white px-6 py-2 rounded-lg text-sm font-semibold transition-colors shadow-sm">
                        <span class="material-symbols-outlined text-[17px]">check</span> Apply Filters
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Data Table Card -->
    <div class="bg-white rounded-xl shadow-card border border-slate-100 overflow-hidden flex flex-col">
        <div class="px-6 py-4 bg-slate-50/50 border-b border-slate-100 flex flex-col sm:flex-row justify-between items-center gap-4">
            <p class="text-sm font-medium text-slate-600">
                Showing <span class="text-slate-900">1,247</span> transactions | 
                Total: <span class="text-emerald-600 font-bold">+₫312,400,000</span>
            </p>
            <div class="flex gap-4 items-center">
                <button class="text-xs font-semibold text-slate-600 flex items-center gap-1.5 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined text-[16px]">view_list</span> Group by Store
                </button>
                <div class="w-px h-4 bg-slate-300"></div>
                <button class="text-xs font-semibold text-slate-600 flex items-center gap-1.5 hover:text-primary transition-colors">
                    Sort: Newest <span class="material-symbols-outlined text-[16px]">expand_more</span>
                </button>
            </div>
        </div>

        <div class="overflow-x-auto w-full pb-0.5">
            <table class="w-full text-left border-collapse min-w-max">
                <thead>
                    <tr class="border-b border-slate-100 bg-slate-50/50 text-slate-500">
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest whitespace-nowrap">#</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest whitespace-nowrap">Date & Time</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest whitespace-nowrap">Type</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest whitespace-nowrap">Store</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest whitespace-nowrap">Reference</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest whitespace-nowrap">Description</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest text-right whitespace-nowrap">Amount</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest text-center whitespace-nowrap">Dir</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest text-right whitespace-nowrap">Balance</th>
                        <th class="py-3 px-4 text-[11px] font-bold uppercase tracking-widest text-right whitespace-nowrap">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    <!-- Row 1: Order Revenue -->
                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer" onclick="toggleDetailPanel()">
                        <td class="py-4 px-4 text-slate-400 font-mono text-xs">1247</td>
                        <td class="py-4 px-4 whitespace-nowrap">
                            <div class="font-medium text-slate-900">Oct 24, 2023</div>
                            <div class="text-[10px] text-slate-400">14:32:01</div>
                        </td>
                        <td class="py-4 px-4">
                            <span class="px-2 py-1 rounded-md text-[10px] font-bold uppercase bg-emerald-100/60 text-emerald-700">Order Revenue</span>
                        </td>
                        <td class="py-4 px-4">
                            <div class="flex items-center gap-2">
                                <div class="size-6 bg-emerald-50 text-emerald-600 rounded flex items-center justify-center text-[10px] font-bold shrink-0">TS</div>
                                <span class="font-medium text-slate-900">TechStore Official</span>
                            </div>
                        </td>
                        <td class="py-4 px-4 text-primary font-medium text-[13px]">ORD-99812</td>
                        <td class="py-4 px-4 text-slate-600 max-w-[200px] truncate text-[13px]">Payment for iPhone 15 Pro Max...</td>
                        <td class="py-4 px-4 text-right font-bold text-emerald-600">+₫2,350,000</td>
                        <td class="py-4 px-4 text-center">
                            <span class="inline-flex items-center text-emerald-600 font-bold text-[10px] gap-0.5"><span class="material-symbols-outlined text-[14px]">arrow_downward</span> IN</span>
                        </td>
                        <td class="py-4 px-4 text-right text-slate-500 text-[13px]">₫44,120,400</td>
                        <td class="py-4 px-4 text-right">
                            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-600">
                                <span class="size-1.5 rounded-full bg-emerald-500"></span> Completed
                            </span>
                        </td>
                    </tr>
                    
                    <!-- Row 2: Commission Link -->
                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer" onclick="toggleDetailPanel()">
                        <td class="py-4 px-4 text-slate-400 font-mono text-xs">1246</td>
                        <td class="py-4 px-4 whitespace-nowrap">
                            <div class="font-medium text-slate-900">Oct 24, 2023</div>
                            <div class="text-[10px] text-slate-400">14:32:02</div>
                        </td>
                        <td class="py-4 px-4 flex items-center h-[58px]">
                            <!-- Bracket equivalent -->
                            <div class="w-2 h-full border-l-[2px] border-y-[2px] border-slate-200 rounded-l mr-2 opacity-50 shrink-0"></div>
                            <span class="px-2 py-1 rounded-md text-[10px] font-bold uppercase bg-teal-100/60 text-teal-700">Commission</span>
                        </td>
                        <td class="py-4 px-4">
                            <div class="flex items-center gap-2 opacity-60">
                                <div class="size-6 bg-emerald-50 text-emerald-600 rounded flex items-center justify-center text-[10px] font-bold shrink-0">TS</div>
                                <span class="font-medium text-slate-900">TechStore Official</span>
                            </div>
                        </td>
                        <td class="py-4 px-4 text-primary font-medium text-[13px]">CMS-99812</td>
                        <td class="py-4 px-4 text-slate-500 italic text-xs">8.5% Platform fee for ORD-99812</td>
                        <td class="py-4 px-4 text-right font-bold text-teal-600">−₫199,750</td>
                        <td class="py-4 px-4 text-center">
                            <span class="inline-flex items-center text-red-500 font-bold text-[10px] gap-0.5"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> OUT</span>
                        </td>
                        <td class="py-4 px-4 text-right text-slate-500 text-[13px]">₫43,920,650</td>
                        <td class="py-4 px-4 text-right">
                            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-600">
                                <span class="size-1.5 rounded-full bg-emerald-500"></span> Completed
                            </span>
                        </td>
                    </tr>

                    <!-- Row 3: Payout -->
                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer border-t-[3px] border-dashed border-slate-100" onclick="toggleDetailPanel()">
                        <td class="py-4 px-4 text-slate-400 font-mono text-xs">1245</td>
                        <td class="py-4 px-4 whitespace-nowrap">
                            <div class="font-medium text-slate-900">Oct 23, 2023</div>
                            <div class="text-[10px] text-slate-400">09:00:00</div>
                        </td>
                        <td class="py-4 px-4">
                            <span class="px-2 py-1 rounded-md text-[10px] font-bold uppercase bg-indigo-100/60 text-indigo-700">Payout</span>
                        </td>
                        <td class="py-4 px-4 text-slate-400 italic text-[13px]">Global Distribution</td>
                        <td class="py-4 px-4 text-indigo-600 font-medium text-[13px]">PYT-B7720</td>
                        <td class="py-4 px-4 text-slate-600 text-[13px]">Weekly settlement transfer</td>
                        <td class="py-4 px-4 text-right font-bold text-indigo-600">−₫10,431,000</td>
                        <td class="py-4 px-4 text-center">
                            <span class="inline-flex items-center text-indigo-600 font-bold text-[10px] gap-0.5"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> OUT</span>
                        </td>
                        <td class="py-4 px-4 text-right text-slate-500 text-[13px]">₫33,489,650</td>
                        <td class="py-4 px-4 text-right">
                            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-600">
                                <span class="size-1.5 rounded-full bg-emerald-500"></span> Completed
                            </span>
                        </td>
                    </tr>

                    <!-- Row 4: Refund -->
                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer" onclick="toggleDetailPanel()">
                        <td class="py-4 px-4 text-slate-400 font-mono text-xs">1244</td>
                        <td class="py-4 px-4 whitespace-nowrap">
                            <div class="font-medium text-slate-900">Oct 23, 2023</div>
                            <div class="text-[10px] text-slate-400">10:45:15</div>
                        </td>
                        <td class="py-4 px-4">
                            <span class="px-2 py-1 rounded-md text-[10px] font-bold uppercase bg-red-100/60 text-red-700">Refund</span>
                        </td>
                        <td class="py-4 px-4 font-medium text-slate-900">Gaming Haven</td>
                        <td class="py-4 px-4 text-red-600 font-medium text-[13px]">REF-00122</td>
                        <td class="py-4 px-4 text-slate-600 text-[13px]">Customer return: RMA-442</td>
                        <td class="py-4 px-4 text-right font-bold text-red-600">−₫1,200,000</td>
                        <td class="py-4 px-4 text-center">
                            <span class="inline-flex items-center text-red-500 font-bold text-[10px] gap-0.5"><span class="material-symbols-outlined text-[14px]">arrow_upward</span> OUT</span>
                        </td>
                        <td class="py-4 px-4 text-right text-slate-500 text-[13px]">₫32,289,650</td>
                        <td class="py-4 px-4 text-right">
                            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-600">
                                <span class="size-1.5 rounded-full bg-emerald-500"></span> Completed
                            </span>
                        </td>
                    </tr>

                    <!-- Row 5: Failed Payout -->
                    <tr class="bg-red-50/40 hover:bg-red-50/70 transition-all cursor-pointer" onclick="toggleDetailPanel()">
                        <td class="py-4 px-4 text-slate-400 font-mono text-xs">1241</td>
                        <td class="py-4 px-4 whitespace-nowrap">
                            <div class="font-medium text-slate-900">Oct 22, 2023</div>
                            <div class="text-[10px] text-slate-400">16:20:10</div>
                        </td>
                        <td class="py-4 px-4">
                            <span class="px-2 py-1 rounded-md text-[10px] font-bold uppercase bg-red-200/50 text-red-800">Payout</span>
