@page
@model GearZone.Web.Pages.Checkout.SuccessModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Order Success - GearZone";
}

<main class="flex flex-col items-center justify-center py-12 px-4 @@container">
    <!-- Main Success Card -->
    <div class="w-full max-w-[600px] bg-white dark:bg-slate-900 rounded-xl shadow-lg border border-slate-100 dark:border-slate-800 p-8 @@xl:p-12">
        <!-- Success Icon & Message -->
        <div class="flex flex-col items-center text-center mb-10">
            <div class="w-20 h-20 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-5xl font-bold">check_circle</span>
            </div>
            <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">Order Successfully Placed!</h1>
            <p class="text-slate-500 dark:text-slate-400 max-w-sm leading-relaxed">
                Thank you for your purchase. We've sent a confirmation email to @(User.FindFirstValue(System.Security.Claims.ClaimTypes.Email) ?? "your email address").
            </p>
        </div>

        <!-- Order Summary Box -->
        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-6 mb-6">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4">Order Summary</h2>
            <div class="space-y-4">
                <div class="flex justify-between items-center">
                    <span class="text-slate-600 dark:text-slate-400">Order ID</span>
                    <span class="font-medium text-slate-900 dark:text-slate-100">#@Model.Order.OrderCode</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-slate-600 dark:text-slate-400">Payment Method</span>
                    <div class="flex items-center gap-2">
                        <span class="font-medium text-slate-900 dark:text-slate-100">@Model.PaymentMethodName</span>
                    </div>
                </div>
                <div class="pt-4 border-t border-slate-200 dark:border-slate-700 flex justify-between items-center">
                    <span class="text-slate-900 dark:text-slate-100 font-semibold">Total Amount</span>
                    <span class="text-xl font-bold text-primary">@Model.Order.GrandTotal.ToString("N0")₫</span>
                </div>
            </div>
        </div>

        <!-- Delivery Estimation -->
        <div class="flex items-center gap-4 bg-primary/5 dark:bg-primary/10 border border-primary/10 rounded-lg p-5 mb-10">
            <div class="text-primary">
                <span class="material-symbols-outlined text-3xl">local_shipping</span>
            </div>
            <div>
                <p class="text-xs font-semibold text-primary uppercase tracking-wide">Delivery Estimation</p>
                <p class="text-slate-700 dark:text-slate-300 font-medium">Estimated arrival: @Model.Order.CreatedAt.AddDays(3).ToString("MMM dd") - @Model.Order.CreatedAt.AddDays(5).ToString("MMM dd, yyyy")</p>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col gap-4">
            <a asp-page="/Buyer/Orders/Details" asp-route-id="@Model.Order.Id" class="w-full bg-primary hover:bg-blue-700 text-white font-bold py-4 rounded-lg transition-all shadow-md flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">package_2</span>
                Track Order
            </a>
            <a asp-page="/Public/Catalog/Browse" class="w-full bg-transparent hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-700 dark:text-slate-200 font-bold py-4 rounded-lg border-2 border-slate-200 dark:border-slate-700 transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">shopping_basket</span>
                Continue Shopping
            </a>
        </div>
    </div>

    <!-- Support Info Footer -->
    <div class="mt-8 text-center">
        <p class="text-slate-500 dark:text-slate-400 text-sm">
            Need help with your order? <a class="text-primary font-semibold hover:underline" href="#">Contact Support</a>
        </p>
    </div>
</main>
